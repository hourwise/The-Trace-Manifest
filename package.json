{
  "name": "the-trace-manifest",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build && node scripts/verify-cloudflare-routes.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "deploy:site": "npm run build",
    "deploy:worker": "wrangler deploy --config wrangler.worker.toml",
    "worker:dev": "wrangler dev --config wrangler.worker.toml --test-scheduled",
    "typecheck": "astro check && tsc --noEmit -p workers/tsconfig.json",
    "test": "tsx workers/ingestion/__tests__/run-tests.ts && tsx tests/stabilisation.test.ts",
    "test:security": "node scripts/security-check.mjs",
    "test:discovery-feeds": "tsx scripts/check-discovery-feeds.ts",
    "test:migrations": "node scripts/validate-migrations.mjs && node scripts/validate-legacy-production-migration.mjs",
    "test:diff": "node scripts/diff-check.mjs",
    "audit:production": "npm audit --omit=dev --audit-level=critical",
    "ci": "npm run test:diff && npm run typecheck && npm test && npm run test:migrations && npm run test:security && npm run build"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/rss": "^4.0.0",
    "@astrojs/sitemap": "^3.0.0",
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260712.1",
    "@types/node": "^22.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "wrangler": "^4.110.0"
  }
}
