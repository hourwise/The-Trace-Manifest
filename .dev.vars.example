# Copy to .dev.vars for local development only. Never commit real values.
TRACE_ENVIRONMENT=development
TRACE_ALLOWED_ORIGINS=http://localhost:4321,http://127.0.0.1:4321

# Public AI is fail-closed. Enable only after D1 migrations and controls exist.
TRACE_AI_PUBLIC_ENABLED=false
TRACE_AI_EDITORIAL_ENABLED=false
TRACE_AI_SCHEDULED_ENABLED=false
TRACE_AI_GLOBAL_KILL_SWITCH=false
DEEPSEEK_API_KEY=replace-with-local-secret
TRACE_VISITOR_HASH_SECRET=replace-with-at-least-32-random-characters
TRACE_AI_PUBLIC_MODEL=deepseek-v4-flash
TRACE_AI_EDITORIAL_MODEL=deepseek-v4-pro
TRACE_AI_DAILY_PUBLIC_BUDGET_USD=1.00
TRACE_AI_MONTHLY_PUBLIC_BUDGET_USD=10.00
TRACE_AI_ASK_DAILY_BUDGET_USD=1.00
TRACE_AI_EDITORIAL_DAILY_BUDGET_USD=1.00
TRACE_AI_MAX_COST_PER_REQUEST_USD=0.02
TRACE_AI_MAX_QUESTION_LENGTH=1000
TRACE_AI_MAX_EVIDENCE_EXCERPTS=8
TRACE_AI_MAX_INPUT_TOKENS=12000
TRACE_AI_MAX_OUTPUT_TOKENS=1500
TRACE_AI_REQUEST_TIMEOUT_MS=25000
TRACE_AI_DAILY_QUESTIONS=3
TRACE_AI_MAX_CONCURRENT=1

# Replace every pricing placeholder with reviewed current provider pricing.
TRACE_AI_FLASH_INPUT_USD_PER_MILLION=replace-with-reviewed-price
TRACE_AI_FLASH_OUTPUT_USD_PER_MILLION=replace-with-reviewed-price
TRACE_AI_PRO_INPUT_USD_PER_MILLION=replace-with-reviewed-price
TRACE_AI_PRO_OUTPUT_USD_PER_MILLION=replace-with-reviewed-price

# Cloudflare Access and the first-party admin proxy.
CF_ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com
CF_ACCESS_AUD=replace-with-access-application-audience
TRACE_ADMIN_READERS=reader@example.com
TRACE_ADMIN_PUBLISHERS=publisher@example.com
TRACE_INGESTION_WORKER_URL=https://replace-with-worker-host.example
TRACE_INTERNAL_SERVICE_SECRET=replace-with-at-least-32-random-characters

# Optional Worker-only secret for higher GitHub API limits.
GITHUB_TOKEN=replace-with-github-token-or-remove
