---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedProviders } from "../../lib/server/catalog-data";

export const prerender = false;
let providers: Awaited<ReturnType<typeof getPublishedProviders>> = [];
let unavailable = false;
try { providers = await getPublishedProviders(Astro.locals.runtime.env.DB); } catch { unavailable = true; }
---

<BaseLayout title="Provider Directory" description="Reviewed provider records published by The Trace Manifest.">
  <div class="wrap" style="max-width:54rem;">
    <h1 class="display h1">Provider Directory</h1>
    <p class="lead">Only reviewed and explicitly published provider records appear here.</p>
    {unavailable ? <div class="card" style="margin-top:2rem;"><p class="meta">Provider data is temporarily unavailable.</p></div> :
      providers.length === 0 ? <div class="card" style="margin-top:2rem;"><p class="meta">No provider records have completed editorial review and publication yet.</p></div> :
      <div class="grid-2" style="margin-top:2rem;">{providers.map((provider) => <article class="card">
        <h2>{provider.website ? <a href={provider.website} rel="noopener noreferrer">{provider.name}</a> : provider.name}</h2>
        <p class="meta">API compatibility: {provider.apiCompatibility ?? "Not recorded"}</p>
        <p class="meta">Regions: {provider.regions.join(", ") || "Not recorded"}</p>
        <p class="meta">Enterprise support: {provider.enterpriseSupport ? "Recorded as available" : "Not recorded as available"}</p>
        {provider.lastVerifiedAt && <p class="meta">Last verified: {provider.lastVerifiedAt}</p>}
      </article>)}</div>}
    <p class="meta" style="margin-top:2rem;">Pricing is withheld until each provider-model relationship has its own reviewed publication state.</p>
  </div>
</BaseLayout>
