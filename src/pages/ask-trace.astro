---
import BaseLayout from "../layouts/BaseLayout.astro";

export const prerender = false;
const askEnabled = Astro.locals.runtime.env.TRACE_AI_PUBLIC_ENABLED === "true";
const suggestions = [
  "What changed in MCP security this week?",
  "What published evidence does TRACE have about coding agents?",
  "Are recent model benchmark claims independently supported?",
];
---

<BaseLayout title="Ask TRACE" description="Evidence-bounded answers from reviewed, published TRACE records when the governed service is enabled.">
  <div class="wrap" style="max-width:42rem;">
    <h1 class="display h1">Ask TRACE</h1>
    <p class="lead" style="margin:.5rem 0 2rem;">
      {askEnabled
        ? "Search reviewed, published TRACE evidence and follow the source trail."
        : "The governed Ask TRACE service is currently disabled. No model request will be made."}
    </p>

    <form id="ask-form" data-enabled={String(askEnabled)} autocomplete="off">
      <div class="field" style="min-height:56px;padding:.5rem 1rem;border-radius:var(--radius-lg);">
        <input id="question-input" maxlength="1000" disabled={!askEnabled} aria-label="Ask TRACE a question" placeholder="Ask about published AI evidence…" style="font-size:1rem;" />
        <button id="ask-submit" class="btn btn-primary" type="submit" disabled={!askEnabled}>Ask</button>
      </div>
      <p id="char-count" class="meta" style="margin-top:.5rem;text-align:right;">0 / 1,000</p>
    </form>

    <div id="ask-status" class="meta" role="status" aria-live="polite" style="display:none;margin-top:1rem;"></div>
    <div id="ask-error" class="card" role="alert" style="display:none;margin-top:1.5rem;"></div>
    <article id="ask-result" class="card" style="display:none;margin-top:2rem;">
      <div style="display:flex;gap:.75rem;align-items:center;flex-wrap:wrap;"><span id="confidence-badge"></span><span id="request-id" class="meta"></span></div>
      <div id="answer-text" class="prose" style="margin-top:1rem;"></div>
      <div id="key-points" style="margin-top:1rem;"></div>
      <section id="caveats" style="display:none;margin-top:1rem;"><h2 style="font-size:.95rem;">Caveats</h2><ul id="caveat-list"></ul></section>
      <section id="evidence" style="display:none;margin-top:1.25rem;"><h2 style="font-size:.95rem;">Published evidence</h2><ol id="citation-list"></ol><p id="freshness" class="meta"></p></section>
      <section id="disagreements" style="display:none;margin-top:1rem;"><h2 style="font-size:.95rem;">Material disagreement</h2><ul id="disagreement-list"></ul></section>
    </article>

    {askEnabled && <section style="margin-top:2.5rem;"><h2 style="font-size:1rem;">Suggested questions</h2><div class="chip-row">{suggestions.map((question) => <button type="button" class="chip suggestion" data-question={question}>{question}</button>)}</div></section>}

    <section class="card" style="margin-top:2.5rem;background:var(--surface-2);">
      <h2 style="font-size:1rem;">Current product boundary</h2>
      <p class="meta">Only evidence attached to explicitly reviewed and published stories can be retrieved. TRACE does not browse arbitrary URLs.</p>
      <p class="meta">Inadequate evidence returns a non-answer. Confidence is calculated from source count, tier, evidence quality, disagreement and freshness—not model self-assessment.</p>
      <p class="meta">Generated factual claims must reference supplied source and claim IDs; unknown references cause a safe non-answer.</p>
    </section>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById("ask-form") as HTMLFormElement;
  const input = document.getElementById("question-input") as HTMLInputElement;
  const submit = document.getElementById("ask-submit") as HTMLButtonElement;
  const status = document.getElementById("ask-status") as HTMLElement;
  const error = document.getElementById("ask-error") as HTMLElement;
  const result = document.getElementById("ask-result") as HTMLElement;
  let submitting = false;

  input?.addEventListener("input", () => {
    const count = document.getElementById("char-count");
    if (count) count.textContent = `${input.value.length} / 1,000`;
  });
  document.querySelectorAll(".suggestion").forEach((button) => button.addEventListener("click", () => {
    input.value = (button as HTMLElement).dataset.question ?? "";
    input.dispatchEvent(new Event("input"));
  }));

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const question = input.value.trim();
    if (submitting || form.dataset.enabled !== "true" || !question) return;
    submitting = true; submit.disabled = true; result.style.display = "none"; error.style.display = "none";
    status.style.display = "block"; status.textContent = "Searching eligible published evidence…";
    try {
      const response = await fetch("/api/trace/ask", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ question }),
      });
      const data: unknown = await response.json();
      status.style.display = "none";
      if (!response.ok) {
        error.style.display = "block";
        error.textContent = errorMessage(data);
        return;
      }
      renderAnswer(data);
    } catch {
      status.style.display = "none"; error.style.display = "block"; error.textContent = "Unable to reach Ask TRACE.";
    } finally {
      submitting = false; submit.disabled = false;
    }
  });

  function renderAnswer(data: any): void {
    result.style.display = "block";
    const badge = document.getElementById("confidence-badge")!;
    const confidenceLabel = String(data.confidence ?? "insufficient_evidence").replaceAll("_", " ");
    const confidenceScore = typeof data.confidenceScore === "number" ? ` (${Math.round(data.confidenceScore)}/100)` : "";
    badge.textContent = `${confidenceLabel}${confidenceScore}`;
    badge.className = `badge badge-${data.confidence === "high" ? "confirmed" : data.confidence === "medium" ? "provisional" : "unverified"}`;
    document.getElementById("request-id")!.textContent = data.requestId ? `ID: ${data.requestId}` : "";
    document.getElementById("answer-text")!.textContent = data.answer ?? "No validated answer was produced.";
    const points = document.getElementById("key-points")!;
    points.replaceChildren(...listWithHeading("Key points", data.keyPoints));
    renderList("caveats", "caveat-list", data.caveats);
    renderList("disagreements", "disagreement-list", data.disagreements?.length ? data.disagreements : data.hasMaterialDisagreement ? ["The supplied evidence includes disputed or contradictory records."] : []);

    const evidence = document.getElementById("evidence")!;
    const citations = Array.isArray(data.citations) ? data.citations : [];
    if (citations.length > 0) {
      evidence.style.display = "block";
      const list = document.getElementById("citation-list")!;
      list.replaceChildren(...citations.map((citation: any) => citationNode(citation)));
      document.getElementById("freshness")!.textContent = data.freshestObservedAt
        ? `Freshest supplied observation: ${new Date(data.freshestObservedAt).toLocaleDateString("en-GB")}.`
        : "No observation date was available.";
    } else evidence.style.display = "none";
  }

  function listWithHeading(heading: string, values: unknown): HTMLElement[] {
    if (!Array.isArray(values) || values.length === 0) return [];
    const title = document.createElement("h2"); title.textContent = heading; title.style.fontSize = ".95rem";
    const list = document.createElement("ul");
    values.forEach((value) => { const item = document.createElement("li"); item.textContent = String(value); list.appendChild(item); });
    return [title, list];
  }
  function renderList(sectionId: string, listId: string, values: unknown): void {
    const section = document.getElementById(sectionId)!;
    if (!Array.isArray(values) || values.length === 0) { section.style.display = "none"; return; }
    section.style.display = "block";
    const list = document.getElementById(listId)!;
    list.replaceChildren(...values.map((value) => { const item = document.createElement("li"); item.textContent = String(value); return item; }));
  }
  function citationNode(citation: any): HTMLLIElement {
    const item = document.createElement("li");
    const url = safeUrl(citation.sourceUrl);
    if (url) { const link = document.createElement("a"); link.href = url; link.rel = "noopener noreferrer"; link.textContent = citation.sourceName ?? citation.sourceId; item.appendChild(link); }
    else item.textContent = citation.sourceName ?? citation.sourceId;
    item.appendChild(document.createTextNode(` — ${citation.sourceClassification ?? "Published TRACE evidence"}`));
    return item;
  }
  function errorMessage(value: unknown): string {
    if (!value || typeof value !== "object") return "Ask TRACE is unavailable.";
    const data = value as { message?: unknown; error?: unknown };
    return typeof data.message === "string"
      ? data.message
      : typeof data.error === "string"
        ? data.error
        : "Ask TRACE is unavailable.";
  }
  function safeUrl(value: unknown): string | null {
    if (typeof value !== "string") return null;
    try {
      const url = new URL(value);
      return (url.protocol === "https:" || url.protocol === "http:") && !url.username && !url.password ? url.href : null;
    } catch { return null; }
  }
</script>
