---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page not found — The Trace Manifest"
  description="The page you requested could not be found."
>
  <main id="main-content" class="section" style="border-top:0;padding-top:2rem;">
    <div class="wrap" style="text-align:center;padding:3rem 1rem;">
      <p style="font-size:4rem;font-weight:700;color:var(--muted);margin-bottom:0.5rem;line-height:1;">404</p>
      <h1 style="font-size:1.5rem;margin-bottom:0.75rem;">Page not found</h1>
      <p class="meta" style="max-width:42ch;margin-inline:auto;margin-bottom:1.5rem;">
        The page you requested doesn't exist or has moved. If you followed a link from elsewhere, the content may have been superseded or corrected — check our <a href="/corrections">corrections ledger</a>.
      </p>
      <div style="display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap;">
        <a href="/" class="btn btn-primary">Go to Latest</a>
        <a href="/ask" class="btn btn-secondary">Ask a question</a>
        <a href="/feed" class="btn btn-ghost">Browse the feed</a>
      </div>
    </div>
  </main>
</BaseLayout>
