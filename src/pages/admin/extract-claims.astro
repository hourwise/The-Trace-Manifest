---
// ADR 0016: Admin operations — manual claim extraction trigger.
// Server-rendered page with direct D1 access. Imports the regex-based
// extraction engine from the Worker module.
import BaseLayout from "../../layouts/BaseLayout.astro";
import { runClaimExtraction, extractClaimsFromItem } from "../../../workers/ingestion/extract-claims";

export const prerender = false;

interface DebugSample { id: number; title: string; rawText: string; normalizedText: string; textLen: number; claimCount: number; claims: string[]; sourceTier: string; }

let result: { processed: number; claimsExtracted: number; evidenceCreated: number } | null = null;
let error: string | null = null;
let debugSamples: DebugSample[] = [];

// Normalise helper — must match extract-claims.ts exactly
function normaliseText(text: string): string {
  return text.replace(/<[^>]*>/g, "").replace(/\s+/g, " ").replace(/&#?[a-z0-9]+;/gi, "").trim();
}

if (Astro.request.method === "POST") {
  try {
    const db = Astro.locals.runtime.env.DB;
    // First run a diagnostic sample on 3 items
    if (Astro.request.headers.get("content-type")?.includes("multipart/form-data") || new URL(Astro.request.url).searchParams.has("debug")) {
      const sampleRows = await db.prepare(
        `SELECT fi.id, fi.title, fi.summary, fi.content_excerpt, s.tier as source_tier, s.treatment as source_treatment
         FROM feed_items fi JOIN sources s ON s.id=fi.source_id
         WHERE fi.ingestion_status IN ('clustered','classified')
         AND (fi.summary IS NOT NULL OR fi.content_excerpt IS NOT NULL)
         AND fi.fetched_at >= datetime('now', '-7 days')
         LIMIT 3`
      ).all<{ id: number; title: string; summary: string | null; content_excerpt: string | null; source_tier: string; source_treatment: string }>();
      for (const row of sampleRows.results) {
        const rawText = [row.title, row.summary ?? "", row.content_excerpt ?? ""].join(". ");
        const normText = normaliseText(rawText);
        // Claims from raw text (like diagnostic)
        const rawClaims = extractClaimsFromItem(
          row as any, row.source_tier ?? "C", row.source_treatment ?? "",
        );
        debugSamples.push({
          id: row.id, title: row.title,
          rawText: rawText.substring(0, 300), normalizedText: normText.substring(0, 300),
          textLen: normText.length,
          claimCount: rawClaims.length,
          claims: rawClaims.slice(0, 3).map((c: any) => c.claimText?.substring(0, 100)),
          sourceTier: row.source_tier ?? "C",
        });
      }
    }
    result = await runClaimExtraction(db);
  } catch (e: any) {
    error = e.message ?? String(e);
  }
}
---

<BaseLayout title="Admin — Extract Claims" description="Manually trigger claim extraction for feed items.">
  <div class="wrap" style="max-width:700px;">
    <h1>Extract Claims</h1>
    <p class="meta" style="margin-bottom:2rem;">
      <a href="/admin">← Admin home</a> &middot; Run regex-based claim extraction on clustered/classified feed items.
    </p>

    <section class="card" style="margin-bottom:2rem;">
      <p>This processes up to 500 feed items (ingested within the last 7 days) that have been clustered or classified but not yet had claims extracted. Extraction is regex-based — no AI cost.</p>
      <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-top:1rem;">
        <form method="POST">
          <button type="submit" class="btn btn-primary">Run Claim Extraction</button>
        </form>
        <form method="POST" action="?debug">
          <button type="submit" class="btn" style="background:var(--bg-muted);">Diagnose — Sample 3 Items</button>
        </form>
      </div>
    </section>

    {debugSamples.length > 0 && (
      <section class="card" style="margin-bottom:2rem;">
        <h2 style="font-size:1.1rem;margin-bottom:0.75rem;">Diagnostic Sample</h2>
        {debugSamples.map((s) => (
          <div style="margin-bottom:1rem;padding-bottom:0.75rem;border-bottom:1px solid var(--border-light);">
            <p style="font-weight:600;font-size:0.85rem;">#{s.id} — {s.title} <span class="badge badge-sm">Tier {s.sourceTier}</span></p>
            <p class="meta" style="font-size:0.7rem;margin-bottom:0.25rem;">Normalized length: {s.textLen} chars · Claims found: <strong>{s.claimCount}</strong></p>
            <details><summary style="font-size:0.7rem;cursor:pointer;">Raw text (first 300 chars)</summary>
              <pre style="font-size:0.65rem;white-space:pre-wrap;word-break:break-word;background:var(--bg-muted);padding:0.5rem;margin-top:0.25rem;max-height:120px;overflow-y:auto;">{s.rawText}</pre>
            </details>
            <details><summary style="font-size:0.7rem;cursor:pointer;">Normalized text (first 300 chars)</summary>
              <pre style="font-size:0.65rem;white-space:pre-wrap;word-break:break-word;background:var(--bg-muted);padding:0.5rem;margin-top:0.25rem;max-height:120px;overflow-y:auto;">{s.normalizedText}</pre>
            </details>
            {s.claimCount > 0 && (
              <details><summary style="font-size:0.7rem;cursor:pointer;">Show claims</summary>
                <ul style="font-size:0.7rem;margin-top:0.25rem;">
                  {s.claims.map((c) => `<li>${c}</li>`)}
                </ul>
              </details>
            )}
          </div>
        ))}
      </section>
    )}

    {result !== null && (
      <section class="card" style={error ? "border-left:3px solid var(--ev-disputed)" : "border-left:3px solid var(--ev-confirmed)"}>
        <h2 style="font-size:1.1rem;margin-bottom:0.5rem;">{error ? "Extraction Failed" : "Extraction Complete"}</h2>
        {error ? (
          <p style="color:var(--ev-disputed);">{error}</p>
        ) : (
          <div>
            <p><strong>{result.processed}</strong> items processed</p>
            <p><strong>{result.claimsExtracted}</strong> claims extracted</p>
            <p><strong>{result.evidenceCreated}</strong> evidence records created</p>
            {result.processed === 0 && <p class="meta" style="margin-top:0.5rem;">No eligible items found. Items must be clustered/classified within the last 7 days.</p>}
          </div>
        )}
      </section>
    )}
  </div>
</BaseLayout>
