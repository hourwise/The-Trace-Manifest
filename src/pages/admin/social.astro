---
import BaseLayout from "../../layouts/BaseLayout.astro";

export const prerender = false;

interface SignalRow {
  id: number; platform: string; canonical_url: string;
  submitted_by: string; submitted_at: string; submission_reason: string;
  author_display_name: string | null; author_handle: string | null;
  reviewer_notes: string; trace_summary: string | null;
  evidence_status: string; corroboration_status: string; review_status: string;
  reviewed_by: string | null; reviewed_at: string | null;
}

let signals: SignalRow[] = [];
let loadError: string | null = null;
let actionMessage: string | null = null;
let actionError: string | null = null;

// Handle POST: submit new signal, or approve/reject existing
if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = (formData.get("_action") as string) ?? "submit";
  const db = Astro.locals.runtime.env.DB;
  const operator = Astro.locals.operator;

  if (action === "approve" || action === "reject") {
    // Approve or reject an existing signal
    const id = parseInt((formData.get("id") as string) ?? "0");
    const summary = (formData.get("trace_summary") as string)?.trim() || null;
    try {
      if (!id || id < 1) throw new Error("Invalid signal ID.");
      await db.prepare(`
        UPDATE social_signals SET review_status = ?, reviewed_by = 'Admin', reviewed_at = datetime('now'),
        trace_summary = COALESCE(?, trace_summary), updated_at = datetime('now')
        WHERE id = ?
      `).bind(action === "approve" ? "approved" : "rejected", summary, id).run();
      actionMessage = action === "approve" ? "Signal approved." : "Signal rejected.";
    } catch (e: any) {
      actionError = e.message || "Action failed.";
    }
  } else {
    // Submit new signal
    try {
      const platform = (formData.get("platform") as string)?.trim().toLowerCase() ?? "";
      const url = (formData.get("url") as string)?.trim() ?? "";
      const reason = (formData.get("reason") as string)?.trim() ?? "";
      const authorDisplayName = (formData.get("authorDisplayName") as string)?.trim() || null;
      const authorHandle = (formData.get("authorHandle") as string)?.trim() || null;
      const notes = (formData.get("notes") as string)?.trim() || "";

      const VALID_PLATFORMS = ["reddit","x","bluesky","mastodon","linkedin","youtube","github-discussion","forum","other-approved"];
      if (!VALID_PLATFORMS.includes(platform)) throw new Error("Invalid platform.");
      if (!url || url.length > 2048) throw new Error("A valid URL is required.");
      try { const p = new URL(url); if (!["https:","http:"].includes(p.protocol) || p.username || p.password) throw new Error(""); } catch { throw new Error("URL is not valid."); }
      if (!reason || reason.length < 10 || reason.length > 1000) throw new Error("Reason must be 10–1000 characters.");

      const canonical = url;
      const hashBuffer = await crypto.subtle.digest("SHA-256", new TextEncoder().encode(canonical));
      const canonicalUrlHash = Array.from(new Uint8Array(hashBuffer), (b) => b.toString(16).padStart(2, "0")).join("");

      await db.prepare(`
        INSERT INTO social_signals (platform, canonical_url, canonical_url_hash, submitted_by, submission_reason, author_display_name, author_handle, reviewer_notes)
        VALUES (?, ?, ?, 'Admin', ?, ?, ?, ?)
      `).bind(platform, canonical, canonicalUrlHash, reason, authorDisplayName, authorHandle, notes).run();

      actionMessage = "Signal recorded.";
    } catch (e: any) {
      actionError = e.message || "Submission failed.";
    }
  }
}

// Load signals for display
try {
  const db = Astro.locals.runtime.env.DB;
  const result = await db.prepare(`
    SELECT id, platform, canonical_url, submitted_by, submitted_at, submission_reason,
           author_display_name, author_handle, reviewer_notes, trace_summary, evidence_status,
           corroboration_status, review_status, reviewed_by, reviewed_at
    FROM social_signals ORDER BY created_at DESC LIMIT 50
  `).all<SignalRow>();
  signals = result.results ?? [];
} catch {
  loadError = "Social signals are unavailable. Verify the D1 binding and migration.";
}
---

<BaseLayout
  title="Admin — Social Signals"
  description="Governed social-media signal intake per ADR 0009."
>
  <div class="wrap">
    <h1>Admin: Social Signals</h1>
    <p class="meta" style="margin-bottom:2rem;">
      <a href="/admin">← Admin home</a> &middot; <a href="/admin/desk">TRACE Desk</a> &middot; <a href="/admin/review">Review Queue</a>
    </p>

    <p style="padding:0.75rem;background:var(--surface-2);border-radius:var(--radius);font-size:0.9rem;margin-bottom:2rem;">
      Governed social-media signal intake per <a href="/docs/adr/0009-governed-social-media-signal-intake-linked-source-discovery-and-outbound-linking.md">ADR 0009</a>.
      Social posts are discovery signals, not proof. Each linked article, paper, or repository must be assessed independently.
    </p>

    <!-- Submit -->
    <section style="margin-bottom:2.5rem;">
      <h2>Submit a Social Signal</h2>
      {actionMessage && <div class="card" style="margin-bottom:1rem;background:color-mix(in oklch, var(--ev-confirmed) 10%, transparent);border-left:3px solid var(--ev-confirmed);"><p style="margin:0;">{actionMessage}</p></div>}
      {actionError && <div class="card" style="margin-bottom:1rem;background:color-mix(in oklch, var(--ev-disputed) 10%, transparent);border-left:3px solid var(--ev-disputed);"><p style="margin:0;color:var(--ev-disputed);">{actionError}</p></div>}
      <form method="POST" class="card" style="background:var(--surface-2);">
        <div style="display:flex;flex-direction:column;gap:1rem;">
          <div>
            <label for="sig-platform" style="font-size:0.85rem;font-weight:600;display:block;margin-bottom:0.25rem;">Platform</label>
            <select name="platform" id="sig-platform" style="width:100%;">
              <option value="">— Select —</option>
              <option value="reddit">Reddit</option>
              <option value="x">X (Twitter)</option>
              <option value="bluesky">Bluesky</option>
              <option value="mastodon">Mastodon</option>
              <option value="linkedin">LinkedIn</option>
              <option value="youtube">YouTube</option>
              <option value="github-discussion">GitHub Discussion</option>
              <option value="forum">Forum</option>
              <option value="other-approved">Other (approved)</option>
            </select>
          </div>
          <div>
            <label for="sig-url" style="font-size:0.85rem;font-weight:600;display:block;margin-bottom:0.25rem;">Public URL <span style="color:var(--ev-disputed);">*required</span></label>
            <input type="url" name="url" id="sig-url" placeholder="https://…" style="width:100%;" />
          </div>
          <div>
            <label for="sig-reason" style="font-size:0.85rem;font-weight:600;display:block;margin-bottom:0.25rem;">Why this matters <span style="color:var(--ev-disputed);">*required</span> <span class="meta" style="font-weight:400;">(10–1000 chars)</span></label>
            <textarea name="reason" id="sig-reason" rows="2" placeholder="What makes this signal worth reviewing?…" style="width:100%;resize:vertical;"></textarea>
          </div>
          <div style="display:flex;gap:1rem;flex-wrap:wrap;">
            <div style="flex:1;min-width:180px;">
              <label for="sig-author-name" style="font-size:0.85rem;font-weight:600;display:block;margin-bottom:0.25rem;">Author display name <span class="meta" style="font-weight:400;">(optional)</span></label>
              <input type="text" name="authorDisplayName" id="sig-author-name" placeholder="e.g. Sarah Chen" style="width:100%;" />
            </div>
            <div style="flex:1;min-width:180px;">
              <label for="sig-author-handle" style="font-size:0.85rem;font-weight:600;display:block;margin-bottom:0.25rem;">Author handle <span class="meta" style="font-weight:400;">(optional)</span></label>
              <input type="text" name="authorHandle" id="sig-author-handle" placeholder="e.g. @sarahchen" style="width:100%;" />
            </div>
          </div>
          <div>
            <label for="sig-notes" style="font-size:0.85rem;font-weight:600;display:block;margin-bottom:0.25rem;">Reviewer notes <span class="meta" style="font-weight:400;">(optional)</span></label>
            <textarea name="notes" id="sig-notes" rows="2" placeholder="Notes about the signal…" style="width:100%;resize:vertical;"></textarea>
          </div>
        </div>
        <div style="margin-top:1rem;">
          <button type="submit" class="btn btn-primary">Submit Signal</button>
        </div>
      </form>
    </section>

    <!-- Pending signals -->
    <section>
      <h2>Pending Signals</h2>
      {loadError ? <div class="card"><p class="meta" style="color:var(--ev-disputed);">{loadError}</p></div> :
       signals.length === 0 ? <div class="card" style="text-align:center;padding:2rem;"><p class="meta">No signals submitted yet.</p></div> :
       <div style="display:flex;flex-direction:column;gap:0.65rem;">
        {signals.map((s) => (
          <div class="card" style="padding:0.75rem 1rem;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;flex-wrap:wrap;">
              <div style="flex:1;min-width:0;">
                <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;margin-bottom:0.35rem;">
                  <span class="badge badge-sm" style="font-size:0.65rem;">{s.platform}</span>
                  <span class="badge badge-sm" style="font-size:0.65rem;background:var(--surface-1);">{s.review_status}</span>
                  <span class="badge badge-sm" style="font-size:0.65rem;background:var(--surface-1);">{s.evidence_status}</span>
                </div>
                <a href={s.canonical_url} target="_blank" rel="noopener" style="font-weight:550;font-size:0.9rem;word-break:break-all;">{s.canonical_url.slice(0, 100)}{s.canonical_url.length > 100 ? "…" : ""}</a>
                {s.author_display_name ? <span class="meta" style="font-size:0.75rem;"> — {s.author_display_name}{s.author_handle ? ` (${s.author_handle})` : ""}</span> : null}
                <p class="meta" style="font-size:0.8rem;margin-top:0.35rem;">{s.submission_reason.slice(0, 200)}{s.submission_reason.length > 200 ? "…" : ""}</p>
                {s.reviewer_notes ? <p class="meta" style="font-size:0.75rem;color:var(--muted);margin-top:0.2rem;">Notes: {s.reviewer_notes.slice(0, 150)}{s.reviewer_notes.length > 150 ? "…" : ""}</p> : null}
                {s.trace_summary ? <p class="meta" style="font-size:0.75rem;margin-top:0.2rem;color:var(--ev-confirmed);">Summary: {s.trace_summary.slice(0, 200)}</p> : null}
                {s.reviewed_by ? <p class="meta" style="font-size:0.7rem;margin-top:0.3rem;">Reviewed by {s.reviewed_by} · {s.reviewed_at ? new Date(s.reviewed_at).toLocaleString("en-GB") : "—"}</p> : null}
                <p class="meta" style="font-size:0.7rem;margin-top:0.3rem;">Submitted by {s.submitted_by} · {s.submitted_at ? new Date(s.submitted_at).toLocaleString("en-GB") : "—"}</p>
              </div>
              {s.review_status === "pending" ? (
                <div style="display:flex;flex-direction:column;gap:0.35rem;min-width:120px;">
                  <form method="POST" style="display:flex;flex-direction:column;gap:0.35rem;">
                    <input type="hidden" name="_action" value="approve" />
                    <input type="hidden" name="id" value={String(s.id)} />
                    <input type="text" name="trace_summary" placeholder="TRACE summary (optional)" style="font-size:0.7rem;width:100%;" />
                    <button type="submit" class="btn btn-primary" style="font-size:0.7rem;padding:0.25rem 0.5rem;">Approve</button>
                  </form>
                  <form method="POST">
                    <input type="hidden" name="_action" value="reject" />
                    <input type="hidden" name="id" value={String(s.id)} />
                    <button type="submit" class="btn btn-secondary" style="font-size:0.7rem;padding:0.25rem 0.5rem;width:100%;">Reject</button>
                  </form>
                </div>
              ) : (
                <span class="badge" style="font-size:0.7rem;background:var(--surface-1);">{s.review_status}</span>
              )}
            </div>
          </div>
        ))}
       </div>
      }
    </section>
  </div>
</BaseLayout>
