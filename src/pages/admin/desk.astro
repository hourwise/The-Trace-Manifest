---
import BaseLayout from "../../layouts/BaseLayout.astro";

export const prerender = false;
const editorialAIEnabled = Astro.locals.runtime.env.TRACE_AI_EDITORIAL_ENABLED === "true";

interface CandidateRow {
  id: string; intake_type: string; submitted_url: string | null;
  lead_text: string | null; state: string; section_slug: string | null;
  topic_slug: string | null; urgency: string; development_status: string | null;
  source_language: string | null; created_by: string; created_at: string;
  updated_at: string;
}

let candidates: CandidateRow[] = [];
let loadError: string | null = null;
let actionMessage: string | null = null;
let actionError: string | null = null;

const VALID_STATES = ["new","drafting","draft_ready","needs_review","published","rejected","archived"] as const;
const TRANSITIONS: Record<string, string[]> = {
  new: ["drafting","rejected"],
  drafting: ["draft_ready","rejected"],
  draft_ready: ["needs_review","drafting","rejected"],
  needs_review: ["draft_ready","rejected"],  // "published" only via Promote button
  published: ["draft_ready","archived"],
  rejected: ["new"],
  archived: [],
};

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = (formData.get("_action") as string) ?? "submit";
  const db = Astro.locals.runtime.env.DB;

  if (action === "transition") {
    const candidateId = (formData.get("candidate_id") as string)?.trim() ?? "";
    const newState = (formData.get("state") as string) ?? "";
    try {
      if (!candidateId || !/^[a-f0-9-]{36}$/i.test(candidateId)) throw new Error(`Invalid candidate ID: ${candidateId || "empty"}`);
      if (!VALID_STATES.includes(newState as any)) throw new Error(`Invalid state: "${newState}"`);
      const current = await db.prepare("SELECT state FROM editorial_candidates WHERE id=?").bind(candidateId).first<{state:string}>();
      if (!current) throw new Error("Candidate not found.");
      if (!TRANSITIONS[current.state]?.includes(newState)) throw new Error(`Cannot move from ${current.state} to ${newState}.`);
      await db.prepare("UPDATE editorial_candidates SET state=?, updated_at=datetime('now') WHERE id=?").bind(newState, candidateId).run();
      actionMessage = `Candidate → ${newState}.`;
    } catch (e: any) { actionError = e.message || "Transition failed."; }
  } else if (action === "promote") {
    const candidateId = (formData.get("candidate_id") as string)?.trim() ?? "";
    try {
      if (!candidateId) throw new Error("Invalid candidate ID.");
      const candidate = await db.prepare("SELECT * FROM editorial_candidates WHERE id=? AND state IN ('needs_review','published')").bind(candidateId).first<CandidateRow>();
      if (!candidate) throw new Error("Candidate must be in 'needs_review' or 'published' state to promote.");

      // Generate headline and summary
      const headline = candidate.lead_text?.slice(0, 150) ?? candidate.submitted_url ?? "Untitled";
      const summary = (candidate.lead_text ?? "").slice(0, 500);

      // Determine evidence status — manual submissions default to vendor_reported or unverified
      const evidenceStatus = candidate.intake_type === "lead" ? "unverified"
        : candidate.intake_type === "social_url" ? "community_reported"
        : "vendor_reported";

      const result = await db.prepare(`
        INSERT INTO story_clusters (title, canonical_url, topic, evidence_status, publication_status, needs_human_review, summary, why_it_matters, created_at, updated_at)
        VALUES (?, ?, ?, ?, 'review', 1, ?, ?, datetime('now'), datetime('now'))
      `).bind(headline, candidate.submitted_url, candidate.topic_slug ?? candidate.section_slug ?? "general", evidenceStatus, summary, summary.slice(0, 300)).run();
      const clusterId = result.meta?.last_row_id;

      if (clusterId) {
        // Create a linked feed_item entry for the candidate's URL
        if (candidate.submitted_url) {
          const urlHash = Array.from(new Uint8Array(await crypto.subtle.digest("SHA-256", new TextEncoder().encode(candidate.submitted_url))), (b) => b.toString(16).padStart(2,"0")).join("");
          const feedResult = await db.prepare(`
            INSERT OR IGNORE INTO feed_items (url, url_hash, title, summary, content_excerpt, source_id, ingestion_status, fetched_at, published_at)
            VALUES (?, ?, ?, ?, ?, ?, 'raw', datetime('now'), datetime('now'))
          `).bind(candidate.submitted_url, urlHash, headline, summary, summary.slice(0, 1000), 1).run();
          const feedItemId = feedResult.meta?.last_row_id;
          if (feedItemId) {
            await db.prepare(`
              INSERT OR IGNORE INTO story_cluster_members (cluster_id, feed_item_id, is_primary)
              VALUES (?, ?, 1)
            `).bind(clusterId, feedItemId).run();
          }
        }

        // Record promotion audit
        await db.prepare(`
          INSERT INTO admin_audit_log (event_id, operator_email, operator_role, action, target_type, target_id, request_id, outcome)
          VALUES (?, 'Admin', 'publisher', 'promote_candidate_to_cluster', 'candidate', ?, ?, 'succeeded')
        `).bind(crypto.randomUUID(), candidateId, crypto.randomUUID()).run();
      }

      await db.prepare("UPDATE editorial_candidates SET state='published', updated_at=datetime('now') WHERE id=?").bind(candidateId).run();
      actionMessage = `Candidate promoted to story cluster #${clusterId} (evidence: ${evidenceStatus}). It needs editorial review before homepage placement.`;
    } catch (e: any) { actionError = e.message || "Promotion failed."; }
  } else {
    try {
      const intakeType = (formData.get("intakeType") as string) ?? "manual_url";
      const rawUrl = (formData.get("url") as string)?.trim() || null;
      const lead = (formData.get("lead") as string)?.trim() || "";
      const section = (formData.get("section") as string)?.trim() || null;
      const urgency = (formData.get("urgency") as string) ?? "normal";
      const sourceLanguage = (formData.get("sourceLanguage") as string)?.trim() || null;

      // Normalize and validate URL
      let url: string | null = null;
      if (rawUrl) {
        try {
          const parsed = new URL(rawUrl);
          if (!["https:", "http:"].includes(parsed.protocol) || parsed.username || parsed.password) {
            throw new Error("URL must be a public HTTP/HTTPS address with no credentials.");
          }
          // Normalize: remove tracking params, trailing slash consistency
          const trackingParams = ["utm_source", "utm_medium", "utm_campaign", "utm_term", "utm_content", "ref", "source", "fbclid", "gclid"];
          for (const param of trackingParams) {
            parsed.searchParams.delete(param);
          }
          let normalized = parsed.toString();
          if (normalized.endsWith("/") && !parsed.pathname.endsWith("/")) {
            normalized = normalized.slice(0, -1);
          }
          url = normalized;
        } catch (e: any) {
          throw new Error(e.message || "URL is not valid.");
        }
      }

      // Minimum lead text for article/social URLs
      if (intakeType !== "lead" && !lead) {
        // Don't require lead text for URL submissions — auto-generate a placeholder
      }
      if (intakeType === "lead" && (!lead || lead.length < 10)) {
        throw new Error("Lead text must be at least 10 characters.");
      }

      // Check for duplicate URL
      if (url) {
        const urlHash = Array.from(
          new Uint8Array(await crypto.subtle.digest("SHA-256", new TextEncoder().encode(url))),
          (b) => b.toString(16).padStart(2, "0")
        ).join("");

        // Check feed_items for already-ingested URL
        const existingItem = await db.prepare(
          "SELECT id FROM feed_items WHERE url_hash = ? LIMIT 1"
        ).bind(urlHash).first<{ id: number }>();
        if (existingItem) {
          // URL is already in the system — check cluster membership
          const clusterMember = await db.prepare(
            "SELECT cluster_id FROM story_cluster_members WHERE feed_item_id = ? LIMIT 1"
          ).bind(existingItem.id).first<{ cluster_id: number }>();
          if (clusterMember) {
            throw new Error(`This URL is already part of story cluster #${clusterMember.cluster_id}. View it in the review queue.`);
          }
          actionMessage = `URL is already ingested (feed item #${existingItem.id}). A candidate can still be created.`;
        }

        // Check editorial_candidates for existing submission
        const existingCandidate = await db.prepare(
          "SELECT id, state FROM editorial_candidates WHERE source_hash = ? AND state NOT IN ('published','archived','rejected') LIMIT 1"
        ).bind(urlHash).first<{ id: string; state: string }>();
        if (existingCandidate) {
          throw new Error(`This URL is already an open candidate (${existingCandidate.state}). <a href="/admin/desk">View it in the queue</a>.`);
        }

        // Search for similar open candidates
        const titleWords = lead ? new Set(
          lead.toLowerCase().replace(/[^\w\s]/g, "").split(/\s+/).filter((w: string) => w.length > 3)
        ) : new Set<string>();
        let matchedCandidate: string | null = null;
        if (titleWords.size >= 3) {
          const recentCandidates = await db.prepare(
            "SELECT id, lead_text FROM editorial_candidates WHERE state NOT IN ('published','archived','rejected') AND created_at >= datetime('now', '-3 days') LIMIT 20"
          ).all<{ id: string; lead_text: string | null }>();
          for (const row of (recentCandidates.results ?? [])) {
            const candWords = new Set(
              (row.lead_text ?? "").toLowerCase().replace(/[^\w\s]/g, "").split(/\s+/).filter((w: string) => w.length > 3)
            );
            const intersection = [...titleWords].filter((w: string) => candWords.has(w));
            if (intersection.length >= 3) {
              matchedCandidate = row.id;
              break;
            }
          }
        }

        const sourceHash = urlHash;
        const candidateId = crypto.randomUUID();
        await db.prepare(`
          INSERT INTO editorial_candidates (id, intake_type, submitted_url, lead_text, source_hash, state, section_slug, urgency, source_language, created_by)
          VALUES (?, ?, ?, ?, ?, 'new', ?, ?, ?, 'Admin')
        `).bind(candidateId, intakeType, url, lead || url, sourceHash, section, urgency, sourceLanguage).run();

        if (matchedCandidate) {
          actionMessage = `Candidate recorded and linked to existing candidate #${matchedCandidate.slice(0, 8)}.`;
        } else {
          actionMessage = `Candidate recorded. URL normalized from "${rawUrl}" to final form.`;
        }
      } else {
        // No URL — lead-only submission
        const sourceHash = Array.from(
          new Uint8Array(await crypto.subtle.digest("SHA-256", new TextEncoder().encode(lead))),
          (b) => b.toString(16).padStart(2, "0")
        ).join("");
        const candidateId = crypto.randomUUID();
        await db.prepare(`
          INSERT INTO editorial_candidates (id, intake_type, submitted_url, lead_text, source_hash, state, section_slug, urgency, source_language, created_by)
          VALUES (?, ?, ?, ?, ?, 'new', ?, ?, ?, 'Admin')
        `).bind(candidateId, intakeType, null, lead, sourceHash, section, urgency, sourceLanguage).run();
        actionMessage = "Editorial lead recorded.";
      }
    } catch (e: any) { actionError = e.message || "Submission failed."; }
  }
}

try {
  const db = Astro.locals.runtime.env.DB;
  const result = await db.prepare(`
    SELECT id, intake_type, submitted_url, lead_text, state, section_slug, topic_slug, urgency, development_status, source_language, created_by, created_at, updated_at
    FROM editorial_candidates ORDER BY created_at DESC LIMIT 50
  `).all<CandidateRow>();
  candidates = result.results ?? [];
} catch { loadError = "TRACE Desk is unavailable."; }

const STATE_LABELS: Record<string, string> = { new:"New", drafting:"Drafting", draft_ready:"Draft ready", needs_review:"Needs review", published:"Published", rejected:"Rejected", archived:"Archived" };
---

<BaseLayout title="TRACE Desk" description="Governed editorial intake for The Trace Manifest.">
  <div class="wrap" style="max-width:900px;">
    <h1>TRACE Desk</h1>
    <p class="meta" style="margin:0.75rem 0 2rem;">
      <a href="/admin">Admin home</a> · <a href="/admin/review">Review queue</a> · <a href="/admin/social">Social signals</a>
    </p>
    {actionMessage && <div class="card" style="margin-bottom:1rem;background:color-mix(in oklch, var(--ev-confirmed) 10%, transparent);border-left:3px solid var(--ev-confirmed);"><p style="margin:0;">{actionMessage}</p></div>}
    {actionError && <div class="card" style="margin-bottom:1rem;background:color-mix(in oklch, var(--ev-disputed) 10%, transparent);border-left:3px solid var(--ev-disputed);"><p style="margin:0;color:var(--ev-disputed);">{actionError}</p></div>}

    <section class="card">
      <h2 style="font-size:1.25rem;">New editorial candidate</h2>
      <form method="POST" class="desk-form" style="display:grid;gap:1rem;margin-top:1rem;">
        <label>Intake type
          <select name="intakeType">
            <option value="manual_url">Article or document URL</option>
            <option value="social_url">Social post URL</option>
            <option value="lead">Editorial lead or tip</option>
            <option value="additional_evidence">Additional evidence URL</option>
          </select>
        </label>
        <label>URL
          <input name="url" type="url" maxlength="2048" placeholder="https://…" />
        </label>
        <label>Lead or editorial note
          <textarea name="lead" id="desk-lead" rows="5" maxlength="8000" placeholder="Why this matters, source context, or a summary."></textarea>
        </label>
        <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;">
          <button type="button" id="desk-ai-btn" class="btn btn-secondary" style="font-size:0.8rem;">🤖 AI Analyse URL</button>
          <span id="desk-ai-status" class="meta" style="font-size:0.75rem;"></span>
        </div>
        <div class="grid grid--3" style="gap:1rem;">
          <label>Section <select name="section"><option value="">Unclassified</option><option value="ai-agents">AI &amp; Agents</option></select></label>
          <label>Urgency <select name="urgency"><option value="normal">Normal</option><option value="high">High</option><option value="breaking">Breaking</option><option value="low">Low</option></select></label>
          <label>Source language <input name="sourceLanguage" maxlength="35" placeholder="e.g. en, zh-CN" /></label>
        </div>
        <div><button type="submit" class="btn btn-primary">Record candidate</button></div>
      </form>
    </section>

    <section class="card" style="margin-top:2rem;">
      <h2 style="font-size:1.25rem;">Candidate Queue</h2>
      {loadError ? <p class="meta" style="color:var(--ev-disputed);">{loadError}</p> :
       candidates.length === 0 ? <p class="meta">No candidates yet.</p> :
       <div style="display:grid;gap:0.75rem;">
        {candidates.map((c) => {
          const nextStates = TRANSITIONS[c.state] ?? [];
          const isPromotable = c.state === "needs_review" || c.state === "published";
          return (
            <div class="card" style="padding:0.75rem 1rem;">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;flex-wrap:wrap;">
                <div style="flex:1;min-width:0;">
                  <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;margin-bottom:0.35rem;">
                    <span class="badge badge-sm">{c.intake_type?.replace(/_/g, " ")}</span>
                    <span class="badge badge-sm" style="background:var(--surface-1);">{STATE_LABELS[c.state] ?? c.state}</span>
                    {c.urgency !== "normal" && <span class="badge badge-sm" style="background:var(--surface-1);">{c.urgency}</span>}
                  </div>
                  {c.submitted_url ? <a href={c.submitted_url} target="_blank" rel="noreferrer" style="font-size:0.85rem;word-break:break-all;">{c.submitted_url}</a> : null}
                  <p style="margin:0.35rem 0;font-size:0.85rem;">{c.lead_text?.slice(0, 300)}{(c.lead_text?.length ?? 0) > 300 ? "…" : ""}</p>
                  <p class="meta" style="font-size:0.7rem;">{c.section_slug || "Unclassified"} · {c.created_at ? new Date(c.created_at + "Z").toLocaleString("en-GB") : "—"}</p>
                </div>
                <div style="display:flex;flex-direction:column;gap:0.3rem;min-width:100px;">
                  {nextStates.map((ns) => (
                    <form method="POST" style="margin:0;">
                      <input type="hidden" name="_action" value="transition" />
                      <input type="hidden" name="candidate_id" value={String(c.id)} />
                      <input type="hidden" name="state" value={ns} />
                      <button type="submit" class="btn btn-secondary" style="font-size:0.65rem;padding:0.15rem 0.4rem;width:100%;">
                        {ns === "published" ? "✓ Publish" : ns === "rejected" ? "✗ Reject" : `→ ${STATE_LABELS[ns] ?? ns}`}
                      </button>
                    </form>
                  ))}
                  {isPromotable && (
                    <form method="POST" style="margin:0;">
                      <input type="hidden" name="_action" value="promote" />
                      <input type="hidden" name="candidate_id" value={String(c.id)} />
                      <button type="submit" class="btn btn-primary" style="font-size:0.65rem;padding:0.15rem 0.4rem;width:100%;">↑ Promote to Story</button>
                    </form>
                  )}
                </div>
              </div>
            </div>
          );
        })}
       </div>
      }
    </section>
  </div>
</BaseLayout>

<script define:vars={{ aiEnabled: editorialAIEnabled }}>
  document.getElementById("desk-ai-btn").addEventListener("click", async function() {
    if (!aiEnabled) { alert("Editorial AI is disabled for this deployment."); return; }
    var urlField = document.querySelector("input[name='url']");
    var leadField = document.getElementById("desk-lead");
    var statusEl = document.getElementById("desk-ai-status");
    var btn = this;
    var url = (urlField && urlField.value) ? urlField.value.trim() : "";

    if (!url) { if (statusEl) statusEl.textContent = "Enter a URL first."; return; }
    btn.disabled = true;
    btn.textContent = "🤖 Analysing…";
    if (statusEl) statusEl.textContent = "Asking AI to analyse this URL…";

    try {
      var res = await fetch("/api/admin/ai-triage", {
        method: "POST", credentials: "include",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ sources: [{ title: "Submitted URL", excerpt: null, url: url }] }),
      });
      if (!res.ok) throw new Error("HTTP " + res.status);
      var data = await res.json();
      var summary = data.summary || "";
      var analysis = data.editorialAnalysis || "";
      var why = data.whyItMatters || "";
      var result = summary;
      if (analysis) result += "\n\n" + analysis;
      if (why) result += "\n\nWhy it matters: " + why;
      if (leadField) leadField.value = result.slice(0, 8000);
      if (statusEl) statusEl.textContent = "✅ Done — review and edit before recording.";
    } catch (e) {
      if (statusEl) statusEl.textContent = "❌ AI analysis failed. You can still enter notes manually.";
      console.error("Desk AI triage failed", e);
    } finally {
      btn.disabled = false;
      btn.textContent = "🤖 AI Analyse URL";
    }
  });
</script>

<style>
  .desk-form label { display: grid; gap: 0.35rem; font-size: 0.875rem; font-weight: 600; }
  .desk-form input, .desk-form select, .desk-form textarea { width: 100%; padding: 0.6rem 0.7rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--bg); }
  .desk-form textarea { min-height: 8rem; resize: vertical; }
</style>
