---
import BaseLayout from "../../layouts/BaseLayout.astro";

export const prerender = false;

interface SourceRow {
  id: number; name: string; url: string; tier: string; treatment: string; ingestion_type: string;
  cadence_minutes: number; health_status: string; active: number; last_fetched_at: string | null;
  last_success_at: string | null; last_error_at: string | null; last_error_message: string | null;
  consecutive_failures: number;
}

let sources: SourceRow[] = [];
let loadError: string | null = null;
try {
  sources = (await Astro.locals.runtime.env.DB.prepare(`
    SELECT id, name, url, tier, treatment, ingestion_type, cadence_minutes, health_status,
           active, last_fetched_at, last_success_at, last_error_at, last_error_message, consecutive_failures
    FROM sources ORDER BY tier, name
  `).all<SourceRow>()).results;
} catch {
  loadError = "Source health is unavailable. Verify the D1 binding and schema migrations.";
}

const implemented = new Set(["rss", "github_api", "arxiv_api", "hackernews_api"]);
const active = sources.filter((source) => Boolean(source.active));
const count = (status: string) => active.filter((source) => source.health_status === status).length;
const fmt = (value: string | null) => value ? new Date(value).toLocaleString("en-GB") : "Never";
const safeHttpUrl = (value: string): string | null => {
  try {
    const url = new URL(value);
    return (url.protocol === "https:" || url.protocol === "http:") && !url.username && !url.password ? url.href : null;
  } catch { return null; }
};
---

<BaseLayout title="Admin — Sources" description="Live source registry and connector health.">
  <div class="wrap">
    <h1>Admin: Sources</h1>
    <p class="meta" style="margin-bottom:2rem;"><a href="/admin/jobs">Jobs</a> · <a href="/admin/review">Review</a> · <a href="/admin">Admin home</a></p>

    {loadError ? <div class="card"><p class="meta">{loadError}</p></div> : <>
      <section class="grid-3" style="margin-bottom:2rem;">
        <div class="card" style="text-align:center;"><p style="font-size:2rem;font-weight:700;">{active.length}</p><p class="meta">Active sources</p></div>
        <div class="card" style="text-align:center;"><p style="font-size:2rem;font-weight:700;color:var(--ev-disputed);">{count("degraded") + count("failing")}</p><p class="meta">Degraded or failing</p></div>
        <div class="card" style="text-align:center;"><p style="font-size:2rem;font-weight:700;color:var(--ev-provisional);">{active.filter((source) => !implemented.has(source.ingestion_type)).length}</p><p class="meta">Unsupported connectors</p></div>
      </section>

      <section>
        <h2>Registry and health</h2>
        <p class="meta">Times, connector support, and failures are read directly from D1. No synthetic health values are displayed.</p>
        <div style="overflow-x:auto;margin-top:1rem;">
          <table style="width:100%;border-collapse:collapse;font-size:0.82rem;">
            <thead><tr style="text-align:left;border-bottom:2px solid var(--border);"><th>Source</th><th>Tier</th><th>Connector</th><th>Status</th><th>Last success</th><th>Last observation</th><th>Failure detail</th></tr></thead>
            <tbody>
              {sources.map((source) => {
                const supported = implemented.has(source.ingestion_type);
                const status = !source.active ? "disabled" : !supported ? "unsupported" : source.health_status;
                const sourceUrl = safeHttpUrl(source.url);
                return <tr style="vertical-align:top;border-bottom:1px solid var(--border);">
                  <td>{sourceUrl ? <a href={sourceUrl} rel="noopener noreferrer">{source.name}</a> : source.name}<br /><span class="meta">{source.treatment}</span></td>
                  <td>{source.tier}</td><td><code>{source.ingestion_type}</code><br /><span class="meta">{source.cadence_minutes} min</span></td>
                  <td><span class={`badge badge-${status === "healthy" ? "confirmed" : status === "failing" ? "disputed" : "provisional"}`}>{status}</span></td>
                  <td class="meta">{fmt(source.last_success_at)}</td><td class="meta">{fmt(source.last_fetched_at)}</td>
                  <td class="meta">{!supported ? "No connector implementation; ingestion is skipped and reported." : source.last_error_message ?? "—"}</td>
                </tr>;
              })}
              {sources.length === 0 && <tr><td colspan="7" class="meta" style="padding:2rem;text-align:center;">No sources are configured.</td></tr>}
            </tbody>
          </table>
        </div>
      </section>
    </>}
  </div>
</BaseLayout>
