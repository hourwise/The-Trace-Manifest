---
import BaseLayout from "../../layouts/BaseLayout.astro";

// Phase 2: Admin — Source management page
// Connects to the ingestion worker API for source status and controls
---

<BaseLayout
  title="Admin — Sources"
  description="Manage ingestion sources, view health status, trigger manual fetches."
>
  <div class="container">
    <h1>Admin: Sources</h1>
    <p class="meta" style="margin-bottom:2rem;">
      Source registry management, health monitoring, and manual ingestion controls.
      <a href="/admin">← Admin home</a>
    </p>

    <p style="padding:0.75rem;background:var(--color-bg-alt);border-radius:var(--radius);font-size:0.9rem;margin-bottom:2rem;">
      <strong>Phase 2:</strong> Source data is loaded from the Cloudflare D1 database via the ingestion Worker API.
      In local dev, sources display from the seed data in <code>db/seed.sql</code>.
    </p>

    <!-- Health summary -->
    <section style="margin-bottom:2rem;">
      <h2>Source Health</h2>
      <div class="grid grid--3" style="margin-top:1rem;">
        <div class="card" style="text-align:center;">
          <p style="font-size:2rem;font-weight:700;color:#166534;">40</p>
          <p class="meta">Healthy</p>
        </div>
        <div class="card" style="text-align:center;">
          <p style="font-size:2rem;font-weight:700;color:#92400e;">0</p>
          <p class="meta">Degraded</p>
        </div>
        <div class="card" style="text-align:center;">
          <p style="font-size:2rem;font-weight:700;color:#991b1b;">0</p>
          <p class="meta">Failing</p>
        </div>
      </div>
    </section>

    <!-- Source tiers -->
    <section style="margin-bottom:2rem;">
      <h2>Tier A — Auto-Ingest Sources</h2>
      <p class="meta" style="margin-bottom:1rem;">30 sources polled every 30 min–3 hours. Eligible for automatic publication.</p>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:0.9rem;">
          <thead>
            <tr style="border-bottom:2px solid var(--color-border);text-align:left;">
              <th style="padding:0.5rem;">Source</th>
              <th style="padding:0.5rem;">Type</th>
              <th style="padding:0.5rem;">Cadence</th>
              <th style="padding:0.5rem;">Status</th>
            </tr>
          </thead>
          <tbody>
            {[
              ["OpenAI News", "rss", "1h", "healthy"],
              ["Anthropic Newsroom", "rss", "1h", "healthy"],
              ["Google DeepMind", "rss", "2h", "healthy"],
              ["Meta AI Blog", "rss", "2h", "healthy"],
              ["Mistral News", "rss", "1–2h", "healthy"],
              ["Hugging Face Blog", "rss", "2h", "healthy"],
              ["GitHub — llama.cpp", "github_api", "3h", "healthy"],
              ["GitHub — Ollama", "github_api", "3h", "healthy"],
              ["GitHub — MCP Spec", "github_api", "3h", "healthy"],
            ].map(([name, type, cadence, status]) => (
              <tr style="border-bottom:1px solid var(--color-border);">
                <td style="padding:0.5rem;">{name}</td>
                <td style="padding:0.5rem;"><code style="font-size:0.8rem;">{type}</code></td>
                <td style="padding:0.5rem;" class="meta">{cadence}</td>
                <td style="padding:0.5rem;"><span class="evidence-label evidence-label--confirmed">{status}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section style="margin-bottom:2rem;">
      <h2>Tier B — Research &amp; Benchmarks</h2>
      <p class="meta" style="margin-bottom:1rem;">25 sources polled daily. Requires classification before publication.</p>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:0.9rem;">
          <thead>
            <tr style="border-bottom:2px solid var(--color-border);text-align:left;">
              <th style="padding:0.5rem;">Source</th>
              <th style="padding:0.5rem;">Type</th>
              <th style="padding:0.5rem;">Cadence</th>
              <th style="padding:0.5rem;">Status</th>
            </tr>
          </thead>
          <tbody>
            {[
              ["arXiv cs.AI", "arxiv_api", "6h", "healthy"],
              ["arXiv cs.CL", "arxiv_api", "6h", "healthy"],
              ["arXiv cs.LG", "arxiv_api", "6h", "healthy"],
              ["MLCommons", "manual", "daily", "healthy"],
              ["Epoch AI Benchmarks", "manual", "daily", "healthy"],
              ["LMSYS Chatbot Arena", "manual", "daily", "healthy"],
              ["SWE-bench", "manual", "daily", "healthy"],
            ].map(([name, type, cadence, status]) => (
              <tr style="border-bottom:1px solid var(--color-border);">
                <td style="padding:0.5rem;">{name}</td>
                <td style="padding:0.5rem;"><code style="font-size:0.8rem;">{type}</code></td>
                <td style="padding:0.5rem;" class="meta">{cadence}</td>
                <td style="padding:0.5rem;"><span class="evidence-label evidence-label--confirmed">{status}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section style="margin-bottom:2rem;">
      <h2>Tier C — Discovery Signals</h2>
      <p class="meta" style="margin-bottom:1rem;">10+ sources. Manual review only. Never auto-published as evidence.</p>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:0.9rem;">
          <thead>
            <tr style="border-bottom:2px solid var(--color-border);text-align:left;">
              <th style="padding:0.5rem;">Source</th>
              <th style="padding:0.5rem;">Type</th>
              <th style="padding:0.5rem;">Cadence</th>
              <th style="padding:0.5rem;">Status</th>
            </tr>
          </thead>
          <tbody>
            {[
              ["Hacker News", "hackernews_api", "2h", "healthy"],
              ["Specialist publications", "rss/manual", "daily", "healthy"],
              ["Reddit (manual)", "manual", "daily", "active"],
            ].map(([name, type, cadence, status]) => (
              <tr style="border-bottom:1px solid var(--color-border);">
                <td style="padding:0.5rem;">{name}</td>
                <td style="padding:0.5rem;"><code style="font-size:0.8rem;">{type}</code></td>
                <td style="padding:0.5rem;" class="meta">{cadence}</td>
                <td style="padding:0.5rem;"><span class="evidence-label evidence-label--confirmed">{status}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Actions -->
    <section style="margin-top:2rem;padding:1rem;background:var(--color-bg-alt);border-radius:var(--radius);">
      <h2>Manual Actions</h2>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:0.75rem;">
        <button style="padding:0.5rem 1rem;background:var(--color-accent);color:#fff;border:none;border-radius:var(--radius);cursor:pointer;font-weight:600;" disabled>
          Trigger Full Ingestion
        </button>
        <button style="padding:0.5rem 1rem;border:1px solid var(--color-border);border-radius:var(--radius);cursor:pointer;" disabled>
          Check All Source Health
        </button>
        <button style="padding:0.5rem 1rem;border:1px solid var(--color-border);border-radius:var(--radius);cursor:pointer;" disabled>
          Run Classification Pipeline
        </button>
      </div>
      <p class="meta" style="margin-top:0.75rem;">
        Controls will be active when connected to the live Worker API. Full functionality in Phase 2 deployment.
      </p>
    </section>

    <p class="meta" style="margin-top:2rem;">
      <a href="/admin/jobs">View ingestion jobs &rarr;</a> &middot;
      <a href="/admin/review">Review queue &rarr;</a>
    </p>
  </div>
</BaseLayout>
