---
import BaseLayout from "../../layouts/BaseLayout.astro";

// The admin home is Access-authenticated by middleware and must execute at
// request time. Without this marker Astro omits the route from the Pages
// server bundle, producing a 404 before the security boundary can run.
export const prerender = false;
---

<BaseLayout title="Admin" description="The Trace Manifest administration dashboard.">
  <div class="wrap">
    <h1>Admin</h1>
    <p class="meta" style="margin-bottom:2rem;">
      Authenticated operations for source health, ingestion outcomes, and editorial review. Values in each view are read
      from the bound database; unavailable data is reported as unavailable.
    </p>

    <div class="grid-3">
      <a href="/admin/desk" class="card card-hover" style="text-decoration:none;color:inherit;">
        <h2 style="font-size:1.15rem;">TRACE Desk</h2>
        <p class="meta">Record governed editorial candidates from article URLs, social links, leads, and additional evidence.</p>
        <p style="color:var(--color-accent);">Open Desk &rarr;</p>
      </a>
      <a href="/admin/sources" class="card card-hover" style="text-decoration:none;color:inherit;">
        <h2 style="font-size:1.15rem;">Sources</h2>
        <p class="meta">Inspect configured sources, real health state, connector support, and last successful ingestion.</p>
        <p style="color:var(--color-accent);">View sources &rarr;</p>
      </a>
      <a href="/admin/jobs" class="card card-hover" style="text-decoration:none;color:inherit;">
        <h2 style="font-size:1.15rem;">Ingestion jobs</h2>
        <p class="meta">Inspect scheduled and manual outcomes, counts, and sanitised failure details.</p>
        <p style="color:var(--color-accent);">View jobs &rarr;</p>
      </a>
      <a href="/admin/review" class="card card-hover" style="text-decoration:none;color:inherit;">
        <h2 style="font-size:1.15rem;">Review queue</h2>
        <p class="meta">Review eligible clusters and apply publisher-only publication or archive decisions.</p>
        <p style="color:var(--color-accent);">Open queue &rarr;</p>
      </a>
      <a href="/admin/social" class="card card-hover" style="text-decoration:none;color:inherit;">
        <h2 style="font-size:1.15rem;">Social Signals</h2>
        <p class="meta">Submit governed social-media signals for review. Posts are discovery leads, not proof.</p>
        <p style="color:var(--color-accent);">Open signals &rarr;</p>
      </a>
      <a href="/admin/ask" class="card card-hover" style="text-decoration:none;color:inherit;">
        <h2 style="font-size:1.15rem;">Ask TRACE Research</h2>
        <p class="meta">Governed research mode — ask questions grounded in published evidence with citations.</p>
        <p style="color:var(--color-accent);">Open research &rarr;</p>
      </a>
      <a href="/admin/extract-claims" class="card card-hover" style="text-decoration:none;color:inherit;">
        <h2 style="font-size:1.15rem;">Extract Claims</h2>
        <p class="meta">Run regex-based claim extraction on feed items to populate the knowledge base.</p>
        <p style="color:var(--color-accent);">Run extraction &rarr;</p>
      </a>
      <a href="/admin/knowledge/gaps" class="card card-hover" style="text-decoration:none;color:inherit;">
        <h2 style="font-size:1.15rem;">Knowledge Builder</h2>
        <p class="meta">Review unanswered questions captured from Ask TRACE. Prioritise knowledge gaps and track building work.</p>
        <p style="color:var(--color-accent);">Open gaps &rarr;</p>
      </a>
    </div>

    <section class="card" style="margin-top:3rem;">
      <h2>Security boundary</h2>
      <p class="meta">
        Cloudflare Access authenticates this area. Server-side role mapping authorises mutations, which are forwarded
        through signed, replay-protected internal requests. Browser-held administrator secrets are not used.
      </p>
    </section>
  </div>
</BaseLayout>
