---
import BaseLayout from "../../layouts/BaseLayout.astro";

export const prerender = false;

interface JobRow {
  id: number; source_name: string | null; job_type: string; status: string; result_status: string;
  items_processed: number; items_created: number; items_rejected: number; items_skipped: number;
  error_message: string | null; outcome_detail: string | null; started_at: string | null; completed_at: string | null;
}
interface CronRow {
  id: number; cron_expression: string; status: string; started_at: string; completed_at: string | null;
  items_processed: number; items_failed: number; items_rejected: number; items_skipped: number; outcome_detail: string | null; error_message: string | null;
}

let jobs: JobRow[] = [];
let cronRuns: CronRow[] = [];
let loadError: string | null = null;
try {
  const db = Astro.locals.runtime.env.DB;
  [jobs, cronRuns] = await Promise.all([
    db.prepare(`
      SELECT j.id, s.name AS source_name, j.job_type, j.status, j.result_status,
             j.items_processed, j.items_created, j.items_rejected, j.items_skipped,
             j.error_message, j.outcome_detail, j.started_at, j.completed_at
      FROM ingestion_jobs j LEFT JOIN sources s ON s.id = j.source_id
      ORDER BY j.created_at DESC LIMIT 100
    `).all<JobRow>().then((result) => result.results),
    db.prepare(`
      SELECT id, cron_expression, status, started_at, completed_at, items_processed,
             items_failed, items_rejected, items_skipped, outcome_detail, error_message
      FROM cron_runs ORDER BY started_at DESC LIMIT 30
    `).all<CronRow>().then((result) => result.results),
  ]);
} catch {
  loadError = "Operational data is unavailable. Verify the D1 binding and stabilisation migration.";
}

const fmt = (value: string | null) => value ? new Date(value).toLocaleString("en-GB") : "—";
---

<BaseLayout title="Admin — Ingestion Jobs" description="Real ingestion and schedule outcomes.">
  <div class="wrap">
    <h1>Admin: Ingestion Jobs</h1>
    <p class="meta" style="margin-bottom:2rem;"><a href="/admin/sources">Sources</a> · <a href="/admin/review">Review</a> · <a href="/admin">Admin home</a></p>

    {loadError && <div class="card"><p class="meta">{loadError}</p></div>}

    {!loadError && <>
      <section>
        <h2>Source runs</h2>
        <p class="meta">Unsupported connectors and partial outcomes are shown explicitly; “completed” only describes job termination.</p>
        <div style="overflow-x:auto;margin-top:1rem;">
          <table style="width:100%;border-collapse:collapse;font-size:0.82rem;">
            <thead><tr style="text-align:left;border-bottom:2px solid var(--border);"><th>ID</th><th>Source</th><th>Type</th><th>Outcome</th><th>Discovered</th><th>Accepted</th><th>Rejected</th><th>Skipped</th><th>Started / completed</th><th>Detail</th></tr></thead>
            <tbody>
              {jobs.map((job) => <tr style="vertical-align:top;border-bottom:1px solid var(--border);">
                <td>{job.id}</td><td>{job.source_name ?? "System"}</td><td><code>{job.job_type}</code></td>
                <td><span class={`badge badge-${job.result_status === "succeeded" ? "confirmed" : job.result_status === "failed" ? "disputed" : "provisional"}`}>{job.result_status}</span></td>
                <td>{job.items_processed}</td><td>{job.items_created}</td><td>{job.items_rejected}</td><td>{job.items_skipped}</td>
                <td class="meta">{fmt(job.started_at)}<br />{fmt(job.completed_at)}</td>
                <td class="meta">{job.error_message ?? job.outcome_detail ?? "—"}</td>
              </tr>)}
              {jobs.length === 0 && <tr><td colspan="10" class="meta" style="padding:2rem;text-align:center;">No ingestion runs have been recorded.</td></tr>}
            </tbody>
          </table>
        </div>
      </section>

      <section style="margin-top:2.5rem;">
        <h2>Scheduled runs</h2>
        <div style="overflow-x:auto;margin-top:1rem;">
          <table style="width:100%;border-collapse:collapse;font-size:0.82rem;">
            <thead><tr style="text-align:left;border-bottom:2px solid var(--border);"><th>Schedule</th><th>Status</th><th>Processed</th><th>Failed</th><th>Rejected</th><th>Skipped</th><th>Timing</th><th>Detail</th></tr></thead>
            <tbody>
              {cronRuns.map((run) => <tr style="vertical-align:top;border-bottom:1px solid var(--border);"><td><code>{run.cron_expression}</code></td><td>{run.status}</td><td>{run.items_processed}</td><td>{run.items_failed}</td><td>{run.items_rejected}</td><td>{run.items_skipped}</td><td class="meta">{fmt(run.started_at)}<br />{fmt(run.completed_at)}</td><td class="meta">{run.error_message ?? run.outcome_detail ?? "—"}</td></tr>)}
              {cronRuns.length === 0 && <tr><td colspan="8" class="meta" style="padding:2rem;text-align:center;">No scheduled runs have been recorded.</td></tr>}
            </tbody>
          </table>
        </div>
      </section>
    </>}
  </div>
</BaseLayout>
