---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Admin — Ingestion Jobs"
  description="Monitor scheduled ingestion jobs, view success/failure rates, and inspect errors."
>
  <div class="wrap">
    <h1>Admin: Ingestion Jobs</h1>
    <p class="meta" style="margin-bottom:2rem;">
      <a href="/admin/sources">← Sources</a> &middot; <a href="/admin">Admin home</a>
    </p>

    <p style="padding:0.75rem;background:var(--surface-2);border-radius:var(--radius);font-size:0.9rem;margin-bottom:2rem;">
      Job history is stored in the <code>ingestion_jobs</code> D1 table and surfaced via the Worker API. Recent jobs appear below.
    </p>

    <div style="overflow-x:auto;">
      <table style="width:100%;border-collapse:collapse;font-size:0.9rem;">
        <thead>
          <tr style="border-bottom:2px solid var(--border);text-align:left;">
            <th style="padding:0.5rem;">Job ID</th>
            <th style="padding:0.5rem;">Source</th>
            <th style="padding:0.5rem;">Type</th>
            <th style="padding:0.5rem;">Status</th>
            <th style="padding:0.5rem;">Processed</th>
            <th style="padding:0.5rem;">Created</th>
            <th style="padding:0.5rem;">Started</th>
          </tr>
        </thead>
        <tbody>
          <tr style="border-bottom:1px solid var(--border);">
            <td colspan="7" style="padding:2rem;text-align:center;" class="meta">
              No jobs have run yet. Jobs will appear here once the ingestion worker is deployed and cron triggers begin.
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <section style="margin-top:2rem;">
      <h2>Job Types</h2>
      <dl style="margin-top:0.75rem;">
        <div style="display:flex;justify-content:space-between;padding:0.25rem 0;border-bottom:1px solid var(--border);"><dt>fetch</dt><dd class="meta">Retrieve items from a source feed or API</dd></div>
        <div style="display:flex;justify-content:space-between;padding:0.25rem 0;border-bottom:1px solid var(--border);"><dt>classify</dt><dd class="meta">Run topic and source classification on raw items (Phase 3)</dd></div>
        <div style="display:flex;justify-content:space-between;padding:0.25rem 0;border-bottom:1px solid var(--border);"><dt>dedup</dt><dd class="meta">Detect and merge duplicate items across sources</dd></div>
        <div style="display:flex;justify-content:space-between;padding:0.25rem 0;border-bottom:1px solid var(--border);"><dt>cluster</dt><dd class="meta">Group related items into story clusters (Phase 3)</dd></div>
        <div style="display:flex;justify-content:space-between;padding:0.25rem 0;border-bottom:1px solid var(--border);"><dt>health_check</dt><dd class="meta">Verify source URLs are reachable and responsive</dd></div>
        <div style="display:flex;justify-content:space-between;padding:0.25rem 0;"><dt>briefing</dt><dd class="meta">Generate daily or weekly briefing from clustered stories (Phase 3)</dd></div>
      </dl>
    </section>
  </div>
</BaseLayout>
