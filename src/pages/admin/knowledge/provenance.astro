---
// KC-05C: publisher-only review queue for claim-relative provenance proposals.
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { authenticateAccessRequest, type AccessEnvironment } from "../../../security/access-auth";

export const prerender = false;
const env = Astro.locals.runtime.env;
const identity = await authenticateAccessRequest(Astro.request, env as unknown as AccessEnvironment);
if (!identity || identity.role !== "publisher") return new Response("Forbidden", { status: 403 });

interface ProposalRow {
  id: string;
  claim_assertion_id: string;
  canonical_claim_id: string;
  canonical_text: string;
  canonical_url: string;
  proposed_relationship: string;
  proposed_directness: string;
  proposed_source_role: string;
  proposed_evidence_treatment: string;
  confidence: number;
  review_requirement: string;
  rationale: string;
}

const rows = await (env.DB as D1Database).prepare(`
  SELECT proposal.id, proposal.claim_assertion_id, proposal.canonical_claim_id,
         claim.canonical_text, document.canonical_url,
         proposal.proposed_relationship, proposal.proposed_directness,
         proposal.proposed_source_role, proposal.proposed_evidence_treatment,
         proposal.confidence, proposal.review_requirement, proposal.rationale
  FROM knowledge_claim_provenance_proposals proposal
  JOIN canonical_claims claim ON claim.id = proposal.canonical_claim_id
  JOIN source_documents document ON document.id = proposal.source_document_id
  WHERE proposal.state = 'proposed'
  ORDER BY CASE proposal.review_requirement WHEN 'mandatory' THEN 0 ELSE 1 END,
           proposal.confidence ASC, proposal.created_at DESC
  LIMIT 100
`).all<ProposalRow>();
const proposals = rows.results ?? [];
const label = (value: string) => value.replace(/_/g, " ");
---

<BaseLayout title="Provenance Review — TRACE Knowledge Builder" description="Publisher review queue for claim provenance proposals.">
  <div class="wrap">
    <h1>Provenance proposal review</h1>
    <p class="meta">These proposals describe source lineage and claim-relative evidence treatment. They remain non-public until reviewed. Accepting updates the assertion metadata only; it does not create a provenance group or membership.</p>
    <p style="margin:1rem 0 2rem;"><a href="/admin/knowledge" style="color:var(--color-accent);">&larr; Knowledge Builder</a> &nbsp;|&nbsp; <a href="/admin/knowledge/claim-matches" style="color:var(--color-accent);">Claim matches</a> &nbsp;|&nbsp; <a href="/admin" style="color:var(--color-accent);">Admin</a></p>

    {proposals.length === 0 ? (
      <div class="card"><p class="meta">No provenance proposals are waiting for review.</p></div>
    ) : (
      <div class="queue">
        {proposals.map((item) => (
          <form class="card provenance-form" data-proposal-id={item.id}>
            <div class="heading-row">
              <h2>{label(item.proposed_relationship)} <span class={item.review_requirement === "mandatory" ? "mandatory" : "standard"}>{label(item.review_requirement)} review</span></h2>
              <code>{item.id}</code>
            </div>
            <p class="meta">Source: <code>{item.canonical_url}</code> · assertion <code>{item.claim_assertion_id}</code></p>
            <div class="claim"><strong>Canonical claim</strong><p>{item.canonical_text}</p><small>Claim: <code>{item.canonical_claim_id}</code></small></div>
            <dl>
              <dt>Relationship</dt><dd>{label(item.proposed_relationship)}</dd>
              <dt>Directness</dt><dd>{label(item.proposed_directness)}</dd>
              <dt>Source role</dt><dd>{label(item.proposed_source_role)}</dd>
              <dt>Evidence treatment</dt><dd>{label(item.proposed_evidence_treatment)}</dd>
              <dt>Confidence</dt><dd>{Math.round(item.confidence * 100)}%</dd>
            </dl>
            <p class="rationale">{item.rationale}</p>
            <label>Review note
              <textarea name="review-note" rows="2" maxlength="2000" placeholder="Confirm or explain the lineage decision."></textarea>
            </label>
            <div class="actions">
              <select name="decision" aria-label="Provenance decision"><option value="accept">Accept metadata proposal</option><option value="reject">Reject proposal</option></select>
              <button type="submit" class="btn">Save decision</button><span class="result" role="status"></span>
            </div>
          </form>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<script>
  document.querySelectorAll(".provenance-form").forEach((form) => {
    const reviewForm = form as HTMLFormElement;
    reviewForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      const result = reviewForm.querySelector(".result") as HTMLElement;
      const decision = (reviewForm.querySelector("[name=decision]") as unknown as HTMLSelectElement).value;
      const body = {
        proposalId: reviewForm.dataset.proposalId,
        decision,
        reviewNote: (reviewForm.querySelector("[name=review-note]") as HTMLTextAreaElement).value,
      };
      result.textContent = "Saving…";
      try {
        const response = await fetch("/api/admin/knowledge/review-claim-provenance", {
          method: "PATCH", credentials: "include", headers: { "Content-Type": "application/json" }, body: JSON.stringify(body),
        });
        const payload = await response.json() as { error?: string };
        result.textContent = response.ok ? "Saved. Reloading…" : (payload.error ?? "Review failed.");
        if (response.ok) setTimeout(() => location.reload(), 500);
      } catch { result.textContent = "Review service unavailable."; }
    });
  });
</script>

<style>
.queue { display:grid; gap:1rem; }
.heading-row { display:flex; justify-content:space-between; gap:1rem; align-items:center; }
.heading-row h2 { font-size:1.05rem; margin:0; text-transform:capitalize; }
.mandatory, .standard { font-size:0.72rem; padding:0.15rem 0.45rem; border-radius:4px; }
.mandatory { background:#fff3cd; color:#856404; }.standard { background:var(--color-bg-muted); }
.claim { padding:0.75rem; background:var(--color-bg-muted); border:1px solid var(--color-border); border-radius:4px; margin:1rem 0; }
.claim p { margin:0.35rem 0; }.rationale { font-size:0.88rem; color:var(--color-muted); }
dl { display:grid; grid-template-columns:max-content 1fr; gap:0.3rem 1rem; font-size:0.88rem; } dt { font-weight:600; } dd { margin:0; }
label { display:block; margin-top:0.75rem; font-size:0.85rem; font-weight:600; }
textarea { display:block; width:100%; box-sizing:border-box; margin-top:0.25rem; padding:0.5rem; font:inherit; border:1px solid var(--color-border); border-radius:4px; background:var(--color-bg-muted); }
.actions { display:flex; align-items:center; gap:0.75rem; margin-top:0.75rem; } select { padding:0.45rem; border:1px solid var(--color-border); border-radius:4px; background:var(--color-bg); }
.result { font-size:0.85rem; color:var(--color-muted); }
@media (max-width:640px) { .heading-row { align-items:flex-start; flex-direction:column; } .actions { align-items:stretch; flex-direction:column; } }
</style>
