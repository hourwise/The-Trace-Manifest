---
// KC-05F: publisher-only unresolved claim conflict queue.
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { authenticateAccessRequest, type AccessEnvironment } from "../../../security/access-auth";

export const prerender = false;
const env = Astro.locals.runtime.env;
const identity = await authenticateAccessRequest(Astro.request, env as unknown as AccessEnvironment);
if (!identity || identity.role !== "publisher") return new Response("Forbidden", { status: 403 });

interface ConflictRow {
  id: string;
  source_claim_id: string;
  source_text: string;
  target_claim_id: string;
  target_text: string;
  conflict_kind: string;
  confidence: number;
  status: string;
  explanation: string;
}
const rows = await (env.DB as D1Database).prepare(`
  SELECT conflict.id, conflict.source_claim_id, source.canonical_text AS source_text,
         conflict.target_claim_id, target.canonical_text AS target_text,
         conflict.conflict_kind, conflict.confidence, conflict.status, conflict.explanation
  FROM knowledge_claim_conflict_cases conflict
  JOIN canonical_claims source ON source.id = conflict.source_claim_id
  JOIN canonical_claims target ON target.id = conflict.target_claim_id
  WHERE conflict.status IN ('unresolved','acknowledged')
  ORDER BY CASE conflict.status WHEN 'unresolved' THEN 0 ELSE 1 END, conflict.confidence DESC
  LIMIT 100
`).all<ConflictRow>();
const conflicts = rows.results ?? [];
const label = (value: string) => value.replace(/_/g, " ");
---

<BaseLayout title="Claim Conflicts — TRACE Knowledge Builder" description="Publisher review queue for unresolved claim conflicts.">
  <div class="wrap">
    <h1>Unresolved claim conflicts</h1>
    <p class="meta">Conflicting claims remain visible together. Review can acknowledge, resolve, dismiss, or reopen a case; no side is selected automatically and no evidence score is changed.</p>
    <p style="margin:1rem 0 2rem;"><a href="/admin/knowledge" style="color:var(--color-accent);">&larr; Knowledge Builder</a> &nbsp;|&nbsp; <a href="/admin/knowledge/claim-relationships" style="color:var(--color-accent);">Claim relationships</a> &nbsp;|&nbsp; <a href="/admin" style="color:var(--color-accent);">Admin</a></p>
    {conflicts.length === 0 ? <div class="card"><p class="meta">No unresolved claim conflicts are waiting for review.</p></div> : (
      <div class="queue">
        {conflicts.map((item) => (
          <form class="card conflict-form" data-conflict-id={item.id}>
            <div class="heading-row"><h2>{label(item.conflict_kind)} <span>{label(item.status)} · {Math.round(item.confidence * 100)}%</span></h2><code>{item.id}</code></div>
            <div class="comparison"><div><strong>Source claim</strong><p>{item.source_text}</p><small><code>{item.source_claim_id}</code></small></div><div><strong>Competing claim</strong><p>{item.target_text}</p><small><code>{item.target_claim_id}</code></small></div></div>
            <p class="rationale">{item.explanation}</p>
            <label>Review note<textarea name="review-note" rows="2" maxlength="2000" placeholder="For resolve or dismiss, explain the decision."></textarea></label>
            <div class="actions"><select name="decision" aria-label="Conflict decision"><option value="acknowledge">Acknowledge unresolved</option><option value="resolve">Resolve with documented decision</option><option value="dismiss">Dismiss as not material</option><option value="reopen">Reopen unresolved</option></select><button type="submit" class="btn">Save decision</button><span class="result" role="status"></span></div>
          </form>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<script>
  document.querySelectorAll(".conflict-form").forEach((form) => {
    const reviewForm = form as HTMLFormElement;
    reviewForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      const result = reviewForm.querySelector(".result") as HTMLElement;
      const decision = (reviewForm.querySelector("[name=decision]") as unknown as HTMLSelectElement).value;
      const body = { conflictCaseId: reviewForm.dataset.conflictId, decision, reviewNote: (reviewForm.querySelector("[name=review-note]") as HTMLTextAreaElement).value };
      result.textContent = "Saving…";
      try {
        const response = await fetch("/api/admin/knowledge/review-claim-conflict", { method: "PATCH", credentials: "include", headers: { "Content-Type": "application/json" }, body: JSON.stringify(body) });
        const payload = await response.json() as { error?: string };
        result.textContent = response.ok ? "Saved. Reloading…" : (payload.error ?? "Review failed.");
        if (response.ok) setTimeout(() => location.reload(), 500);
      } catch { result.textContent = "Review service unavailable."; }
    });
  });
</script>

<style>
.queue { display:grid; gap:1rem; }.heading-row { display:flex; justify-content:space-between; gap:1rem; align-items:center; }.heading-row h2 { font-size:1.05rem; margin:0; text-transform:capitalize; }.heading-row span { color:var(--color-accent); font-size:0.8rem; }
.comparison { display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin:1rem 0; }.comparison > div { padding:0.75rem; background:var(--color-bg-muted); border:1px solid var(--color-border); border-radius:4px; }.comparison p { margin:0.4rem 0; }.rationale { font-size:0.88rem; color:var(--color-muted); }
label { display:block; margin-top:0.75rem; font-size:0.85rem; font-weight:600; } textarea { display:block; width:100%; box-sizing:border-box; margin-top:0.25rem; padding:0.5rem; font:inherit; border:1px solid var(--color-border); border-radius:4px; background:var(--color-bg-muted); }.actions { display:flex; align-items:center; gap:0.75rem; margin-top:0.75rem; } select { padding:0.45rem; border:1px solid var(--color-border); border-radius:4px; background:var(--color-bg); }.result { font-size:0.85rem; color:var(--color-muted); }
@media (max-width:640px) { .comparison { grid-template-columns:1fr; } .heading-row { align-items:flex-start; flex-direction:column; } .actions { align-items:stretch; flex-direction:column; } }
</style>
