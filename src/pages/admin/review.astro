---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EvidenceBadge from "../../components/EvidenceBadge.astro";

// All 10 evidence states with their meanings and review triggers
const evidenceStates = [
  { status: "confirmed", label: "Confirmed", desc: "Multiple independent primary sources confirm this information. High confidence.", triggersReview: false },
  { status: "strongly_supported", label: "Strongly Supported", desc: "Primary sources with corroboration strongly support this claim.", triggersReview: false },
  { status: "provisionally_supported", label: "Provisionally Supported", desc: "Available evidence supports this claim, but verification is incomplete.", triggersReview: true },
  { status: "vendor_reported", label: "Vendor-reported", desc: "Information originates from a vendor. Independent verification pending.", triggersReview: true },
  { status: "community_reported", label: "Community-reported", desc: "Information reported by the community. Awaiting primary-source confirmation.", triggersReview: true },
  { status: "disputed", label: "Disputed", desc: "Conflicting claims or evidence exist. Treat with caution.", triggersReview: true },
  { status: "unverified", label: "Unverified", desc: "This item has not yet been verified against primary or independent sources.", triggersReview: true },
  { status: "corrected", label: "Corrected", desc: "This item has been corrected. The original statement was inaccurate or incomplete.", triggersReview: false },
  { status: "superseded", label: "Superseded", desc: "A more recent item provides updated or more accurate information.", triggersReview: false },
  { status: "outdated", label: "Outdated", desc: "The information may no longer be current. Seek more recent sources.", triggersReview: true },
];
---

<BaseLayout
  title="Admin — Review Queue"
  description="Manual review queue for high-impact claims, disputed stories, and corrections."
>
  <div class="wrap">
    <h1>Admin: Review Queue</h1>
    <p class="meta" style="margin-bottom:2rem;">
      <a href="/admin/sources">← Sources</a> &middot; <a href="/admin/jobs">Jobs</a> &middot; <a href="/admin">Admin home</a>
    </p>

    <p style="padding:0.75rem;background:var(--surface-2);border-radius:var(--radius);font-size:0.9rem;margin-bottom:2rem;">
      Items flagged for human review per <a href="/docs/adr/0004-human-review-boundary.md">ADR-0004</a>.
      The pipeline auto-flags items when: only Tier C sources report a story, a single non-Tier-A source reports,
      vendor claims conflict with independent findings, or story confidence is below threshold.
    </p>

    <!-- Pending review queue -->
    <section style="margin-bottom:2.5rem;">
      <h2>Pending Review</h2>
      <div class="card" style="text-align:center;padding:2rem;">
        <p class="meta">No items currently pending review.</p>
        <p class="meta" style="margin-top:0.5rem;">
          Items flagged with <code>needs_human_review = 1</code> in the <code>story_clusters</code> table appear here.
          The pipeline runs claim extraction and conflict detection at 09:00 UTC daily.
        </p>
        <p class="meta" style="margin-top:0.75rem;">
          API: <code>POST /admin/extract-claims</code> &middot; <code>POST /admin/detect-conflicts</code>
        </p>
      </div>
    </section>

    <!-- Evidence state reference -->
    <section style="margin-bottom:2.5rem;">
      <h2>Evidence States Reference</h2>
      <p class="meta" style="margin-bottom:1rem;">
        The 10-state evidence system. Each state determines whether an item needs human review.
      </p>
      <div style="display:flex;flex-direction:column;gap:0.65rem;">
        {evidenceStates.map((state) => (
          <div class="card" style="display:flex;align-items:flex-start;gap:0.75rem;padding:0.75rem 1rem;">
            <EvidenceBadge status={state.status} size="sm" />
            <div style="flex:1;min-width:0;">
              <p style="font-size:0.85rem;margin:0;">{state.desc}</p>
              {state.triggersReview && (
                <span class="review-indicator" style="margin-top:0.35rem;">Needs Review</span>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Review criteria -->
    <section style="margin-bottom:2.5rem;">
      <h2>Review Criteria</h2>
      <p class="meta">The following require human review before publication (per ADR-0004):</p>
      <ul style="padding-left:1.5rem;margin-top:0.75rem;display:flex;flex-direction:column;gap:0.35rem;" class="meta">
        <li><strong>High-impact security claims</strong> — CVEs, vulnerabilities, advisories</li>
        <li><strong>Legal or regulatory claims</strong> — legislation, compliance requirements</li>
        <li><strong>Claims accusing organisations or individuals of misconduct</strong></li>
        <li><strong>Major benchmark conclusions</strong> — "best model" rankings</li>
        <li><strong>"Best model" or "best provider" rankings</strong> — must be evidence-grounded</li>
        <li><strong>Corrections affecting prominent stories</strong> — must follow correction workflow</li>
        <li><strong>Sponsored comparisons</strong> — must flag commercial interest</li>
        <li><strong>Claims based mainly on community reports</strong> — Tier C only clusters</li>
        <li><strong>Stories with strong contradictory evidence</strong> — conflict detected</li>
        <li><strong>Extraordinary-severity claims</strong> — automatic flag regardless of source</li>
      </ul>
    </section>

    <!-- Review history -->
    <section>
      <h2>Review History</h2>
      <div class="card" style="text-align:center;padding:2rem;">
        <p class="meta">No reviews have been completed yet.</p>
        <p class="meta" style="margin-top:0.5rem;">
          Completed reviews are recorded in <code>story_clusters.reviewed_by</code> and <code>story_clusters.reviewed_at</code>.
        </p>
      </div>
    </section>

    <!-- Publish a story -->
    <section style="margin-top:2.5rem;">
      <h2>Publish a Story</h2>
      <p class="meta" style="margin-bottom:1rem;">
        Select a draft cluster, write the editorial summary, and publish. Published stories appear on the public <a href="/feed">feed</a> and <a href="/">homepage</a>.
      </p>

      <!-- Admin token -->
      <div class="card" style="margin-bottom:1.5rem;background:var(--surface-2);">
        <label for="admin-token" style="font-size:0.85rem;font-weight:600;display:block;margin-bottom:0.35rem;">Admin API Token</label>
        <div style="display:flex;gap:0.5rem;">
          <input type="password" id="admin-token" placeholder="Paste your ADMIN_API_TOKEN…" style="flex:1;font-family:var(--font-mono);font-size:0.8rem;" />
          <button type="button" id="save-token-btn" class="btn btn-secondary" style="white-space:nowrap;font-size:0.8rem;">Save</button>
        </div>
        <p class="meta" style="margin-top:0.35rem;font-size:0.75rem;">Stored in session storage only — cleared when you close the tab. Never sent to the Pages server.</p>
      </div>

      <!-- Cluster selector -->
      <div class="card" style="margin-bottom:1.5rem;background:var(--surface-2);">
        <div style="display:flex;gap:0.5rem;align-items:flex-end;flex-wrap:wrap;">
          <div style="flex:1;min-width:200px;">
            <label for="cluster-select" style="font-size:0.85rem;font-weight:600;display:block;margin-bottom:0.35rem;">Story Cluster</label>
            <select id="cluster-select" style="width:100%;" disabled>
              <option value="">— Enter token and click Load —</option>
            </select>
          </div>
          <button type="button" id="load-clusters-btn" class="btn btn-secondary" style="font-size:0.8rem;">Load Clusters</button>
        </div>
        <p class="meta" style="margin-top:0.35rem;font-size:0.75rem;" id="cluster-count"></p>
      </div>

      <!-- Source Material — appears when cluster selected -->
      <div id="source-material" class="card" style="margin-bottom:1.5rem;background:var(--surface-2);display:none;">
        <h3 style="font-size:0.95rem;margin-bottom:0.75rem;">Source Material <span class="meta" style="font-weight:400;" id="source-count"></span></h3>
        <div id="source-list" style="display:flex;flex-direction:column;gap:0.75rem;max-height:400px;overflow-y:auto;"></div>
      </div>

      <!-- Editorial fields -->
      <div class="card" style="margin-bottom:1.5rem;background:var(--surface-2);">
        <div style="display:flex;flex-direction:column;gap:1rem;">
          <div>
            <label for="pub-headline" style="font-size:0.85rem;font-weight:600;display:block;margin-bottom:0.25rem;">Headline <span class="meta" style="font-weight:400;">(optional — uses cluster title if blank)</span></label>
            <input type="text" id="pub-headline" placeholder="Override the auto-generated headline…" style="width:100%;" />
          </div>
          <div>
            <label for="pub-summary" style="font-size:0.85rem;font-weight:600;display:block;margin-bottom:0.25rem;">Summary <span style="color:var(--ev-disputed);">*required</span></label>
            <textarea id="pub-summary" rows="3" placeholder="A concise neutral summary of what happened. Min 20 characters." style="width:100%;resize:vertical;"></textarea>
          </div>
          <div>
            <label for="pub-analysis" style="font-size:0.85rem;font-weight:600;display:block;margin-bottom:0.25rem;">TRACE Editorial Analysis <span class="meta" style="font-weight:400;">(optional)</span></label>
            <textarea id="pub-analysis" rows="3" placeholder="Why this matters, what may be overstated, how it relates to earlier events." style="width:100%;resize:vertical;"></textarea>
          </div>
          <div>
            <label for="pub-why" style="font-size:0.85rem;font-weight:600;display:block;margin-bottom:0.25rem;">Why This Matters <span class="meta" style="font-weight:400;">(optional)</span></label>
            <input type="text" id="pub-why" placeholder="A one-line explanation of significance…" style="width:100%;" />
          </div>
          <div>
            <label for="pub-image" style="font-size:0.85rem;font-weight:600;display:block;margin-bottom:0.25rem;">Headline Image URL <span class="meta" style="font-weight:400;">(optional — auto-detected from feed if blank)</span></label>
            <input type="url" id="pub-image" placeholder="https://…" style="width:100%;" />
          </div>
          <div>
            <label for="pub-reviewer" style="font-size:0.85rem;font-weight:600;display:block;margin-bottom:0.25rem;">Reviewed By</label>
            <input type="text" id="pub-reviewer" placeholder="Your name or initials" value="admin" style="width:100%;max-width:200px;" />
          </div>
        </div>
        <div style="margin-top:1rem;display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap;">
          <button type="button" id="publish-btn" class="btn btn-primary" disabled>Publish Story</button>
          <button type="button" id="archive-btn" class="btn btn-secondary" style="font-size:0.8rem;" disabled>Archive (not news)</button>
          <span id="publish-status" class="meta"></span>
        </div>
      </div>

      <!-- Recent publishes -->
      <div class="card" style="background:var(--surface-2);">
        <h3 style="font-size:0.95rem;margin-bottom:0.5rem;">Recently Published</h3>
        <div id="recent-publishes" class="meta" style="font-size:0.8rem;">—</div>
      </div>
    </section>

    <script>
      const WORKER_URL = "https://trace-manifest-ingestion.philgeran.workers.dev";

      function getToken(): string { return sessionStorage.getItem("admin_token") || ""; }
      function setToken(t: string): void { sessionStorage.setItem("admin_token", t); }

      function authHeaders(): Record<string, string> {
        return {
          "Authorization": "Bearer " + getToken(),
          "Content-Type": "application/json",
        };
      }

      function status(msg: string, isError: boolean): void {
        const el = document.getElementById("publish-status");
        if (el) { el.textContent = msg; el.style.color = isError ? "var(--ev-disputed)" : "var(--ev-confirmed)"; }
      }

      // Helper: typed getElementById
      function $<T extends HTMLElement>(id: string): T | null {
        return document.getElementById(id) as T | null;
      }

      // Save token
      $<HTMLButtonElement>("save-token-btn")?.addEventListener("click", () => {
        const input = $<HTMLInputElement>("admin-token");
        const t = input?.value?.trim();
        if (t) { setToken(t); status("Token saved for this session.", false); }
        else { status("Enter a token first.", true); }
      });

      // Load clusters
      $<HTMLButtonElement>("load-clusters-btn")?.addEventListener("click", async () => {
        const select = $<HTMLSelectElement>("cluster-select");
        const count = document.getElementById("cluster-count");
        if (!select || !count) return;

        if (!getToken()) { status("Save your admin token first.", true); return; }

        select.disabled = true;
        select.innerHTML = '<option value="">Loading…</option>';
        status("Loading clusters…", false);

        try {
          const res = await fetch(`${WORKER_URL}/admin/clusters?limit=50`, { headers: authHeaders() });
          if (!res.ok) { throw new Error(`HTTP ${res.status}`); }
          const clusters: Array<{ id: number; title: string; publication_status: string; source_count: number }> = await res.json();

          select.innerHTML = '<option value="">— Select a cluster —</option>';
          if (clusters.length > 0) {
            // Fetch source types for all clusters to show indicators
            const clusterMeta: Record<number, string> = {};
            await Promise.all(clusters.slice(0, 15).map(async (c: any) => {
              try {
                const srcRes = await fetch(`${WORKER_URL}/admin/cluster-sources?clusterId=${c.id}`, { headers: authHeaders() });
                if (srcRes.ok) {
                  const srcs: Array<{ sourceName: string }> = await srcRes.json();
                  const names = new Set(srcs.map((s: any) => s.sourceName));
                  clusterMeta[c.id] = [...names].slice(0, 3).join(", ");
                }
              } catch { clusterMeta[c.id] = ""; }
            }));

            clusters.forEach((c: any) => {
              const opt = document.createElement("option");
              opt.value = String(c.id);
              const meta = clusterMeta[c.id] ? ` — ${clusterMeta[c.id]}` : "";
              opt.textContent = `#${c.id}: ${c.title.slice(0, 70)} [${c.publication_status}] (${c.source_count || 0} sources${meta})`;
              select.appendChild(opt);
            });
            count.textContent = `${clusters.length} clusters loaded. ${clusters.filter((c) => c.publication_status === 'draft').length} drafts.`;
          } else {
            count.textContent = "No clusters found. The ingestion pipeline may not have run yet.";
          }

          select.disabled = false;
          status("Select a cluster from the dropdown.", false);
        } catch (e) {
          select.innerHTML = '<option value="">— Error loading —</option>';
          select.disabled = false;
          count.textContent = "";
          status("Failed to load. Check your token and network.", true);
          console.error(e);
        }
      });

      // Enable publish button when cluster selected and summary has content
      function checkPublishReady(): void {
        const btn = $<HTMLButtonElement>("publish-btn");
        const archBtn = $<HTMLButtonElement>("archive-btn");
        const select = $<HTMLSelectElement>("cluster-select");
        const summary = $<HTMLTextAreaElement>("pub-summary");
        if (btn && select && summary) {
          btn.disabled = !select.value || !summary.value || summary.value.trim().length < 20;
        }
        if (archBtn && select) {
          archBtn.disabled = !select.value;
        }
      }
      $<HTMLSelectElement>("cluster-select")?.addEventListener("change", checkPublishReady);
      $<HTMLTextAreaElement>("pub-summary")?.addEventListener("input", checkPublishReady);

      // Load source material when cluster is selected
      $<HTMLSelectElement>("cluster-select")?.addEventListener("change", async function() {
        const clusterId = parseInt(this.value || "");
        const panel = document.getElementById("source-material");
        const list = document.getElementById("source-list");
        const count = document.getElementById("source-count");
        if (!panel || !list || !count) return;

        if (!clusterId) { panel.style.display = "none"; return; }
        if (!getToken()) return;

        panel.style.display = "block";
        list.innerHTML = '<p class="meta">Loading source material…</p>';
        count.textContent = "";

        try {
          const res = await fetch(`${WORKER_URL}/admin/cluster-sources?clusterId=${clusterId}`, { headers: authHeaders() });
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
          const sources: Array<{ title: string; url: string; excerpt: string | null; sourceName: string; sourceTier: string; publishedAt: string | null }> = await res.json();

          count.textContent = `(${sources.length} source${sources.length !== 1 ? "s" : ""})`;
          list.innerHTML = sources.map((s, i) => `
            <div style="padding:0.5rem 0;border-bottom:1px solid var(--border);${i === sources.length - 1 ? "border-bottom:none;" : ""}">
              <div style="display:flex;gap:0.5rem;align-items:baseline;flex-wrap:wrap;">
                <span class="badge badge-sm" style="font-size:0.65rem;">Tier ${s.sourceTier}</span>
                <span class="meta" style="font-size:0.7rem;">${s.sourceName}</span>
              </div>
              <a href="${s.url}" target="_blank" rel="noopener" style="font-size:0.85rem;font-weight:550;display:block;margin-top:0.2rem;">${s.title}</a>
              ${s.excerpt ? `<p class="meta" style="font-size:0.75rem;margin-top:0.15rem;line-height:1.4;">${s.excerpt.slice(0, 300)}${s.excerpt.length > 300 ? "…" : ""}</p>` : ""}
            </div>
          `).join("");
        } catch (e) {
          list.innerHTML = '<p class="meta" style="color:var(--ev-disputed);">Failed to load source material.</p>';
          console.error(e);
        }
      });

      // Archive button — hide boring clusters from the draft list
      $<HTMLButtonElement>("archive-btn")?.addEventListener("click", async () => {
        if (!getToken()) { status("Save your admin token first.", true); return; }
        const select = $<HTMLSelectElement>("cluster-select");
        const clusterId = parseInt(select?.value || "");
        if (!clusterId || isNaN(clusterId)) { status("Select a cluster first.", true); return; }

        const btn = $<HTMLButtonElement>("archive-btn");
        if (btn) { btn.disabled = true; btn.textContent = "Archiving…"; }
        status("Archiving…", false);

        try {
          const res = await fetch(`${WORKER_URL}/admin/archive-cluster`, {
            method: "POST",
            headers: authHeaders(),
            body: JSON.stringify({ clusterId }),
          });
          if (!res.ok) { const d = await res.json() as { error?: string }; throw new Error(d.error || `HTTP ${res.status}`); }
          status("Archived. Click Load Clusters to refresh.", false);
          // Remove from dropdown
          if (select) { const opt = select.querySelector(`option[value="${clusterId}"]`); if (opt) opt.remove(); }
        } catch (e: any) {
          status(e.message || "Archive failed", true);
        } finally {
          if (btn) { btn.disabled = false; btn.textContent = "Archive (not news)"; }
        }
      });

      // Publish button
      $<HTMLButtonElement>("publish-btn")?.addEventListener("click", async () => {
        if (!getToken()) { status("Save your admin token first.", true); return; }

        const select = $<HTMLSelectElement>("cluster-select");
        const clusterId = parseInt(select?.value || "");
        if (!clusterId || isNaN(clusterId)) { status("Select a cluster first.", true); return; }

        const summary = $<HTMLTextAreaElement>("pub-summary")?.value?.trim();
        if (!summary || summary.length < 20) { status("Summary must be at least 20 characters.", true); return; }

        const body = {
          clusterId,
          summary,
          headline: $<HTMLInputElement>("pub-headline")?.value?.trim() || undefined,
          editorialAnalysis: $<HTMLTextAreaElement>("pub-analysis")?.value?.trim() || undefined,
          whyItMatters: $<HTMLInputElement>("pub-why")?.value?.trim() || undefined,
          headlineImageUrl: $<HTMLInputElement>("pub-image")?.value?.trim() || undefined,
          reviewedBy: $<HTMLInputElement>("pub-reviewer")?.value?.trim() || "admin",
        };

        const btn = $<HTMLButtonElement>("publish-btn");
        if (btn) { btn.disabled = true; btn.textContent = "Publishing…"; }
        status("Publishing…", false);

        try {
          const res = await fetch(`${WORKER_URL}/admin/publish-story`, {
            method: "POST",
            headers: authHeaders(),
            body: JSON.stringify(body),
          });
          const data: { error?: string; story?: { slug: string; headline: string } } = await res.json();

          if (!res.ok) {
            status(data.error || `HTTP ${res.status}`, true);
          } else if (data.story) {
            status(`Published! Slug: ${data.story.slug}`, false);
            const recent = document.getElementById("recent-publishes");
            if (recent) {
              recent.innerHTML = `<a href="/stories/${data.story.slug}" style="font-weight:550;">${data.story.headline}</a> <span class="meta">— ${new Date().toLocaleTimeString()}</span>` + (recent.innerHTML !== "—" ? "<br>" + recent.innerHTML : "");
            }
          }
        } catch (e) {
          status("Network error — check console.", true);
          console.error(e);
        } finally {
          if (btn) { btn.disabled = false; btn.textContent = "Publish Story"; }
        }
      });

      // Restore saved token on load
      (function() {
        const saved = getToken();
        if (saved) {
          const input = $<HTMLInputElement>("admin-token");
          if (input) input.value = saved;
        }
      })();
    </script>

    <!-- Record a correction -->
    <section style="margin-top:2.5rem;">
      <h2>Record a Correction</h2>
      <p class="meta" style="margin-bottom:1rem;">
        Use <code>POST /admin/correct</code> to record a correction against a cluster or claim.
        Corrections are permanent and visible on the public <a href="/corrections">corrections ledger</a>.
      </p>

      <div class="card" style="background:var(--surface-2);">
        <h3 style="font-size:0.95rem;margin-bottom:0.75rem;">API Reference</h3>
        <pre style="font-size:0.78rem;line-height:1.55;overflow-x:auto;padding:0.75rem;background:var(--bg);border-radius:var(--radius);" class="mono"><code>POST /admin/correct
Authorization: Bearer &lt;ADMIN_API_TOKEN&gt;
Content-Type: application/json

{'{'}
  "clusterId": 1,              // optional: target cluster
  "claimId": null,             // optional: target claim (use clusterId OR claimId)
  "correctionType": "factual_error | rating_change | licence_correction |
                     pricing_correction | benchmark_correction | supersession |
                     deprecation | methodology_update | other",
  "previousStatement": "Original text that was incorrect",
  "updatedStatement": "Corrected text",
  "previousEvidenceStatus": "vendor_reported",    // optional
  "updatedEvidenceStatus": "corrected",           // optional, defaults to "corrected"
  "reason": "Why the correction was made",
  "evidenceUrl": "https://...",                   // optional
  "impact": "What changed as a result",           // optional
  "correctedBy": "reviewer-name"
{'}'}</code></pre>
      </div>

      <div class="card" style="margin-top:1rem;background:var(--surface-2);">
        <h3 style="font-size:0.95rem;margin-bottom:0.75rem;">Correction Types</h3>
        <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
          {[
            "factual_error", "rating_change", "licence_correction", "pricing_correction",
            "benchmark_correction", "supersession", "deprecation", "methodology_update", "other"
          ].map(t => (
            <code style="font-size:0.75rem;padding:0.2em 0.5em;background:var(--bg);border-radius:4px;">{t}</code>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
