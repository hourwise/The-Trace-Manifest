---
import BaseLayout from "../layouts/BaseLayout.astro";
import EvidenceBadge from "../components/EvidenceBadge.astro";
import { getPublishedCorrections } from "../lib/server/d1";

export const prerender = false;

let corrections: Awaited<ReturnType<typeof getPublishedCorrections>> = [];
let loadError: string | null = null;
try {
  corrections = await getPublishedCorrections(Astro.locals.runtime.env.DB, 100);
} catch {
  loadError = "The corrections ledger is temporarily unavailable.";
}

const labels: Record<string, string> = {
  factual_error: "Factual error", rating_change: "Rating change", licence_correction: "Licence correction",
  pricing_correction: "Pricing correction", benchmark_correction: "Benchmark correction",
  supersession: "Superseded", deprecation: "Deprecated", methodology_update: "Methodology update", other: "Correction",
};
const safeEvidenceUrl = (value: string | null) => {
  if (!value) return null;
  try { const url = new URL(value); return url.protocol === "https:" || url.protocol === "http:" ? url.href : null; } catch { return null; }
};
---

<BaseLayout title="Corrections Ledger" description="Public record of reviewed corrections and superseded conclusions.">
  <div class="wrap" style="max-width:42rem;">
    <h1>Corrections Ledger</h1>
    <p class="lead" style="margin-bottom:2rem;">Corrections remain public. Each entry below was explicitly recorded and published by an authorised reviewer.</p>

    {loadError && <div class="card"><p class="meta">{loadError}</p></div>}
    {!loadError && corrections.length === 0 && <div class="card" style="text-align:center;padding:2rem;"><p class="meta">No published corrections have been recorded.</p></div>}

    <div style="display:flex;flex-direction:column;gap:1.5rem;">
      {corrections.map((correction) => {
        const evidenceUrl = safeEvidenceUrl(correction.evidenceUrl);
        return <article class="card" style="border-left:4px solid var(--ev-corrected);">
          <div style="display:flex;justify-content:space-between;gap:0.5rem;">
            <p class="meta"><strong>{labels[correction.correctionType] ?? correction.correctionType}</strong> · {new Date(correction.correctedAt).toLocaleDateString("en-GB")}</p>
            <EvidenceBadge status="corrected" size="sm" />
          </div>
          <div style="margin-top:0.75rem;padding:0.6rem;background:color-mix(in oklch, var(--ev-disputed) 8%, transparent);border-radius:var(--radius);"><p style="text-decoration:line-through;margin:0;">Previously: {correction.previousStatement}</p></div>
          <div style="margin-top:0.5rem;padding:0.6rem;background:color-mix(in oklch, var(--ev-confirmed) 8%, transparent);border-radius:var(--radius);"><p style="margin:0;">Updated: {correction.updatedStatement}</p></div>
          <p class="meta" style="margin-top:0.75rem;"><strong>Reason:</strong> {correction.reason}</p>
          {correction.impact && <p class="meta"><strong>Impact:</strong> {correction.impact}</p>}
          {evidenceUrl && <p class="meta"><a href={evidenceUrl} rel="noopener noreferrer">Review supporting evidence →</a></p>}
        </article>;
      })}
    </div>
  </div>
</BaseLayout>
