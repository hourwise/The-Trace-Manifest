---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BenchmarkHealthBadge from "../../components/BenchmarkHealthBadge.astro";
import { getPublishedBenchmarkBySlug, getPublishedBenchmarkRuns } from "../../lib/server/catalog-data";

export const prerender = false;
const slug = Astro.params.slug ?? "";
let benchmark: Awaited<ReturnType<typeof getPublishedBenchmarkBySlug>> = null;
let runs: Awaited<ReturnType<typeof getPublishedBenchmarkRuns>> = [];
let unavailable = false;
try {
  const db = Astro.locals.runtime.env.DB;
  benchmark = await getPublishedBenchmarkBySlug(db, slug);
  if (benchmark) runs = await getPublishedBenchmarkRuns(db, benchmark.id);
} catch { unavailable = true; }
Astro.response.status = unavailable ? 503 : benchmark ? 200 : 404;
---

<BaseLayout title={benchmark ? `${benchmark.name} — Benchmark Detail` : "Benchmark not available"} description={benchmark?.purpose ?? "Reviewed benchmark record."}>
  <div class="wrap" style="max-width:46rem;">
    <nav class="meta" aria-label="Breadcrumb"><a href="/benchmarks">Benchmarks</a> &rsaquo; {benchmark?.name ?? "Not available"}</nav>
    {unavailable ? <div class="card" style="margin-top:2rem;"><h1>Benchmark data unavailable</h1></div> : !benchmark ?
      <div class="card" style="margin-top:2rem;"><h1>Benchmark not found</h1><p class="meta">This benchmark is not published or does not exist.</p></div> :
      <article style="margin-top:1.5rem;">
        <div style="display:flex;gap:0.75rem;align-items:center;"><h1>{benchmark.name}</h1><BenchmarkHealthBadge healthStatus={benchmark.healthStatus} /></div>
        <p class="meta">{benchmark.version ?? "Version not recorded"} · {benchmark.owner ?? "Owner not recorded"} · {benchmark.domain}</p>
        <p class="lead">{benchmark.purpose}</p>
        <dl class="card" style="display:grid;gap:0.6rem;">
          <div><dt class="meta">Reproducibility</dt><dd>{benchmark.reproducibility ?? "Not assessed"}</dd></div>
          <div><dt class="meta">Contamination concern</dt><dd>{benchmark.contaminationConcern ?? "Not assessed"}</dd></div>
          <div><dt class="meta">Saturation</dt><dd>{benchmark.saturationLevel ?? "Not assessed"}</dd></div>
          {benchmark.lastReviewedAt && <div><dt class="meta">Last reviewed</dt><dd>{benchmark.lastReviewedAt}</dd></div>}
        </dl>
        <section style="margin-top:2rem;"><h2>Reviewed results</h2>
          {runs.length === 0 ? <p class="meta">No benchmark runs have independently completed review and publication.</p> :
            <div class="table-wrap"><table class="data"><thead><tr><th>Model</th><th>Score</th><th>Date</th><th>Provenance</th><th>Source</th></tr></thead><tbody>
              {runs.map((run) => <tr><td>{run.modelName ?? "Unlinked model"}</td><td>{run.scoreDisplay}</td><td>{run.testDate}</td><td>{run.isIndependent ? "Independent" : run.isVendorRun ? "Vendor-run" : "Other reviewed source"}</td><td>{run.sourceUrl ? <a href={run.sourceUrl} rel="noopener noreferrer">Evidence</a> : "Withheld"}</td></tr>)}
            </tbody></table></div>}
        </section>
      </article>}
  </div>
</BaseLayout>
