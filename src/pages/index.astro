---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Evidence-linked AI intelligence"
  description="The Trace Manifest is a current, evidence-linked intelligence platform tracking AI models, benchmarks, research, providers, and open-source activity. Follow the evidence. Understand the change."
  currentNav="Latest"
>
  <!-- Hero -->
  <section class="hero" style="text-align:center;">
    <div class="wrap">
      <h1 class="display h1" style="max-width:20ch;margin:0 auto 1rem;">
        Follow the evidence.<br />Understand the change.
      </h1>
      <p class="lead" style="max-width:36rem;margin:0 auto 1.5rem;">
        A current, evidence-linked intelligence platform showing what changed in AI, what is credible, what is disputed, and what people should actually use.
      </p>
      <div class="hero-actions" style="justify-content:center;">
        <a href="/feed" class="btn btn-primary">View the feed</a>
        <a href="/ask" class="btn btn-secondary">Ask a question</a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section" style="padding-block:2rem;">
    <div class="wrap">
      <div class="grid-3" style="text-align:center;">
        <div><p class="display h1" style="color:var(--accent);margin-bottom:0;">64</p><p class="meta">Sources registered</p></div>
        <div><p class="display h1" style="color:var(--accent);margin-bottom:0;">Daily</p><p class="meta">Briefing published</p></div>
        <div><p class="display h1" style="color:var(--accent);margin-bottom:0;">Public</p><p class="meta">Corrections ledger</p></div>
      </div>
    </div>
  </section>

  <!-- What we track -->
  <section class="section" style="padding-block:3rem;">
    <div class="wrap">
      <h2 class="display h2" style="text-align:center;margin-bottom:2rem;">What we track</h2>
      <div class="grid-3">
        <div class="card card-hover"><h3 class="h3">Models &amp; Providers</h3><p class="meta" style="margin-top:0.5rem;">Frontier, open-weight, and local models. Pricing, capabilities, hardware requirements, and independent benchmarks.</p><p style="margin-top:0.75rem;"><a href="/models">Browse models →</a></p></div>
        <div class="card card-hover"><h3 class="h3">Benchmarks</h3><p class="meta" style="margin-top:0.5rem;">Methodology-aware comparison. Vendor claims vs independent results. Saturation, contamination, and reproducibility flags.</p><p style="margin-top:0.75rem;"><a href="/benchmarks">Browse benchmarks →</a></p></div>
        <div class="card card-hover"><h3 class="h3">Research &amp; Open Source</h3><p class="meta" style="margin-top:0.5rem;">Papers, repositories, releases, and community discoveries with evidence grading.</p><p style="margin-top:0.75rem;"><a href="/feed">Browse research →</a></p></div>
      </div>
    </div>
  </section>

  <!-- Evidence labels -->
  <section class="section" style="padding-block:2rem;">
    <div class="wrap">
      <h2 class="display h2" style="text-align:center;margin-bottom:1.5rem;">How we rate evidence</h2>
      <div style="display:flex;flex-wrap:wrap;gap:0.5rem;justify-content:center;margin-bottom:1.5rem;">
        <span class="badge badge-confirmed">Confirmed</span>
        <span class="badge badge-disputed">Disputed</span>
        <span class="badge badge-provisional">Unverified</span>
        <span class="badge badge-vendor">Vendor-reported</span>
        <span class="badge badge-corrected">Corrected</span>
        <span class="badge badge-outdated">Outdated</span>
      </div>
      <p class="meta" style="text-align:center;">Every rating is decomposable into source class, evidence quality, corroboration, timeliness, and independence. <a href="/methodology">Read our full methodology →</a></p>
    </div>
  </section>

  <!-- Stay current -->
  <section class="section" style="padding-block:2rem;">
    <div class="wrap">
      <h2 class="display h2" style="text-align:center;margin-bottom:1.5rem;">Stay current</h2>
      <div class="grid-2">
        <div class="card card-hover"><h3 class="h3">Daily Briefing</h3><p class="meta" style="margin-top:0.5rem;">Five things that matter today. Model releases, pricing changes, important research, security issues.</p><p style="margin-top:0.75rem;"><a href="/briefing/daily">Read today's briefing →</a></p></div>
        <div class="card card-hover"><h3 class="h3">Newsletter &amp; RSS</h3><p class="meta" style="margin-top:0.5rem;">Get the daily briefing by email or follow via RSS. Briefings published as downloadable Markdown.</p><p style="margin-top:0.75rem;"><a href="/rss/daily.xml">Subscribe via RSS →</a></p></div>
      </div>
    </div>
  </section>
</BaseLayout>
