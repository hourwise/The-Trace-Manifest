---
import BaseLayout from "../layouts/BaseLayout.astro";
import EvidenceBadge from "../components/EvidenceBadge.astro";
import { getPublishedStories } from "../lib/server/d1";

export const prerender = false;

// Fetch live stats for homepage
let latestStories: Awaited<ReturnType<typeof getPublishedStories>> = [];
let topicCount = 0;
let publishedStoryCount = 0;
let evidenceCount = 0;
let modelCount = 0;
let briefingLabel: string | null = null;

try {
  const db = Astro.locals.runtime.env.DB;
  [latestStories, publishedStoryCount, evidenceCount, modelCount, topicCount, briefingLabel] = await Promise.all([
    getPublishedStories(db, { limit: 4 }),
    db.prepare("SELECT COUNT(*) as count FROM story_clusters WHERE publication_status = 'published'").first<{ count: number }>().then(r => r?.count ?? 0),
    db.prepare("SELECT COUNT(*) as count FROM claim_evidence").first<{ count: number }>().then(r => r?.count ?? 0),
    db.prepare("SELECT COUNT(*) as count FROM models WHERE publication_status = 'published'").first<{ count: number }>().then(r => r?.count ?? 0),
    db.prepare("SELECT COUNT(DISTINCT topic) as count FROM story_clusters WHERE publication_status = 'published' AND topic IS NOT NULL").first<{ count: number }>().then(r => r?.count ?? 0),
    db.prepare("SELECT briefing_date FROM published_briefings WHERE briefing_type = 'daily' AND publication_status = 'published' ORDER BY briefing_date DESC LIMIT 1").first<{ briefing_date: string }>().then(r => r ? new Date(r.briefing_date).toLocaleDateString("en-GB", { day: "numeric", month: "short" }) : null),
  ]);
} catch {
  console.error(JSON.stringify({ message: "Homepage query failed" }));
}
---

<BaseLayout
  title="Evidence-linked AI intelligence"
  description="The Trace Manifest is a current, evidence-linked intelligence platform tracking AI models, benchmarks, research, providers, and open-source activity. Follow the evidence. Understand the change."
  currentNav="Latest"
>
  <!-- Hero -->
  <section class="hero" style="text-align:center;">
    <div class="wrap">
      <h1 class="display h1" style="max-width:20ch;margin:0 auto 1rem;">
        Follow the evidence.<br />Understand the change.
      </h1>
      <p class="lead" style="max-width:36rem;margin:0 auto 1.5rem;">
        A current, evidence-linked intelligence platform showing what changed in AI, what is credible, what is disputed, and what people should actually use.
      </p>
      <div class="hero-actions" style="justify-content:center;">
        <a href="/feed" class="btn btn-primary">View the feed</a>
        <a href="/ask-trace" class="btn btn-secondary">Ask a question</a>
      </div>
    </div>
  </section>

  <!-- Stats — live counts from database -->
  <section class="section" style="padding-block:2rem;">
    <div class="wrap">
      <div class="grid-3" style="text-align:center;">
        <div><p class="display h1" style="color:var(--accent);margin-bottom:0;">{publishedStoryCount || "—"}</p><p class="meta">Published stories</p></div>
        <div><p class="display h1" style="color:var(--accent);margin-bottom:0;">{evidenceCount || "—"}</p><p class="meta">Evidence records</p></div>
        <div><p class="display h1" style="color:var(--accent);margin-bottom:0;">{modelCount || "—"}</p><p class="meta">Models tracked</p></div>
      </div>
      <div class="grid-2" style="text-align:center;margin-top:1.5rem;">
        <div><p class="meta">Tracking {topicCount || "—"} topics</p></div>
        <div><p class="meta">Daily briefing: {briefingLabel || "—"}</p></div>
      </div>
    </div>
  </section>

  <!-- Latest stories — only shown when live data exists -->
  {latestStories.length > 0 && (
    <section class="section" style="padding-block:2rem;">
      <div class="wrap">
        <div style="display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.5rem;">
          <h2 class="display h2">Latest published stories</h2>
          <a href="/feed" class="meta">View all &rarr;</a>
        </div>
        <div class="grid-2">
          {latestStories.map(s => (
            <article class="card">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:0.5rem;">
                <span class="meta">{s.topic || "Uncategorised"}</span>
                <EvidenceBadge status={s.evidenceStatus} size="sm" />
              </div>
              <h3 style="font-size:1.05rem;margin-top:0.5rem;">
                <a href={`/stories/${s.slug}`}>{s.headline}</a>
              </h3>
              <p class="meta" style="margin-top:0.25rem;">
                {s.summary?.slice(0, 120)}{(s.summary?.length ?? 0) > 120 ? "…" : ""}
              </p>
              <p class="meta" style="margin-top:0.5rem;font-size:0.8rem;">
                {s.sourceCount} source{s.sourceCount !== 1 ? "s" : ""}
                {s.publishedAt && <> &middot; {new Date(s.publishedAt).toLocaleDateString("en-GB", { day: "numeric", month: "short" })}</>}
              </p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- What we track -->
  <section class="section" style="padding-block:3rem;">
    <div class="wrap">
      <h2 class="display h2" style="text-align:center;margin-bottom:2rem;">What we track</h2>
      <div class="grid-3">
        <div class="card card-hover"><h3 class="h3">Models &amp; Providers</h3><p class="meta" style="margin-top:0.5rem;">Frontier, open-weight, and local models. Pricing, capabilities, hardware requirements, and independent benchmarks.</p><p style="margin-top:0.75rem;"><a href="/models">Browse models &rarr;</a></p></div>
        <div class="card card-hover"><h3 class="h3">Benchmarks</h3><p class="meta" style="margin-top:0.5rem;">Methodology-aware comparison. Vendor claims vs independent results. Saturation, contamination, and reproducibility flags.</p><p style="margin-top:0.75rem;"><a href="/benchmarks">Browse benchmarks &rarr;</a></p></div>
        <div class="card card-hover"><h3 class="h3">Research &amp; Open Source</h3><p class="meta" style="margin-top:0.5rem;">Papers, repositories, releases, and community discoveries with evidence grading.</p><p style="margin-top:0.75rem;"><a href="/feed">Browse research &rarr;</a></p></div>
      </div>
    </div>
  </section>

  <!-- Evidence labels -->
  <section class="section" style="padding-block:2rem;">
    <div class="wrap">
      <h2 class="display h2" style="text-align:center;margin-bottom:1.5rem;">How we rate evidence</h2>
      <div style="display:flex;flex-wrap:wrap;gap:0.5rem;justify-content:center;margin-bottom:1.5rem;">
        <span class="badge badge-confirmed">Confirmed</span>
        <span class="badge badge-disputed">Disputed</span>
        <span class="badge badge-provisional">Unverified</span>
        <span class="badge badge-vendor">Vendor-reported</span>
        <span class="badge badge-corrected">Corrected</span>
        <span class="badge badge-outdated">Outdated</span>
      </div>
      <p class="meta" style="text-align:center;">Every rating is decomposable into source class, evidence quality, corroboration, timeliness, and independence. <a href="/methodology">Read our full methodology &rarr;</a></p>
    </div>
  </section>

  <!-- Stay current -->
  <section class="section" style="padding-block:2rem;">
    <div class="wrap">
      <h2 class="display h2" style="text-align:center;margin-bottom:1.5rem;">Stay current</h2>
      <div class="grid-2">
        <div class="card card-hover"><h3 class="h3">Daily Briefing</h3><p class="meta" style="margin-top:0.5rem;">Reviewed model releases, pricing changes, research, and security developments when a briefing has been published.</p><p style="margin-top:0.75rem;"><a href="/briefing/daily">Read the latest briefing &rarr;</a></p></div>
        <div class="card card-hover"><h3 class="h3">Newsletter &amp; RSS</h3><p class="meta" style="margin-top:0.5rem;">Get the daily briefing by email or follow via RSS. Briefings published as downloadable Markdown.</p><p style="margin-top:0.75rem;"><a href="/rss/daily.xml">Subscribe via RSS &rarr;</a></p></div>
      </div>
    </div>
  </section>
</BaseLayout>
