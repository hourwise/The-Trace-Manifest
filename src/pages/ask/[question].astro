---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { mockAnswers } from "../../data/mock-ask-answers";
import {
  statusLabel,
  statusBadgeClass,
  evidenceBlockClass,
  sourceRoleClass,
} from "../../types/ask";
import type { AskAnswer } from "../../types/ask";

export function getStaticPaths() {
  return Object.keys(mockAnswers).map((slug) => ({ params: { question: slug } }));
}

const { question } = Astro.params;
const answer: AskAnswer | undefined = mockAnswers[question ?? ""];
---

<BaseLayout
  title={answer ? answer.question : "Ask — The Trace Manifest"}
  description={answer ? answer.directAnswer.substring(0, 160) : "Evidence-linked answers to practical AI questions."}
  currentNav="Ask"
>
  {!answer ? (
    <main id="main-content" class="section page-detail" style="border-top:0;padding-top:1.5rem;">
      <div class="wrap-wide">
        <div class="state-panel" style="border:1px dashed var(--border);border-radius:var(--radius-lg);padding:2rem;text-align:center;background:var(--surface);">
          <h2 class="h2">Answer not found</h2>
          <p class="meta" style="margin-top:0.5rem;">This question has not been answered yet. <a href="/ask">Browse curated answers →</a></p>
        </div>
      </div>
    </main>
  ) : (
    <main id="main-content" class="section page-detail" style="border-top:0;padding-top:1.5rem;">
      <div class="wrap-wide ask-layout" style="display:grid;gap:1.5rem;">
        {answer && (
          <>
            <div class="ask-main" style="min-width:0;">
              <!-- Header -->
              <header class="ask-header" style="display:grid;gap:0.85rem;margin-bottom:0.25rem;">
                <nav class="breadcrumb" aria-label="Breadcrumb">
                  <a href="/">Latest</a> <span aria-hidden="true">/</span>
                  <a href="/ask">Ask</a> <span aria-hidden="true">/</span>
                  <span>Result</span>
                </nav>
                <p class="kicker">Evidence-linked answer</p>
                <h1 class="display h1">{answer.question}</h1>
                <div class="ask-status-row" style="display:flex;flex-wrap:wrap;align-items:center;gap:0.55rem 1rem;">
                  <span class={`badge ${statusBadgeClass(answer.status)}`}>{statusLabel(answer.status)}</span>
                  <div class="conf" title={`Confidence ${answer.confidence} percent`}>
                    <span>Confidence</span>
                    <span class="conf-bar" aria-hidden="true">
                      <span class={`conf-fill ${answer.confidence < 50 ? "low" : answer.confidence < 75 ? "warn" : ""}`} style={`width:${answer.confidence}%;`}></span>
                    </span>
                    <span class="mono">{answer.confidence}%</span>
                  </div>
                  <span class="meta">Freshness: <time datetime={answer.freshnessDate} class="mono">{answer.freshnessText}</time></span>
                  <span class="meta mono">{answer.sourceCount} sources</span>
                </div>
                <div class="ask-actions" style="display:flex;flex-wrap:wrap;gap:0.4rem;">
                  <button type="button" class="btn btn-secondary btn-sm" aria-disabled="true" title="Available in Phase 6">Save</button>
                  <button type="button" class="btn btn-ghost btn-sm" aria-disabled="true" title="Available in Phase 6">Share</button>
                  <a class="btn btn-ghost btn-sm" href="/rss/daily.xml">RSS</a>
                </div>
              </header>

              <!-- Mobile TOC -->
              <nav class="ask-toc" aria-label="On this page" style="display:none;flex-wrap:wrap;gap:0.35rem;padding:0.65rem 0;border-bottom:1px solid var(--border);margin-bottom:0.5rem;">
                <a href="#answer" style="font-size:0.75rem;font-weight:500;color:var(--muted);padding:0.35rem 0.65rem;border:1px solid var(--border);border-radius:999px;background:var(--surface);">Answer</a>
                <a href="#recommendation" style="font-size:0.75rem;font-weight:500;color:var(--muted);padding:0.35rem 0.65rem;border:1px solid var(--border);border-radius:999px;background:var(--surface);">Rec</a>
                <a href="#evidence-summary" style="font-size:0.75rem;font-weight:500;color:var(--muted);padding:0.35rem 0.65rem;border:1px solid var(--border);border-radius:999px;background:var(--surface);">Evidence</a>
                <a href="#breakdown" style="font-size:0.75rem;font-weight:500;color:var(--muted);padding:0.35rem 0.65rem;border:1px solid var(--border);border-radius:999px;background:var(--surface);">Breakdown</a>
                <a href="#sources" style="font-size:0.75rem;font-weight:500;color:var(--muted);padding:0.35rem 0.65rem;border:1px solid var(--border);border-radius:999px;background:var(--surface);">Sources</a>
                <a href="#related" style="font-size:0.75rem;font-weight:500;color:var(--muted);padding:0.35rem 0.65rem;border:1px solid var(--border);border-radius:999px;background:var(--surface);">Related</a>
              </nav>

              <div class="stack-lg">
                <!-- Direct Answer -->
                <section class="answer-hero" id="answer" aria-labelledby="answer-label" style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.25rem 1.35rem 1.35rem;display:grid;gap:0.85rem;">
                  <p class="answer-label" id="answer-label" style="font-size:0.7rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);">Direct current answer</p>
                  <p class="answer-body" style="font-size:1.05rem;line-height:1.55;max-width:62ch;text-wrap:pretty;color:color-mix(in oklch, var(--fg) 96%, var(--muted));">{answer.directAnswer}</p>
                  <div class="answer-why" style="font-size:0.9rem;color:var(--muted);max-width:60ch;line-height:1.55;padding-top:0.75rem;border-top:1px solid var(--border);">
                    <strong style="display:block;font-size:0.7rem;letter-spacing:0.07em;text-transform:uppercase;color:var(--muted);font-weight:600;margin-bottom:0.35rem;">Why (brief)</strong>
                    {answer.briefWhy}
                  </div>
                </section>

                <!-- Recommendation -->
                <section class="rec-callout" id="recommendation" aria-labelledby="rec-heading" style="background:color-mix(in oklch, var(--accent) 8%, var(--surface));border:1px solid color-mix(in oklch, var(--accent) 32%, var(--border));border-radius:var(--radius-lg);padding:1.15rem 1.25rem;display:grid;gap:0.55rem;">
                  <h2 id="rec-heading" style="font-size:0.7rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);">Practical recommendation</h2>
                  <p style="font-size:0.98rem;line-height:1.55;max-width:60ch;color:color-mix(in oklch, var(--fg) 94%, var(--muted));text-wrap:pretty;">{answer.recommendation}</p>
                </section>

                <!-- Evidence Summary -->
                <section class="evidence-summary" id="evidence-summary" aria-labelledby="ev-sum-heading" style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.1rem 1.2rem;">
                  <h2 id="ev-sum-heading" style="font-size:0.7rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);margin-bottom:0.85rem;">Evidence summary</h2>
                  <div style="display:grid;gap:0.65rem;">
                    {answer.evidenceSummary.map((chip) => (
                      <div class={`evidence-chip is-${chip.type}`} style="display:grid;gap:0.25rem;padding:0.7rem 0.8rem;border:1px solid var(--border);border-radius:var(--radius);background:var(--surface-2);min-height:72px;">
                        <span style="font-size:0.68rem;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:var(--muted);">{chip.label}</span>
                        <span style="font-size:0.88rem;line-height:1.4;color:var(--fg);">{chip.value}</span>
                        <span style="font-size:0.72rem;font-family:var(--font-mono);color:var(--muted);">{chip.meta}</span>
                      </div>
                    ))}
                  </div>
                </section>

                <!-- Separated Breakdown -->
                <section class="answer-section" id="breakdown" aria-labelledby="breakdown-heading" style="display:grid;gap:0.65rem;padding-top:0.25rem;">
                  <h2 id="breakdown-heading" style="font-family:var(--font-display);font-size:1.15rem;letter-spacing:-0.015em;font-weight:600;">Separated breakdown</h2>
                  <p class="section-note" style="font-size:0.85rem;color:var(--muted);max-width:62ch;">Each block is a different epistemic type. Colour is secondary; labels carry the meaning.</p>
                  <div class="answer-stack" style="display:grid;gap:0;border:1px solid var(--border);border-radius:var(--radius-lg);background:var(--surface);overflow:hidden;">
                    {answer.breakdown.map((block) => (
                      <article class={`answer-block ${evidenceBlockClass(block.type)}`} style="border-left:3px solid var(--border);padding:0.95rem 1.1rem 1rem 1rem;margin:0;border-bottom:1px solid var(--border);">
                        <h3 style="font-size:0.7rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);margin-bottom:0.4rem;font-weight:600;">{block.heading}</h3>
                        {block.items && block.items.length > 0 ? (
                          <ul style="margin:0.15rem 0 0 1.1rem;font-size:0.92rem;line-height:1.55;color:color-mix(in oklch, var(--fg) 92%, var(--muted));max-width:62ch;">
                            {block.items.map((item) => <li style="margin-top:0.35rem;">{item}</li>)}
                          </ul>
                        ) : (
                          <p style="font-size:0.92rem;line-height:1.55;color:color-mix(in oklch, var(--fg) 92%, var(--muted));max-width:62ch;">{block.content}</p>
                        )}
                      </article>
                    ))}
                  </div>
                </section>

                <!-- What Could Change -->
                <section class="answer-section" id="what-could-change" aria-labelledby="change-heading" style="display:grid;gap:0.65rem;padding-top:0.25rem;">
                  <h2 id="change-heading" style="font-family:var(--font-display);font-size:1.15rem;letter-spacing:-0.015em;font-weight:600;">What could change the conclusion</h2>
                  <ul class="change-list" style="margin:0;padding:0;list-style:none;display:grid;gap:0.55rem;">
                    {answer.changeConditions.map((c) => (
                      <li style="display:grid;grid-template-columns:auto 1fr;gap:0.65rem;align-items:start;padding:0.75rem 0.9rem;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);font-size:0.9rem;color:color-mix(in oklch, var(--fg) 92%, var(--muted));line-height:1.45;">
                        <span class="cl-mark" aria-hidden="true" style="width:6px;height:6px;margin-top:0.45rem;border-radius:50%;background:var(--accent);flex-shrink:0;"></span>
                        <span>{c.text}</span>
                      </li>
                    ))}
                  </ul>
                </section>

                <!-- Sources -->
                <section class="answer-section" id="sources" aria-labelledby="sources-heading" style="display:grid;gap:0.65rem;padding-top:0.25rem;">
                  <h2 id="sources-heading" style="font-family:var(--font-display);font-size:1.15rem;letter-spacing:-0.015em;font-weight:600;">Sources &amp; provenance</h2>
                  <p class="section-note" style="font-size:0.85rem;color:var(--muted);max-width:62ch;">IDs are stable desk references. Type labels show how each source may be used in the answer.</p>
                  <div class="cite-list" style="display:grid;gap:0;border:1px solid var(--border);border-radius:var(--radius-lg);background:var(--surface);overflow:hidden;">
                    {answer.sources.map((src) => (
                      <article class="cite" style="font-size:0.84rem;padding:0.85rem 1rem;border-bottom:1px solid var(--border);display:grid;gap:0.3rem;">
                        <span class="src-id" style="font-family:var(--font-mono);font-size:0.72rem;color:var(--muted);letter-spacing:0.02em;">{src.id} · checked {src.checkedDate}</span>
                        <a href={src.url} style="color:var(--fg);font-weight:550;text-decoration:underline;text-decoration-color:color-mix(in oklch, var(--accent) 55%, transparent);text-underline-offset:2px;">{src.label}</a>
                        <div class="cite-meta-row" style="display:flex;flex-wrap:wrap;gap:0.35rem 0.65rem;align-items:center;">
                          <span class={`cite-type ${sourceRoleClass(src.role)}`} style="font-size:0.68rem;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;color:var(--muted);padding:0.12em 0.45em;border:1px solid var(--border);border-radius:4px;background:var(--surface-2);">{src.roleLabel}</span>
                          <span class="meta">{src.note}</span>
                        </div>
                      </article>
                    ))}
                  </div>
                </section>

                <!-- Related Questions -->
                <section class="answer-section" id="related" aria-labelledby="related-heading" style="display:grid;gap:0.65rem;padding-top:0.25rem;">
                  <h2 id="related-heading" style="font-family:var(--font-display);font-size:1.15rem;letter-spacing:-0.015em;font-weight:600;">Related questions</h2>
                  <div class="related-list" style="display:grid;gap:0.45rem;">
                    {answer.relatedQuestions.map((rq) => (
                      <a href={`/ask/${rq.slug}`} style="display:block;padding:0.75rem 0.9rem;border:1px solid var(--border);border-radius:var(--radius);background:var(--surface);font-size:0.9rem;line-height:1.4;min-height:44px;color:var(--fg);">{rq.question}</a>
                    ))}
                  </div>
                </section>
              </div>
            </div>

            <!-- Sidebar -->
            <aside class="ask-rail" aria-label="Answer posture" style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.15rem;position:sticky;top:72px;">
              <h3 style="font-size:0.72rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);margin-bottom:1rem;">Answer posture</h3>
              <dl>
                <div style="display:flex;justify-content:space-between;gap:0.75rem;padding:0.55rem 0;border-bottom:1px solid var(--border);font-size:0.85rem;">
                  <dt style="color:var(--muted);">Status</dt>
                  <dd><span class={`badge ${statusBadgeClass(answer.status)}`}>{statusLabel(answer.status)}</span></dd>
                </div>
                <div style="display:flex;justify-content:space-between;gap:0.75rem;padding:0.55rem 0;border-bottom:1px solid var(--border);font-size:0.85rem;">
                  <dt style="color:var(--muted);">Confidence</dt>
                  <dd class="mono" style="text-align:right;font-weight:500;">{answer.confidence}%</dd>
                </div>
                <div style="display:flex;justify-content:space-between;gap:0.75rem;padding:0.55rem 0;border-bottom:1px solid var(--border);font-size:0.85rem;">
                  <dt style="color:var(--muted);">Sources</dt>
                  <dd class="mono" style="text-align:right;font-weight:500;">{answer.sourceCount}</dd>
                </div>
                <div style="display:flex;justify-content:space-between;gap:0.75rem;padding:0.55rem 0;border-bottom:1px solid var(--border);font-size:0.85rem;">
                  <dt style="color:var(--muted);">Primary</dt>
                  <dd class="mono" style="text-align:right;font-weight:500;">{answer.primarySourceCount}</dd>
                </div>
                <div style="display:flex;justify-content:space-between;gap:0.75rem;padding:0.55rem 0;border-bottom:1px solid var(--border);font-size:0.85rem;">
                  <dt style="color:var(--muted);">Last checked</dt>
                  <dd class="mono" style="text-align:right;font-weight:500;">{new Date(answer.freshnessDate).toLocaleTimeString("en-GB", { hour: "2-digit", minute: "2-digit", timeZone: "UTC" })} UTC</dd>
                </div>
              </dl>
              <div class="ev-explain" style="margin-top:1rem;padding-top:1rem;border-top:1px solid var(--border);font-size:0.85rem;color:var(--muted);line-height:1.55;">
                <strong class="ev-explain-title" style="display:block;margin-bottom:0.35rem;color:var(--fg);font-weight:600;">Why {statusLabel(answer.status).toLowerCase()}?</strong>
                {answer.postureExplanation}
              </div>
              <div class="ask-rail-actions" style="display:grid;gap:0.4rem;margin-top:1rem;">
                <a class="btn btn-secondary btn-sm" href="/models">Open model directory</a>
                <a class="btn btn-ghost btn-sm" href="/methodology">Methodology</a>
              </div>
            </aside>
          </>
        )}
      </div>
    </main>
  )}
</BaseLayout>

<style>
  .ask-layout {
    display: grid;
    gap: 1.5rem;
  }
  @media (min-width: 1024px) {
    .ask-layout {
      grid-template-columns: minmax(0, 1fr) 280px;
      gap: 2rem;
      align-items: start;
    }
  }
  @media (max-width: 1023px) {
    .ask-rail { display: none; }
    .ask-toc { display: flex !important; }
  }
  .evidence-chip.is-supporting { border-color: color-mix(in oklch, var(--ev-confirmed) 35%, var(--border)); }
  .evidence-chip.is-conflicting { border-color: color-mix(in oklch, var(--ev-disputed) 35%, var(--border)); }
  .evidence-chip.is-vendor { border-color: color-mix(in oklch, var(--ev-vendor) 35%, var(--border)); }
  .evidence-chip.is-gap { border-color: color-mix(in oklch, var(--ev-provisional) 35%, var(--border)); }
  .answer-block.facts { border-left-color: var(--ev-confirmed); }
  .answer-block.conflict { border-left-color: var(--ev-disputed); }
  .answer-block.vendor { border-left-color: var(--ev-vendor); }
  .answer-block.community { border-left-color: var(--ev-community); }
  .answer-block.uncertain { border-left-color: var(--ev-provisional); }
  .answer-block.interp { border-left-color: var(--ev-community); }
  .cite-type.is-primary { color: var(--ev-confirmed); border-color: color-mix(in oklch, var(--ev-confirmed) 30%, var(--border)); }
  .cite-type.is-vendor { color: var(--ev-vendor); border-color: color-mix(in oklch, var(--ev-vendor) 30%, var(--border)); }
  .cite-type.is-method { color: var(--ev-community); border-color: color-mix(in oklch, var(--ev-community) 30%, var(--border)); }
</style>
