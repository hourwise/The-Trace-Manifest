---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EvidenceBadge from "../../components/EvidenceBadge.astro";
import RatingExplanation from "../../components/RatingExplanation.astro";
import {
  getPublishedStoryBySlug,
  getPublishedSourcesForStory,
  getCorrectionsForStory,
  getRelatedStories,
} from "../../lib/server/d1";

export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return new Response("Not found", { status: 404 });
}

// Fetch story from D1 — returns null if slug doesn't exist or isn't published
const db = Astro.locals.runtime.env.DB;
const story = await getPublishedStoryBySlug(db, slug);
if (!story) {
  return new Response("Not found", { status: 404 });
}

// Fetch supporting data
let sources: Awaited<ReturnType<typeof getPublishedSourcesForStory>> = [];
let corrections: Awaited<ReturnType<typeof getCorrectionsForStory>> = [];
let relatedStories: Awaited<ReturnType<typeof getRelatedStories>> = [];

try {
  [sources, corrections, relatedStories] = await Promise.all([
    getPublishedSourcesForStory(db, story.id),
    getCorrectionsForStory(db, story.id),
    getRelatedStories(db, story.id, 4),
  ]);
} catch {
  // Supporting data fetch failed — story page still renders, just without enrichments
  console.error(JSON.stringify({ message: "Story enrichment query failed" }));
}

// KC-01: claim-level independence, corroboration, source tier, and
// reproducibility are not yet available from reviewed evidence records.
// Never infer them from the number of feed items in a cluster.
const hasConflicts = story.evidenceStatus === "disputed";
---

<BaseLayout
  title={`${story.headline} — The Trace Manifest`}
  description={story.summary || `Published story: ${story.headline}`}
>
  <div class="wrap" style="max-width:42rem;">
    <nav aria-label="Breadcrumb" class="meta" style="margin-bottom:1.5rem;">
      <a href="/feed">Feed</a>
      {story.topic && <> &rsaquo; <a href={`/feed?topic=${story.topic.toLowerCase().replace(/\s+/g, "-")}`}>{story.topic}</a></>}
      &rsaquo; <span>{story.headline}</span>
    </nav>

    <EvidenceBadge status={story.evidenceStatus} />

    <h1 style="margin-top:0.75rem;">{story.headline}</h1>

    <div class="meta" style="margin-top:0.75rem;display:flex;gap:1rem;flex-wrap:wrap;">
      {story.publishedAt && <span>Published: {new Date(story.publishedAt).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" })}</span>}
      {story.lastCheckedAt && <span>Last checked: {new Date(story.lastCheckedAt).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" })}</span>}
      {story.sourceClass && <span>Source: {story.sourceClass}</span>}
    </div>

    <!-- Status banners for withdrawn/superseded -->
    {story.publicationStatus === "withdrawn" && (
      <div class="card" style="margin-top:1.5rem;padding:1rem;background:color-mix(in oklch, var(--ev-corrected) 8%, transparent);border-left:4px solid var(--ev-corrected);">
        <p class="meta" style="font-weight:600;color:var(--ev-corrected);">⚠ This story has been withdrawn. The information below is retained for transparency in accordance with our corrections policy.</p>
      </div>
    )}
    {story.publicationStatus === "superseded" && (
      <div class="card" style="margin-top:1.5rem;padding:1rem;background:color-mix(in oklch, var(--ev-outdated) 8%, transparent);border-left:4px solid var(--ev-outdated);">
        <p class="meta" style="font-weight:600;color:var(--ev-outdated);">⚠ This story has been superseded by more recent information. It is retained for reference.</p>
      </div>
    )}

    <!-- Summary -->
    {story.summary && (
      <div style="margin-top:2rem;">
        <h2>Summary</h2>
        <p>{story.summary}</p>
      </div>
    )}

    <!-- TRACE Editorial Analysis -->
    {story.editorialAnalysis && (
      <div style="margin-top:2rem;">
        <h2>TRACE Analysis</h2>
        <div style="padding:1rem;background:color-mix(in oklch, var(--accent) 5%, transparent);border-radius:var(--radius);border-left:4px solid var(--accent);">
          <p style="margin:0;">{story.editorialAnalysis}</p>
        </div>
      </div>
    )}

    <!-- Why it matters -->
    {story.whyItMatters && (
      <div style="margin-top:1.5rem;">
        <h2>Why this matters</h2>
        <p>{story.whyItMatters}</p>
      </div>
    )}

    <!-- Headline image -->
    {story.headlineImageUrl && (
      <div style="margin-top:1.5rem;">
        <img
          src={story.headlineImageUrl}
          alt={story.headline}
          style="max-width:100%;border-radius:var(--radius-lg);"
          loading="lazy"
        />
      </div>
    )}

    <RatingExplanation
      status={story.evidenceStatus}
      sourceClass={story.sourceClass || "Unknown"}
      hasConflicts={hasConflicts}
      lastChecked={story.lastCheckedAt}
      publishedDate={story.publishedAt || undefined}
    />

    <!-- Sources -->
    {sources.length > 0 && (
      <div style="margin-top:2rem;">
        <h2>Sources</h2>
        <ul style="padding-left:1.25rem;">
          {sources.map(s => (
            <li style="margin-bottom:0.35rem;">
              <a href={s.url}>{s.label}</a>
              <span class="meta" style="margin-left:0.5rem;">({s.sourceName})</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Related stories -->
    {relatedStories.length > 0 && (
      <div style="margin-top:2rem;">
        <h2>Related stories</h2>
        <div style="display:flex;flex-direction:column;gap:0.5rem;">
          {relatedStories.map(r => (
            <div class="card" style="padding:0.6rem 1rem;">
              <a href={`/stories/${r.slug}`} style="font-size:0.9rem;">{r.headline}</a>
              {r.topic && <span class="meta" style="margin-left:0.75rem;">{r.topic}</span>}
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Corrections -->
    {corrections.length > 0 && (
      <div style="margin-top:2rem;">
        <h2>Corrections</h2>
        {corrections.map(c => (
          <div style="margin-top:0.75rem;padding:1rem;background:color-mix(in oklch, var(--ev-corrected) 6%, transparent);border:1px solid color-mix(in oklch, var(--ev-corrected) 18%, transparent);border-radius:var(--radius);border-left:4px solid var(--ev-corrected);">
            <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem;">
              <span class="badge badge-sm badge-corrected">{c.correctionType}</span>
              <span class="meta">{new Date(c.createdAt).toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })}</span>
            </div>
            <div style="padding:0.4rem 0.6rem;background:color-mix(in oklch, var(--ev-disputed) 8%, transparent);border-radius:4px;margin-bottom:0.4rem;">
              <p style="font-size:0.82rem;text-decoration:line-through;color:var(--ev-disputed);margin:0;">Previously: {c.previousStatement}</p>
            </div>
            <div style="padding:0.4rem 0.6rem;background:color-mix(in oklch, var(--ev-confirmed) 8%, transparent);border-radius:4px;">
              <p style="font-size:0.85rem;color:var(--ev-confirmed);margin:0;">Updated: {c.updatedStatement}</p>
            </div>
            <p class="meta" style="margin-top:0.5rem;"><strong>Reason:</strong> {c.reason}</p>
          </div>
        ))}
        <p class="meta" style="margin-top:0.75rem;">
          <a href="/corrections">View all corrections in the public ledger &rarr;</a>
        </p>
      </div>
    )}

    <!-- Review metadata -->
    <footer style="margin-top:3rem;padding-top:1.5rem;border-top:1px solid var(--border);">
      <p class="meta">
        {story.reviewedBy && <>Reviewed by: {story.reviewedBy}{story.reviewedAt && <> on {new Date(story.reviewedAt).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" })}</>}. </>}
        Evidence rating assigned by The Trace Manifest methodology.
        <a href="/methodology">How ratings work &rarr;</a>
      </p>
      <p class="meta">
        <a href="/corrections">Report an error or suggest a correction &rarr;</a>
      </p>
    </footer>
  </div>
</BaseLayout>
