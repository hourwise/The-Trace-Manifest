---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EvidenceBadge from "../../components/EvidenceBadge.astro";
import { getPublishedStoriesByTopic, getPublishedTopics } from "../../lib/server/d1";

export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return new Response("Not found", { status: 404 });
}

// Convert URL slug to topic name (e.g. "frontier-models" → "Frontier Models")
const topicName = slug
  .split("-")
  .map(w => w.charAt(0).toUpperCase() + w.slice(1))
  .join(" ");

// Fetch published stories for this topic
let stories: Awaited<ReturnType<typeof getPublishedStoriesByTopic>> = [];
let allTopics: string[] = [];
let topicDescription = "";

try {
  stories = await getPublishedStoriesByTopic(topicName, { limit: 30 });
  allTopics = await getPublishedTopics();
} catch (e: any) {
  console.error(`Topic query failed for "${slug}":`, e.message);
}

// If no stories found for this topic, check if the topic even exists in published data
if (stories.length === 0) {
  // Check if this is a known topic (case-insensitive)
  const knownTopic = allTopics.find(t => t.toLowerCase() === topicName.toLowerCase());
  if (knownTopic) {
    topicDescription = `Published stories about ${knownTopic}.`;
  }
}
---

<BaseLayout title={topicName} description={topicDescription || `Published stories about ${topicName} — The Trace Manifest`}>
  <div class="container" style="max-width:42rem;">
    <nav aria-label="Breadcrumb" class="meta" style="margin-bottom:1.5rem;">
      <a href="/feed">Feed</a> &rsaquo; {topicName}
    </nav>

    <h1>{topicName}</h1>
    {topicDescription && <p class="meta" style="margin-top:0.5rem;">{topicDescription}</p>}

    {stories.length === 0 ? (
      <div class="card" style="margin-top:2rem;padding:2rem;text-align:center;background:var(--surface-2);">
        <p style="font-size:1.1rem;margin-bottom:0.5rem;">No published stories in this topic yet</p>
        <p class="meta">
          Stories are published after editorial review. The ingestion pipeline may have material classified under this topic that hasn't yet been reviewed.
        </p>
        <p class="meta" style="margin-top:0.5rem;">
          <a href="/feed">Browse all published stories &rarr;</a>
        </p>
      </div>
    ) : (
      <div style="margin-top:2rem;display:flex;flex-direction:column;gap:1rem;">
        {stories.map(s => (
          <article class="card">
            <EvidenceBadge status={s.evidenceStatus} size="sm" />
            <h2 style="font-size:1.1rem;margin-top:0.5rem;"><a href={`/stories/${s.slug}`}>{s.headline}</a></h2>
            <p class="meta" style="margin-top:0.25rem;">
              {s.summary || "No summary available."}
            </p>
            <p class="meta" style="margin-top:0.5rem;font-size:0.8rem;">
              {s.publishedAt && <>{new Date(s.publishedAt).toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })} &middot; </>}
              {s.sourceCount} source{s.sourceCount !== 1 ? "s" : ""}
            </p>
          </article>
        ))}
      </div>
    )}

    <p class="meta" style="text-align:center;margin-top:2rem;">
      <a href="/feed">All topics &rarr;</a>
    </p>
  </div>
</BaseLayout>
