---
import BaseLayout from "../layouts/BaseLayout.astro";

// Phase 1 static curated Q&A — validates demand before Phase 5 full RAG (ADR-0007)
const curatedAnswers = [
  {
    q: "What is currently considered the best local coding model?",
    answer: "As of July 2026, the best local coding model depends on your hardware. For systems with 16 GB RAM, quantised Llama 4 (8B) and DeepSeek Coder V3 (7B) lead community benchmarks. For 32 GB+, Qwen 3 Coder (32B) at 4-bit quantisation currently holds the top spot in independent tests.",
    why: "These rankings are based on independent community benchmarks on HumanEval, SWE-bench Verified, and MultiPL-E across multiple hardware configurations, not vendor-reported scores.",
    confidence: "Strongly supported",
    sources: ["Community benchmark aggregator (July 2026)", "Independent hardware-specific tests", "SWE-bench Verified leaderboard"],
    disagreement: "Some users report that CodeLlama 4 (13B) performs better on specific languages like Rust and Go. The ranking varies by programming language.",
    recommendation: "If you have 16 GB RAM, start with Llama 4 (8B) at Q4_K_M quantisation via Ollama or LM Studio.",
    freshness: "2026-07-12",
  },
  {
    q: "Which model is best for 16 GB RAM?",
    answer: "For 16 GB RAM systems, the strongest overall performers are Llama 4 (8B) at Q4_K_M, DeepSeek Coder V3 (7B), and Phi-4 (14B) at Q3_K_M. These all run comfortably within 16 GB while leaving room for context.",
    why: "These recommendations are based on real-world testing across common quantisation formats (GGUF) and inference engines (Ollama, LM Studio, llama.cpp).",
    confidence: "Confirmed",
    sources: ["r/LocalLLaMA community benchmarks", "Independent hardware tests (July 2026)", "Ollama model library"],
    disagreement: "Phi-4 at heavy quantisation (Q3) loses some reasoning quality. Some users prefer the smaller but less quantised Llama 4 (8B) at Q5.",
    recommendation: "Start with Llama 4 (8B) Q4_K_M for general use. Add DeepSeek Coder V3 for coding-specific tasks.",
    freshness: "2026-07-11",
  },
  {
    q: "Which provider offers the best price-to-speed ratio?",
    answer: "As of July 2026, for frontier models, Anthropic (Claude 4 Haiku) leads price-to-speed. For mid-tier, Groq and Together AI offer the best latency-per-dollar. For open-weight model hosting, Fireworks AI and Together AI are most competitive.",
    why: "Comparison is based on published API pricing, independent latency measurements, and throughput benchmarks across equivalent model tiers.",
    confidence: "Strongly supported",
    sources: ["Provider pricing pages (July 2026)", "Independent API latency benchmarks", "artificialanalysis.ai comparison data"],
    disagreement: "Groq offers superior latency but limited model selection. Together AI offers more models at slightly higher latency.",
    recommendation: "Use Anthropic for frontier quality, Groq for maximum speed, and Together AI for the widest open-weight model selection.",
    freshness: "2026-07-12",
  },
  {
    q: "What is the current thinking on agent memory?",
    answer: "The current consensus (July 2026) is moving away from monolithic vector databases toward hybrid approaches: structured working memory (key-value + relational) for active context, semantic retrieval for long-term reference, and episodic summarisation for conversation history. MemGPT-style hierarchical memory and Mem0-style persistent user memory are the leading patterns.",
    why: "This represents convergence across multiple research groups (Berkeley, Stanford, Microsoft) and production systems (LangChain, LlamaIndex, CrewAI).",
    confidence: "Strongly supported",
    sources: ["MemGPT paper (Berkeley, 2024)", "Mem0 architecture documentation", "LangChain Memory module docs", "Letta (MemGPT successor) v0.5 release notes"],
    disagreement: "Debate continues on whether agent memory should be model-managed (MemGPT approach) or framework-managed (LangChain approach). The hybrid consensus is emerging but not settled.",
    recommendation: "For new projects, start with a simple key-value store for working memory and add semantic retrieval only when needed. Evaluate Mem0 or Letta for persistent user memory.",
    freshness: "2026-07-10",
  },
  {
    q: "Has GPT-5 been independently verified?",
    answer: "GPT-5 was released on 10 July 2026. As of 12 July 2026, independent benchmark verification is still in progress. Vendor-reported scores on coding and reasoning benchmarks are available but should be treated as provisional until independent results are published.",
    why: "Early community testing is underway. Full independent verification typically takes 1–3 weeks after a major release.",
    confidence: "Vendor-reported",
    sources: ["OpenAI GPT-5 technical report (10 July 2026)", "Early community reports on r/MachineLearning", "SWE-bench submission pending"],
    disagreement: "Early community reports are mixed on real-world coding performance versus vendor-reported benchmark scores.",
    recommendation: "Wait for independent SWE-bench and HumanEval+ results before making procurement decisions. Expect initial independent results by 17–24 July.",
    freshness: "2026-07-12",
  },
  {
    q: "What changed in MCP gateways this month?",
    answer: "July 2026 saw three significant MCP gateway developments: (1) Anthropic released MCP Gateway v2 with streaming tool results and improved authentication, (2) the open-source mcpx gateway added dynamic tool discovery, and (3) Cloudflare announced an MCP gateway product integrated with Workers.",
    why: "MCP gateway competition is accelerating as tool-use becomes standard in agent workflows. Streaming results and dynamic discovery are the key differentiators.",
    confidence: "Confirmed",
    sources: ["Anthropic MCP Gateway v2 changelog", "mcpx v0.9 release notes", "Cloudflare blog (July 2026)"],
    disagreement: "Whether to use provider-specific gateways (Anthropic) or provider-agnostic (mcpx/Cloudflare) depends on your model mix.",
    recommendation: "If you use primarily Anthropic models, MCP Gateway v2 is the path of least resistance. For multi-provider setups, evaluate mcpx or Cloudflare.",
    freshness: "2026-07-11",
  },
  {
    q: "Which coding agent is most reliable?",
    answer: "As of July 2026, the most reliably measured coding agents on SWE-bench Verified are: Devin (Cognition) at 38.7%, Claude Code (Anthropic) at 35.2%, and the open-source SWE-Agent at 29.1%. However, 'reliability' also depends on cost, latency, and task type.",
    why: "SWE-bench Verified is currently the best available measure of real-world coding task completion, though it has limitations.",
    confidence: "Strongly supported",
    sources: ["SWE-bench Verified leaderboard (July 2026)", "Independent agent comparison reports", "Community experience reports"],
    disagreement: "SWE-bench scores don't capture iteration speed, cost, or developer experience. Some developers report better day-to-day reliability from Cursor + Claude despite lower benchmark scores.",
    recommendation: "For autonomous bug-fixing, Devin leads. For interactive coding, Claude Code or Cursor + Claude. For budget-conscious teams, SWE-Agent with Llama 4 is viable.",
    freshness: "2026-07-09",
  },
  {
    q: "Is tool X genuinely open source?",
    answer: "This depends on the specific tool. Always check: (1) the exact licence text, not just the label, (2) whether all dependencies are also openly licensed, (3) whether the model weights or only the inference code is open, (4) whether there are commercial-use restrictions. Many 'open-source' AI tools use custom restricted licences that are not OSI-approved.",
    why: "The term 'open source' is frequently misused in AI. OSI has published an Open Source AI definition, but adoption is inconsistent.",
    confidence: "Confirmed",
    sources: ["OSI Open Source AI Definition v1.0", "Model licence registry projects", "Software Freedom Conservancy AI analysis"],
    disagreement: "The definition of 'open source AI' itself is contested between OSI, FSF, and industry groups.",
    recommendation: "Use our licence classification: check the specific licence, commercial-use terms, and data/model/code openness separately. Don't rely on marketing labels.",
    freshness: "2026-07-08",
  },
  {
    q: "What are the current best practices for AI security?",
    answer: "Current AI security best practices (July 2026) centre on: (1) prompt injection prevention via input sanitisation and structured prompting, (2) output validation and sandboxing for tool-using agents, (3) model access control and rate limiting, (4) data isolation between tenants, (5) adversarial input detection, and (6) regular red-teaming including indirect prompt injection scenarios.",
    why: "OWASP Top 10 for LLM Applications v2.0 and NIST AI 600-1 provide the current authoritative frameworks.",
    confidence: "Confirmed",
    sources: ["OWASP Top 10 for LLM Applications v2.0", "NIST AI 600-1", "ANSSI AI security recommendations", "NCSC AI security guidance"],
    disagreement: "Debate continues on whether RAG-based systems need fundamentally different security models from traditional web applications.",
    recommendation: "Start with the OWASP LLM Top 10. Implement structured prompting (XML/JSON schemas) to reduce injection surface. Sandbox all tool executions.",
    freshness: "2026-07-07",
  },
  {
    q: "What is the strongest open-weight model for commercial use?",
    answer: "As of July 2026, Llama 4 (405B) is the strongest open-weight model for commercial use, followed by Qwen 3 (72B) and DeepSeek V3 (671B MoE). All three have commercially permissive licences. For smaller deployments, Llama 4 (70B) offers the best performance-per-parameter ratio.",
    why: "Independent benchmarks across MMLU, HumanEval, GSM8K, and HellaSwag confirm these rankings. Licence terms have been verified.",
    confidence: "Confirmed",
    sources: ["Open LLM Leaderboard (July 2026)", "Independent model comparisons", "Official licence documents"],
    disagreement: "DeepSeek V3's mixture-of-experts architecture means 671B total parameters but only ~37B active per token, making comparisons with dense models complex.",
    recommendation: "For maximum capability, Llama 4 (405B). For cost efficiency, DeepSeek V3. For balance, Qwen 3 (72B). All three are commercially usable.",
    freshness: "2026-07-12",
  },
  {
    q: "How do I run local models on a budget?",
    answer: "The most cost-effective local AI setup (July 2026) is a used RTX 3090 (24 GB VRAM, ~£550 used) running Ollama or LM Studio. This comfortably runs Llama 4 (8B) at Q8, Llama 4 (70B) at Q3, or DeepSeek Coder V3 at Q6. For CPU-only, a Mac Mini M4 (24 GB unified memory, £599) runs 7B–14B models at acceptable speeds.",
    why: "Price-to-performance analysis based on current used hardware prices and inference benchmarks.",
    confidence: "Strongly supported",
    sources: ["r/LocalLLaMA hardware threads (July 2026)", "Independent inference benchmarks", "Current used hardware prices (eBay, CeX)"],
    disagreement: "Apple Silicon offers better power efficiency but less software flexibility. NVIDIA offers CUDA compatibility and wider model support.",
    recommendation: "RTX 3090 used for maximum capability on a budget. Mac Mini M4 for quiet, efficient, CPU-based inference. Avoid new RTX 4090s unless you need the absolute fastest token generation.",
    freshness: "2026-07-10",
  },
  {
    q: "What are the best models for structured output?",
    answer: "For structured JSON/output generation (July 2026): GPT-5 with structured outputs mode leads, followed by Claude 4 with tool-use JSON mode, and Llama 4 (70B) with outlines/guidance libraries. For local structured output, Llama 4 (8B) with llama.cpp grammars performs well.",
    why: "Structured output reliability is measured by schema adherence rate, not just output quality. GPT-5 currently achieves >99% schema adherence.",
    confidence: "Strongly supported",
    sources: ["Provider structured-output documentation", "Independent schema-adherence tests", "Community comparison threads"],
    disagreement: "For simple schemas, open-weight models with grammars achieve comparable adherence. The gap widens for complex, nested schemas.",
    recommendation: "GPT-5 for complex structured output in production. Llama 4 + grammars for local/private structured output. Claude 4 for balanced quality and schema support.",
    freshness: "2026-07-11",
  },
  {
    q: "Which AI API is best for a startup?",
    answer: "For startups (July 2026), the best API depends on your primary need: Anthropic (Claude 4 Haiku) for cost-effective coding and reasoning, OpenAI (GPT-5) for maximum capability and ecosystem maturity, and Groq for latency-sensitive applications. Together AI offers the best value for open-weight model hosting.",
    why: "Comparison factors: pricing, latency, reliability, model selection, SDK maturity, and startup programme benefits.",
    confidence: "Strongly supported",
    sources: ["Provider pricing pages", "API latency benchmarks", "Startup programme comparisons (Anthropic, OpenAI, Google)"],
    disagreement: "Startups in the EU may prefer Anthropic or Mistral for data-residency reasons. Google Cloud offers the best startup credits programme ($200K+).",
    recommendation: "Start with Anthropic Claude 4 Haiku for cost efficiency. Add GPT-5 for tasks requiring maximum capability. Apply for startup credits from all major providers.",
    freshness: "2026-07-09",
  },
  {
    q: "What is the best model for long-context tasks?",
    answer: "As of July 2026, Gemini 3 Pro (2M token context) leads raw context capacity. Claude 4 (200K) leads in-context retrieval accuracy (needle-in-haystack >99%). GPT-5 (256K) offers the best balance of context length and reasoning quality at long ranges.",
    why: "Long-context performance degrades differently across models. Raw context size ≠ effective context utilisation.",
    confidence: "Strongly supported",
    sources: ["RULER benchmark (July 2026)", "Needle-in-haystack tests", "Provider documentation"],
    disagreement: "For most practical use cases, 128K–200K tokens are sufficient. The 2M token ceiling of Gemini is rarely needed outside document-processing pipelines.",
    recommendation: "Claude 4 for tasks requiring precise retrieval from long documents. GPT-5 for long-form reasoning. Gemini 3 Pro for extreme context needs (full codebase analysis).",
    freshness: "2026-07-08",
  },
  {
    q: "Should I use a model router?",
    answer: "Model routers (July 2026) are increasingly viable. OpenRouter, Martian, and Portkey offer routing across 200+ models. The value proposition is real: cost savings of 30–60% by routing simple queries to smaller models while reserving frontier models for complex tasks.",
    why: "Router quality has improved significantly. Modern routers use lightweight classifiers to predict task difficulty before selecting a model.",
    confidence: "Confirmed",
    sources: ["OpenRouter docs and pricing", "Martian Model Router benchmarks", "Independent router comparison (July 2026)"],
    disagreement: "Some developers prefer explicit model selection for predictability. Routers add a layer of opacity to model choice.",
    recommendation: "Use a router for cost-sensitive applications with varied query difficulty. For latency-critical or compliance-sensitive applications, select models explicitly.",
    freshness: "2026-07-07",
  },
  {
    q: "What are the best practices for prompt engineering in 2026?",
    answer: "Prompt engineering best practices have evolved (July 2026): (1) use structured prompts (XML or JSON schema) rather than prose for complex tasks, (2) provide 3–5 diverse examples rather than 1, (3) specify output format explicitly, (4) use chain-of-thought only for reasoning tasks where it demonstrably improves accuracy, (5) separate system instructions from user input clearly, and (6) test prompts against adversarial inputs.",
    why: "These practices are informed by the latest research on prompting effectiveness, including the 'structured prompting beats clever prompting' consensus.",
    confidence: "Confirmed",
    sources: ["Anthropic prompt engineering guide (2026)", "OpenAI prompt engineering guide", "Research: 'Structured Prompts Outperform Creative Prompts' (June 2026)"],
    disagreement: "Chain-of-thought prompting can increase latency and cost without improving accuracy for simple tasks. Use it selectively.",
    recommendation: "Start with structured XML prompts. Add examples for ambiguous tasks. Use chain-of-thought only when accuracy matters more than speed.",
    freshness: "2026-07-06",
  },
  {
    q: "How do I evaluate whether an AI benchmark result is trustworthy?",
    answer: "To evaluate benchmark trustworthiness, check: (1) Who ran it — vendor or independent? (2) Is the code and data public? (3) What prompting method was used? (4) Was the benchmark contaminated in training data? (5) Is the benchmark saturated? (6) Were multiple runs averaged? (7) Were the settings comparable across models? Use our benchmark health labels as a starting point.",
    why: "Benchmark results are frequently incomparable due to different prompting methods, hardware, sampling settings, or contamination.",
    confidence: "Confirmed",
    sources: ["The Trace Manifest benchmark methodology", "Research on benchmark contamination", "Independent evaluation standards"],
    disagreement: "Some argue that 'contamination' is inevitable and not always harmful. Others argue it fundamentally invalidates benchmark results.",
    recommendation: "Trust independent, reproducible benchmarks over vendor-reported results. Check our benchmark registry for health status before citing scores.",
    freshness: "2026-07-05",
  },
  {
    q: "What's the difference between open-weight, open-source, and source-available models?",
    answer: "Open-weight: model weights are publicly downloadable but training data and code may be private (e.g., Llama 4). Open-source (OSI definition): weights, training code, data, and methodology are all publicly available under an OSI-approved licence (very rare for frontier models). Source-available: code is public but under restrictive terms (e.g., no commercial use). Most 'open-source' AI models are actually open-weight.",
    why: "These distinctions matter for commercial use, reproducibility, and licence compliance.",
    confidence: "Confirmed",
    sources: ["OSI Open Source AI Definition v1.0", "Model licence analysis", "Software Freedom Conservancy guidance"],
    disagreement: "Meta and others contest the OSI definition, arguing that open-weight alone should qualify as 'open source'. The OSI and FSF disagree.",
    recommendation: "Always check the specific licence terms. 'Open-weight' is the safest accurate term for most downloadable models. Reserve 'open-source' for OSI-compliant releases.",
    freshness: "2026-07-04",
  },
  {
    q: "What local inference tools should I use?",
    answer: "The current best local inference tools (July 2026): Ollama for ease of use and model management, LM Studio for GUI-based discovery and testing, llama.cpp for maximum performance and flexibility, vLLM for production serving, and text-generation-webui for experimentation. For Apple Silicon, MLX (Apple's framework) offers the best performance.",
    why: "Tool choice depends on your use case: experimentation vs production, GUI vs CLI, single-user vs multi-user serving.",
    confidence: "Confirmed",
    sources: ["Official tool documentation", "Community performance benchmarks", "r/LocalLLaMA tool comparison threads"],
    disagreement: "Ollama is easiest but abstracts away configuration. llama.cpp offers more control but requires more expertise.",
    recommendation: "Start with Ollama for personal use. Move to LM Studio if you prefer a GUI. Use vLLM for production serving. Use MLX on Apple Silicon.",
    freshness: "2026-07-03",
  },
  {
    q: "Is AI regulation affecting what models I can use?",
    answer: "Yes. The EU AI Act (enforced from August 2026) classifies AI systems by risk tier. Most developer tools and general-purpose models fall under limited or minimal risk with transparency obligations. High-risk applications (healthcare, hiring, law enforcement) have stricter requirements. The US has executive orders but no comprehensive federal law yet. The UK has a sectoral approach. Check your jurisdiction.",
    why: "Regulatory requirements vary by region, use case, and model classification.",
    confidence: "Confirmed",
    sources: ["EU AI Act final text", "UK AI regulation white paper", "US Executive Order on AI", "Provider compliance documentation"],
    disagreement: "The EU AI Act's classification of general-purpose AI is still being interpreted. Guidance is evolving.",
    recommendation: "For EU deployments, review your AI Act tier classification. Most SaaS and developer-tool use cases are limited risk. Consult legal counsel for high-risk applications.",
    freshness: "2026-07-02",
  },
];

const confidenceClass = (c: string) => {
  const map: Record<string,string> = {
    "Confirmed": "evidence-label--confirmed",
    "Strongly supported": "evidence-label--confirmed",
    "Vendor-reported": "evidence-label--vendor",
    "Disputed": "evidence-label--disputed",
  };
  return map[c] ?? "evidence-label--unverified";
};
---

<BaseLayout
  title="Ask — Citation-grounded answers"
  description="Ask practical questions about AI models, providers, benchmarks, tools, and best practices. Answers are grounded in dated, cited sources."
>
  <div class="wrap" style="max-width:42rem;">
    <h1>Ask</h1>
    <p class="meta" style="margin-bottom:2rem;">
      Curated answers to practical AI questions. Each answer includes supporting evidence, points of disagreement, confidence ratings, and freshness dates.
    </p>

    <p style="padding:0.75rem;background:var(--surface-2);border-radius:var(--radius);font-size:0.9rem;margin-bottom:2rem;">
      <strong>Phase 1 prototype:</strong> These {curatedAnswers.length} questions and answers are manually curated to validate demand and establish answer formatting. A full retrieval-augmented ask box arrives in Phase 5.
      <a href="/docs/adr/0007-early-ask-validation.md">Read ADR-0007 &rarr;</a>
    </p>

    <!-- Search / question input placeholder -->
    <div style="margin-bottom:2rem;">
      <label for="ask-input" class="sr-only">Ask a question</label>
      <input
        id="ask-input"
        type="search"
        placeholder="Ask a question about AI models, benchmarks, tools, or best practices..."
        style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius);font-size:1rem;font-family:var(--font-sans);"
        disabled
      />
      <p class="meta" style="margin-top:0.25rem;">Full ask box with dynamic retrieval coming in Phase 5. Browse curated answers below.</p>
    </div>

    <!-- Curated Q&A list -->
    <div style="display:flex;flex-direction:column;gap:2rem;">
      {curatedAnswers.map(a => (
        <article class="card" id={a.q.toLowerCase().replace(/[^a-z0-9]+/g,'-').substring(0,50)}>
          <h2 style="font-size:1.1rem;">{a.q}</h2>
          <div style="display:flex;gap:0.5rem;align-items:center;margin-top:0.75rem;flex-wrap:wrap;">
            <span class={`evidence-label ${confidenceClass(a.confidence)}`}>{a.confidence}</span>
            <span class="meta" style="font-size:0.8rem;">Freshness: {a.freshness}</span>
          </div>

          <div style="margin-top:1rem;">
            <h3 style="font-size:0.9rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);">Current answer</h3>
            <p style="margin-top:0.25rem;">{a.answer}</p>
          </div>

          <div style="margin-top:1rem;">
            <h3 style="font-size:0.9rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);">Why</h3>
            <p class="meta" style="margin-top:0.25rem;">{a.why}</p>
          </div>

          <div style="margin-top:1rem;">
            <h3 style="font-size:0.9rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);">Supporting evidence</h3>
            <ul style="padding-left:1.25rem;margin-top:0.25rem;" class="meta">
              {a.sources.map(s => <li>{s}</li>)}
            </ul>
          </div>

          <div style="margin-top:1rem;">
            <h3 style="font-size:0.9rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);">Points of disagreement</h3>
            <p class="meta" style="margin-top:0.25rem;">{a.disagreement}</p>
          </div>

          <div style="margin-top:1rem;padding:0.75rem;background:var(--surface-2);border-radius:var(--radius);">
            <h3 style="font-size:0.9rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);">Practical recommendation</h3>
            <p style="margin-top:0.25rem;font-weight:500;">{a.recommendation}</p>
          </div>

          <p class="meta" style="margin-top:1rem;font-size:0.75rem;">
            Confidence: {a.confidence} &middot; Freshness: {a.freshness} &middot;
            <a href="/methodology">How ratings work &rarr;</a>
          </p>
        </article>
      ))}
    </div>

    <p class="meta" style="text-align:center;margin-top:3rem;">
      Have a question not covered here? The full ask box with dynamic retrieval and citation assembly arrives in Phase 5.
    </p>
  </div>
</BaseLayout>
