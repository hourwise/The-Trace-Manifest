---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ModelCard from "../../components/ModelCard.astro";
import { getPublishedModels, getTraceModelScores } from "../../lib/server/catalog-data";

export const prerender = false;
let models: Awaited<ReturnType<typeof getPublishedModels>> = [];
let traceScores: Awaited<ReturnType<typeof getTraceModelScores>> = [];
let unavailable = false;
try {
  const db = Astro.locals.runtime.env.DB;
  [models, traceScores] = await Promise.all([
    getPublishedModels(db),
    getTraceModelScores(db),
  ]);
} catch { unavailable = true; }
const scoreBySlug = new Map(traceScores.filter(s => s.aggregateScore !== null).map(s => [s.modelSlug, s.aggregateScore!]));
const closedModels = models.filter((item) => item.openness === "closed" || item.openness === "api_only");
const openModels = models.filter((item) => item.openness === "open_weight" || item.openness === "open_source");
---

<BaseLayout title="Model Directory" description="Reviewed model records published by The Trace Manifest.">
  <div class="wrap" style="max-width:60rem;">
    <h1 class="display h1">Model Directory</h1>
    <p class="lead">Only reviewed and explicitly published model records appear here. <a href="/methodology">Methodology &rarr;</a></p>
    {unavailable ? (
      <div class="card" style="margin-top:2rem;"><p class="meta">Model data is temporarily unavailable.</p></div>
    ) : models.length === 0 ? (
      <div class="card" style="margin-top:2rem;"><p class="meta">No model records have completed editorial review and publication yet.</p></div>
    ) : (
      <>
        {closedModels.length > 0 && <section style="margin-top:2rem;"><h2>Closed and API-only models</h2><div class="grid-2">{closedModels.map((item) => <ModelCard model={item} traceScore={scoreBySlug.get(item.slug) ?? null} />)}</div></section>}
        {openModels.length > 0 && <section style="margin-top:2rem;"><h2>Open-weight and open-source models</h2><div class="grid-2">{openModels.map((item) => <ModelCard model={item} traceScore={scoreBySlug.get(item.slug) ?? null} />)}</div></section>}
      </>
    )}
  </div>
</BaseLayout>
