---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedModelBySlug } from "../../lib/server/catalog-data";

export const prerender = false;
const slug = Astro.params.slug ?? "";
let model: Awaited<ReturnType<typeof getPublishedModelBySlug>> = null;
let unavailable = false;
try { model = await getPublishedModelBySlug(Astro.locals.runtime.env.DB, slug); } catch { unavailable = true; }
Astro.response.status = unavailable ? 503 : model ? 200 : 404;
const openness: Record<string, string> = { closed: "Closed", api_only: "API only", open_weight: "Open-weight", open_source: "Open-source" };
---

<BaseLayout title={model ? `${model.name} — Model Detail` : "Model not available"} description={model?.description ?? "Reviewed model record."}>
  <div class="wrap" style="max-width:46rem;">
    <nav class="meta" aria-label="Breadcrumb"><a href="/models">Models</a> &rsaquo; {model?.name ?? "Not available"}</nav>
    {unavailable ? <div class="card" style="margin-top:2rem;"><h1>Model data unavailable</h1><p class="meta">The catalogue could not be read.</p></div> : !model ?
      <div class="card" style="margin-top:2rem;"><h1>Model not found</h1><p class="meta">This model is not published or does not exist.</p></div> :
      <article style="margin-top:1.5rem;">
        <h1>{model.name}</h1>
        <p class="meta">{model.provider} · {openness[model.openness] ?? model.openness}{model.version ? ` · ${model.version}` : ""}</p>
        {model.description && <p class="lead">{model.description}</p>}
        <dl class="card" style="margin-top:1.5rem;display:grid;gap:0.6rem;">
          <div><dt class="meta">Status</dt><dd>{model.status}</dd></div>
          {model.releaseDate && <div><dt class="meta">Release date</dt><dd>{model.releaseDate}</dd></div>}
          {model.licence && <div><dt class="meta">Licence</dt><dd>{model.licence}</dd></div>}
          {model.parameterCount && <div><dt class="meta">Parameters</dt><dd>{model.parameterCount}</dd></div>}
          {model.contextWindow && <div><dt class="meta">Context window</dt><dd>{model.contextWindow}</dd></div>}
          <div><dt class="meta">Modalities</dt><dd>{model.modalities}</dd></div>
          <div><dt class="meta">Capabilities recorded</dt><dd>{[model.toolUse && "tool use", model.structuredOutput && "structured output", model.apiAvailable && "API", model.localAvailable && "local use"].filter(Boolean).join(", ") || "None recorded"}</dd></div>
          {model.lastVerifiedAt && <div><dt class="meta">Last verified</dt><dd>{model.lastVerifiedAt}</dd></div>}
        </dl>
        {model.bestUseCases.length > 0 && <section><h2>Reviewed use cases</h2><ul>{model.bestUseCases.map((item) => <li>{item}</li>)}</ul></section>}
        {model.weaknesses.length > 0 && <section><h2>Recorded limitations</h2><ul>{model.weaknesses.map((item) => <li>{item}</li>)}</ul></section>}
        <p class="meta" style="margin-top:2rem;">Pricing is omitted until provider-model pricing rows have their own completed review and publication state.</p>
      </article>}
  </div>
</BaseLayout>
