---
import BaseLayout from "../layouts/BaseLayout.astro";
import EvidenceBadge from "../components/EvidenceBadge.astro";
import SocialSignalCard from "../components/SocialSignalCard.astro";
import { getPublishedStories, getPublishedTopics } from "../lib/server/d1";

export const prerender = false;

// Read topic filter from query string — topics are stored as lowercase slugs
const topicParam = Astro.url.searchParams.get("topic");
const topic = topicParam || undefined;

// Fetch published stories from D1 — publication gate enforced server-side
let stories: Awaited<ReturnType<typeof getPublishedStories>>;
let allTopicSlugs: string[] = [];
let error: string | null = null;

try {
  const db = Astro.locals.runtime.env.DB;
  stories = await getPublishedStories(db, { topic, limit: 30 });
  allTopicSlugs = await getPublishedTopics(db);
} catch {
  stories = [];
  error = "Feed data is temporarily unavailable. Stories appear here only after editorial review and publication.";
  console.error(JSON.stringify({ message: "Feed query failed" }));
}

// Human-readable labels for topic slugs
function topicLabel(slug: string): string {
  return slug.split("-").map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(" ");
}

// Build filter items: { slug, label, href }
const topicFilters = [
  { slug: null, label: "All", href: "/feed" },
  ...allTopicSlugs.map(s => ({ slug: s, label: topicLabel(s), href: `/feed?topic=${s}` })),
];

// ADR 0009: fetch approved social signals for public display
let socialSignals: Array<{
  id: number; platform: string; canonical_url: string;
  trace_summary: string | null; author_display_name: string | null;
  author_handle: string | null; corroboration_status: string;
  evidence_status: string; linked_source_ids: string;
}> = [];
try {
  const db = Astro.locals.runtime.env.DB;
  const result = await db.prepare(`
    SELECT id, platform, canonical_url, COALESCE(trace_summary, submission_reason) as trace_summary,
           author_display_name, author_handle, corroboration_status, evidence_status, linked_source_ids
    FROM social_signals
    WHERE review_status = 'approved'
    ORDER BY reviewed_at DESC LIMIT 10
  `).all();
  socialSignals = (result.results ?? []) as typeof socialSignals;
} catch { /* social signals are optional */ }

---

<BaseLayout
  title={topic ? `${topicLabel(topic)} — Intelligence Feed` : "Intelligence Feed"}
  description="Chronological and relevance-ranked feed of AI model launches, research, benchmarks, security incidents, and provider updates with evidence ratings."
>
  <div class="wrap">
    <h1>Intelligence Feed</h1>
    <p class="meta" style="margin-bottom:2rem;">
      {topic
        ? `Stories tagged "${topicLabel(topic)}". `
        : "Chronological feed of AI developments with source classification and evidence ratings. "}
      <a href="/methodology">How ratings work &rarr;</a>
    </p>

    <!-- Filter bar -->
    <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:2rem;" role="group" aria-label="Filter by topic">
      {topicFilters.map(f => {
        const isActive = (f.slug === null && !topic) || f.slug === topic;
        return (
          <a href={f.href}
             style={`font-size:0.85rem;padding:0.25rem 0.75rem;border:1px solid var(--border);border-radius:var(--radius);text-decoration:none;${isActive ? "background:var(--accent);color:var(--bg);border-color:var(--accent);" : ""}`}
             class="meta">
            {f.label}
          </a>
        );
      })}
    </div>

    <!-- Error state -->
    {error && (
      <div class="card" style="padding:2rem;text-align:center;background:var(--surface-2);">
        <p class="meta">{error}</p>
      </div>
    )}

    <!-- Empty state -->
    {!error && stories.length === 0 && socialSignals.length === 0 && (
      <div class="card" style="padding:2rem;text-align:center;background:var(--surface-2);">
        <p style="font-size:1.1rem;margin-bottom:0.5rem;">No published stories yet</p>
        <p class="meta">
          {topic
            ? `No published stories match the topic "${topicLabel(topic)}". Stories are published after editorial review.`
            : "The ingestion pipeline is collecting and classifying source material. Stories appear here after editorial review and publication."}
        </p>
        <p class="meta" style="margin-top:0.5rem;">
          <a href="/methodology">How the publication process works &rarr;</a>
        </p>
      </div>
    )}

    <!-- Feed items — chronological, reviewed stories -->
    {stories.length > 0 && (
      <div style="display:flex;flex-direction:column;gap:1rem;">
        {stories.map(story => (
          <article class="card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:0.5rem;">
              <span class="meta">{story.topic ? topicLabel(story.topic) : "Uncategorised"}</span>
              <EvidenceBadge status={story.evidenceStatus} size="sm" />
            </div>
            <h2 style="font-size:1.15rem;margin-top:0.5rem;">
              <a href={`/stories/${story.slug}`}>{story.headline}</a>
            </h2>
            <p class="meta" style="margin-top:0.25rem;">
              {story.summary || "No summary available. This story is awaiting editorial review."}
            </p>
            <p class="meta" style="margin-top:0.5rem;font-size:0.8rem;">
              {story.primarySourceName && <>Source: {story.primarySourceName} &middot; </>}
              {story.sourceCount} source{story.sourceCount !== 1 ? "s" : ""}
              {story.publishedAt && <> &middot; {new Date(story.publishedAt).toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })}</>}
            </p>
          </article>
        ))}
      </div>
    )}

    {stories.length > 0 && (
      <p class="meta" style="text-align:center;margin-top:2rem;">
        Showing {stories.length} published {topic ? `"${topicLabel(topic)}" ` : ""}stories. Stories are reviewed before publication. <a href="/methodology">See methodology &rarr;</a>
      </p>
    )}

    <!-- ADR 0009: Community Signals — unverified social posts, below the chronological feed -->
    {socialSignals.length > 0 && (
      <section style="margin-top:3rem;padding-top:2rem;border-top:2px solid var(--color-border);">
        <h2 style="font-size:1.1rem;margin-bottom:0.5rem;">Community Signals</h2>
        <p class="meta" style="margin-bottom:1rem;font-size:0.85rem;">
          Unverified posts from social media. These are discovery leads, not evidence. They have not been reviewed and may be inaccurate.
        </p>
        {socialSignals.map((sig) => (
          <SocialSignalCard
            platform={sig.platform}
            traceSummary={sig.trace_summary ?? ""}
            authorDisplayName={sig.author_display_name}
            authorHandle={sig.author_handle}
            canonicalUrl={sig.canonical_url}
            corroborationStatus={sig.corroboration_status}
            evidenceStatus={sig.evidence_status}
            linkedSourceCount={JSON.parse(sig.linked_source_ids || "[]").length}
          />
        ))}
      </section>
    )}
  </div>
</BaseLayout>
