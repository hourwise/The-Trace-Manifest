---
import BaseLayout from "../layouts/BaseLayout.astro";
import EvidenceBadge from "../components/EvidenceBadge.astro";
import { getPublishedStories, getPublishedTopics } from "../lib/server/d1";

export const prerender = false;

// Read topic filter from query string
const topicParam = Astro.url.searchParams.get("topic");
const topic = topicParam
  ? topicParam.split("-").map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(" ")
  : undefined;

// Fetch published stories from D1 — publication gate enforced server-side
let stories: Awaited<ReturnType<typeof getPublishedStories>>;
let allTopics: string[] = [];
let error: string | null = null;

try {
  const db = Astro.locals.runtime.env.DB;
  stories = await getPublishedStories(db, { topic, limit: 30 });
  allTopics = await getPublishedTopics(db);
} catch {
  stories = [];
  error = "Feed data is temporarily unavailable. Stories appear here only after editorial review and publication.";
  console.error(JSON.stringify({ message: "Feed query failed" }));
}

// Map topic slugs for filter links
const topicFilterLabels = ["All", ...allTopics];
---

<BaseLayout
  title={topic ? `${topic} — Intelligence Feed` : "Intelligence Feed"}
  description="Chronological and relevance-ranked feed of AI model launches, research, benchmarks, security incidents, and provider updates with evidence ratings."
>
  <div class="wrap">
    <h1>Intelligence Feed</h1>
    <p class="meta" style="margin-bottom:2rem;">
      {topic
        ? `Stories tagged "${topic}". `
        : "Chronological feed of AI developments with source classification and evidence ratings. "}
      <a href="/methodology">How ratings work &rarr;</a>
    </p>

    <!-- Filter bar -->
    <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:2rem;" role="group" aria-label="Filter by topic">
      {topicFilterLabels.map(t => {
        const isActive = (t === "All" && !topic) || t === topic;
        const href = t === "All" ? "/feed" : `/feed?topic=${t.toLowerCase().replace(/\s+/g, "-")}`;
        return (
          <a href={href}
             style={`font-size:0.85rem;padding:0.25rem 0.75rem;border:1px solid var(--border);border-radius:var(--radius);text-decoration:none;${isActive ? "background:var(--accent);color:var(--bg);border-color:var(--accent);" : ""}`}
             class="meta">
            {t}
          </a>
        );
      })}
    </div>

    <!-- Error state -->
    {error && (
      <div class="card" style="padding:2rem;text-align:center;background:var(--surface-2);">
        <p class="meta">{error}</p>
      </div>
    )}

    <!-- Empty state -->
    {!error && stories.length === 0 && (
      <div class="card" style="padding:2rem;text-align:center;background:var(--surface-2);">
        <p style="font-size:1.1rem;margin-bottom:0.5rem;">No published stories yet</p>
        <p class="meta">
          {topic
            ? `No published stories match the topic "${topic}". Stories are published after editorial review.`
            : "The ingestion pipeline is collecting and classifying source material. Stories appear here after editorial review and publication."}
        </p>
        <p class="meta" style="margin-top:0.5rem;">
          <a href="/methodology">How the publication process works &rarr;</a>
        </p>
      </div>
    )}

    <!-- Feed items -->
    {stories.length > 0 && (
      <div style="display:flex;flex-direction:column;gap:1rem;">
        {stories.map(story => (
          <article class="card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:0.5rem;">
              <span class="meta">{story.topic || "Uncategorised"}</span>
              <EvidenceBadge status={story.evidenceStatus} size="sm" />
            </div>
            <h2 style="font-size:1.15rem;margin-top:0.5rem;">
              <a href={`/stories/${story.slug}`}>{story.headline}</a>
            </h2>
            <p class="meta" style="margin-top:0.25rem;">
              {story.summary || "No summary available. This story is awaiting editorial review."}
            </p>
            <p class="meta" style="margin-top:0.5rem;font-size:0.8rem;">
              {story.primarySourceName && <>Source: {story.primarySourceName} &middot; </>}
              {story.sourceCount} source{story.sourceCount !== 1 ? "s" : ""}
              {story.publishedAt && <> &middot; {new Date(story.publishedAt).toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })}</>}
            </p>
          </article>
        ))}
      </div>
    )}

    {stories.length > 0 && (
      <p class="meta" style="text-align:center;margin-top:2rem;">
        Showing {stories.length} published {topic ? `"${topic}" ` : ""}stories. Stories are reviewed before publication. <a href="/methodology">See methodology &rarr;</a>
      </p>
    )}
  </div>
</BaseLayout>
