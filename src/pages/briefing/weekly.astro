---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EvidenceBadge from "../../components/EvidenceBadge.astro";
import { getLatestPublishedBriefing, getPublishedStories, parsePublishedBriefingItems } from "../../lib/server/d1";

export const prerender = false;

let briefing: Awaited<ReturnType<typeof getLatestPublishedBriefing>> = null;
let recentStories: Awaited<ReturnType<typeof getPublishedStories>> = [];

try {
  const db = Astro.locals.runtime.env.DB;
  briefing = await getLatestPublishedBriefing(db, "weekly");
  if (!briefing) {
    recentStories = await getPublishedStories(db, { limit: 10 });
  }
} catch {
  console.error(JSON.stringify({ message: "Weekly briefing query failed" }));
}

const briefingItems = briefing?.contentJson ? parsePublishedBriefingItems(briefing.contentJson) : [];
---

<BaseLayout
  title="Weekly Briefing"
  description="Weekly summary of consequential AI developments, benchmark movement, provider changes, and disputed claims."
>
  <div class="wrap" style="max-width:42rem;">
    <nav aria-label="Breadcrumb" class="meta" style="margin-bottom:1.5rem;">
      <a href="/briefing/daily">Briefings</a> &rsaquo; Weekly
    </nav>

    <h1>Weekly Briefing</h1>

    {briefing ? (
      <>
        <p class="meta" style="margin-top:0.25rem;">
          {new Date(briefing.briefingDate).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" })} &middot; {briefing.summary}
        </p>

        {briefingItems.length > 0 ? (
          <section style="margin-top:2rem;">
            <h2>This week's developments</h2>
            <ol style="padding-left:1.25rem;display:flex;flex-direction:column;gap:1rem;">
              {briefingItems.map((item) => (
                <li>
                  <article>
                    <h3 style="font-size:1.05rem;"><a href={`/stories/${item.slug}`}>{item.headline}</a></h3>
                    <EvidenceBadge status={item.evidenceStatus} size="sm" />
                    <p class="meta" style="margin-top:0.25rem;">{item.why}</p>
                  </article>
                </li>
              ))}
            </ol>
          </section>
        ) : (
          <div style="margin-top:2rem;">
            <p>{briefing.summary}</p>
          </div>
        )}
      </>
    ) : recentStories.length > 0 ? (
      <>
        <p style="margin-top:1.5rem;padding:0.75rem;background:var(--surface-2);border-radius:var(--radius);font-size:0.9rem;">
          <strong>No weekly briefing has been published yet.</strong> Below are the latest published stories from this week.
        </p>
        <div style="margin-top:1.5rem;display:flex;flex-direction:column;gap:1rem;">
          {recentStories.map(s => (
            <article class="card">
              <EvidenceBadge status={s.evidenceStatus} size="sm" />
              <h2 style="font-size:1.1rem;margin-top:0.5rem;"><a href={`/stories/${s.slug}`}>{s.headline}</a></h2>
              <p class="meta" style="margin-top:0.25rem;">{s.summary || ""}</p>
            </article>
          ))}
        </div>
      </>
    ) : (
      <div class="card" style="margin-top:1.5rem;padding:2rem;text-align:center;background:var(--surface-2);">
        <p style="font-size:1.1rem;margin-bottom:0.5rem;">No weekly briefing has been published yet</p>
        <p class="meta">
          Weekly briefings are editorially assembled after stories have been published and reviewed.
        </p>
        <p class="meta" style="margin-top:0.5rem;">
          <a href="/feed">Browse published stories &rarr;</a>
        </p>
      </div>
    )}

    <div style="margin-top:2rem;">
      <a href="/rss/daily.xml" style="border:1px solid var(--accent);color:var(--accent);padding:0.5rem 1rem;border-radius:var(--radius);font-size:0.9rem;text-decoration:none;">Subscribe via RSS</a>
    </div>
  </div>
</BaseLayout>
