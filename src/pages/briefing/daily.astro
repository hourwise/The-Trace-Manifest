---
import BaseLayout from "../../layouts/BaseLayout.astro";

const briefingDate = "12 July 2026";
const items = [
  { headline: "New frontier model announced — vendor claims coding SOTA", why: "First major release in six weeks. Independent benchmarks not yet available. Approach with caution.", evidenceStatus: "Vendor-reported", slug: "new-frontier-model-july-2026" },
  { headline: "Open-weight model beats proprietary models on local hardware under 16 GB", why: "Multiple independent tests confirm. Practical impact for local-model users is high.", evidenceStatus: "Confirmed", slug: "open-weight-model-16gb-july-2026" },
  { headline: "Critical prompt injection vulnerability in popular agent framework — patch now", why: "Affects widely deployed agent systems. Exploit is straightforward. Patches available.", evidenceStatus: "Confirmed", slug: "prompt-injection-advisory-july-2026" },
  { headline: "Provider API pricing drops 40% on mid-tier — comparison tables updated", why: "Significant cost reduction for developers. Multiple providers competing on price.", evidenceStatus: "Confirmed", slug: "provider-pricing-drop-july-2026" },
  { headline: "EU AI Act implementation guidance published", why: "Regulatory clarity for EU deployments. Classification thresholds and compliance timelines detailed.", evidenceStatus: "Confirmed", slug: "eu-ai-act-guidance-july-2026" },
];
---

<BaseLayout
  title={`Daily Briefing — ${briefingDate}`}
  description={`Five things that matter in AI today. Model releases, pricing changes, research, security issues, and community discoveries.`}
>
  <div class="container" style="max-width:42rem;">
    <nav aria-label="Breadcrumb" class="meta" style="margin-bottom:1.5rem;">
      <a href="/briefing/daily">Daily Briefing</a> &rsaquo; {briefingDate}
    </nav>

    <h1>Daily Briefing</h1>
    <p class="meta" style="margin-top:0.25rem;">{briefingDate} &middot; Five things that matter today</p>

    <p style="margin-top:1.5rem;padding:0.75rem;background:var(--color-bg-alt);border-radius:var(--radius);font-size:0.9rem;">
      <strong>Note:</strong> This is a static Phase 1 placeholder. Live daily briefings with automated generation begin in Phase 2–3.
    </p>

    <ol style="margin-top:2rem;display:flex;flex-direction:column;gap:1.5rem;padding-left:1.5rem;">
      {items.map((item) => (
        <li>
          <article>
            <h2 style="font-size:1.15rem;"><a href={`/stories/${item.slug}`}>{item.headline}</a></h2>
            <span class={`evidence-label ${item.evidenceStatus === 'Confirmed' ? 'evidence-label--confirmed' : 'evidence-label--vendor'}`} style="margin-top:0.25rem;">{item.evidenceStatus}</span>
            <p class="meta" style="margin-top:0.25rem;"><strong>Why it matters:</strong> {item.why}</p>
          </article>
        </li>
      ))}
    </ol>

    <div style="margin-top:2rem;padding:1rem;background:var(--color-bg-alt);border-radius:var(--radius);">
      <p class="meta">
        <strong>Claims awaiting verification today:</strong> Frontier model coding benchmark claims (vendor-reported only). Check back for independent results.
      </p>
    </div>

    <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;">
      <a href="/rss/daily.xml" style="border:1px solid var(--color-accent);color:var(--color-accent);padding:0.5rem 1rem;border-radius:var(--radius);font-size:0.9rem;text-decoration:none;">Subscribe via RSS</a>
      <a href="/briefing/weekly" style="border:1px solid var(--color-border);color:var(--color-text);padding:0.5rem 1rem;border-radius:var(--radius);font-size:0.9rem;text-decoration:none;">Weekly briefing &rarr;</a>
    </div>
  </div>
</BaseLayout>
