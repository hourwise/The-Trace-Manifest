---
import "../styles/global.css";

// The Trace Manifest — Base Layout (Design System v2)
export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  currentNav?: string;
}
const { title, description, ogImage, currentNav } = Astro.props;
const navItems = [
  { href: "/", label: "Latest" },
  { href: "/briefing/daily", label: "Briefings" },
  { href: "/models", label: "Models" },
  { href: "/benchmarks", label: "Benchmarks" },
  { href: "/knowledge", label: "Knowledge" },
  { href: "/feed", label: "Feed" },
  { href: "/ask", label: "Ask" },
  { href: "/methodology", label: "Methodology" },
];
---
<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="The Trace Manifest" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="The Trace Manifest — Daily Briefing" href="/rss/daily.xml" />
    <title>{title} — The Trace Manifest</title>
  </head>
  <body>
    <a class="sr-only skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <div class="wrap-wide header-inner">
        <a class="wordmark" href="/">
          <span class="wordmark-mark" aria-hidden="true"></span>
          The Trace Manifest
        </a>
        <nav class="nav-desktop" aria-label="Primary">
          {navItems.map(item => (
            <a href={item.href} aria-current={currentNav === item.label ? "page" : undefined}>{item.label}</a>
          ))}
        </nav>
        <div class="header-actions">
          <button type="button" class="btn-icon" id="theme-toggle" aria-pressed="false" aria-label="Switch to light mode" title="Theme">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
          </button>
          <a class="btn btn-primary btn-sm" href="/briefing/daily">Subscribe</a>
          <button type="button" class="btn-icon mobile-nav-toggle" id="mobile-nav-toggle" aria-controls="mobile-drawer" aria-expanded="false" aria-label="Open menu">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
          </button>
        </div>
      </div>
      <div class="mobile-drawer" id="mobile-drawer">
        <nav aria-label="Mobile">
          {navItems.map(item => (
            <a href={item.href} aria-current={currentNav === item.label ? "page" : undefined}>{item.label}</a>
          ))}
        </nav>
        <div class="mobile-drawer-actions">
          <a class="btn btn-secondary" href="/corrections">Corrections</a>
          <a class="btn btn-primary" href="/briefing/daily">Subscribe</a>
        </div>
      </div>
    </header>
    <main id="main-content"><slot /></main>
    <footer class="site-footer">
      <div class="wrap-wide">
        <div class="footer-grid">
          <div><h4>The Trace Manifest</h4><p class="meta" style="max-width:28ch;">Follow the evidence. Understand the change.</p></div>
          <div><h4>Browse</h4><a href="/feed">Feed</a><a href="/knowledge">Knowledge Base</a><a href="/models">Models</a><a href="/benchmarks">Benchmarks</a><a href="/briefing/daily">Daily Briefing</a><a href="/ask">Ask</a></div>
          <div><h4>About</h4><a href="/methodology">Methodology</a><a href="/corrections">Corrections</a><a href="/rss/daily.xml">RSS</a></div>
        </div>
        <div class="footer-bottom">
          <span>&copy; {new Date().getFullYear()} The Trace Manifest</span>
          <a href="https://www.pcgsoft.co.uk" target="_blank" rel="noopener">pcgsoft.co.uk</a>
          <a href="https://github.com/hourwise" target="_blank" rel="noopener">github.com/hourwise</a>
        </div>
      </div>
    </footer>
    <script>
      // Theme toggle
      (function() {
        const stored = localStorage.getItem('theme');
        if (stored === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
      const themeToggle = document.getElementById('theme-toggle');
      if (themeToggle) {
        themeToggle.addEventListener('click', () => {
          const current = document.documentElement.getAttribute('data-theme');
          const next = current === 'light' ? 'dark' : 'light';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
          themeToggle.setAttribute('aria-label', next === 'light' ? 'Switch to dark mode' : 'Switch to light mode');
          themeToggle.setAttribute('aria-pressed', next === 'light' ? 'true' : 'false');
        });
        // Sync initial state
        const initial = document.documentElement.getAttribute('data-theme');
        themeToggle.setAttribute('aria-label', initial === 'light' ? 'Switch to dark mode' : 'Switch to light mode');
        themeToggle.setAttribute('aria-pressed', initial === 'light' ? 'true' : 'false');
      }

      // Mobile drawer
      const drawerToggle = document.getElementById('mobile-nav-toggle');
      const drawer = document.getElementById('mobile-drawer');
      if (drawerToggle && drawer) {
        drawerToggle.addEventListener('click', () => {
          const expanded = drawerToggle.getAttribute('aria-expanded') === 'true';
          drawerToggle.setAttribute('aria-expanded', String(!expanded));
          drawer.classList.toggle('open', !expanded);
        });
        // Close drawer when a link inside is clicked
        drawer.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            drawerToggle.setAttribute('aria-expanded', 'false');
            drawer.classList.remove('open');
          });
        });
      }
    </script>
  </body>
</html>
