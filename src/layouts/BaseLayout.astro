---
// Base layout for all pages
export interface Props {
  title: string;
  description: string;
  ogImage?: string;
}
const { title, description, ogImage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="The Trace Manifest" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="The Trace Manifest — Daily Briefing" href="/rss/daily.xml" />
    <title>{title} — The Trace Manifest</title>
  </head>
  <body>
    <a href="#main-content" class="sr-only" style="top:0;left:0;z-index:9999;background:var(--color-accent);color:#fff;padding:0.5rem 1rem;">
      Skip to main content
    </a>
    <header>
      <nav class="container" aria-label="Main navigation" style="display:flex;align-items:center;justify-content:space-between;padding-top:1rem;padding-bottom:1rem;border-bottom:1px solid var(--color-border);">
        <a href="/" style="font-weight:700;font-size:1.25rem;color:var(--color-text);text-decoration:none;">
          The Trace Manifest
        </a>
        <ul style="display:flex;gap:1.5rem;list-style:none;flex-wrap:wrap;" role="list">
          <li><a href="/feed">Feed</a></li>
          <li><a href="/models">Models</a></li>
          <li><a href="/benchmarks">Benchmarks</a></li>
          <li><a href="/briefing/daily">Daily Briefing</a></li>
          <li><a href="/ask">Ask</a></li>
          <li><a href="/methodology">Methodology</a></li>
        </ul>
      </nav>
    </header>
    <main id="main-content" style="flex:1;padding:2rem 0;">
      <slot />
    </main>
    <footer style="border-top:1px solid var(--color-border);padding:2rem 0;margin-top:3rem;font-size:0.85rem;color:var(--color-text-muted);">
      <div class="container">
        <div class="grid grid--3">
          <div>
            <p style="font-weight:600;color:var(--color-text);margin-bottom:0.5rem;">The Trace Manifest</p>
            <p>Follow the evidence. Understand the change.</p>
          </div>
          <div>
            <p style="font-weight:600;color:var(--color-text);margin-bottom:0.5rem;">Pages</p>
            <ul style="list-style:none;display:flex;flex-direction:column;gap:0.25rem;" role="list">
              <li><a href="/feed">Feed</a></li>
              <li><a href="/models">Models</a></li>
              <li><a href="/benchmarks">Benchmarks</a></li>
              <li><a href="/briefing/daily">Daily Briefing</a></li>
              <li><a href="/corrections">Corrections Ledger</a></li>
            </ul>
          </div>
          <div>
            <p style="font-weight:600;color:var(--color-text);margin-bottom:0.5rem;">About</p>
            <ul style="list-style:none;display:flex;flex-direction:column;gap:0.25rem;" role="list">
              <li><a href="/methodology">Methodology</a></li>
              <li><a href="/ask">Ask</a></li>
              <li><a href="/rss/daily.xml">RSS</a></li>
            </ul>
          </div>
        </div>
        <p style="margin-top:1.5rem;">&copy; {new Date().getFullYear()} The Trace Manifest. Content available under licence. <a href="/corrections">Corrections</a> remain public.</p>
      </div>
    </footer>
  </body>
</html>
