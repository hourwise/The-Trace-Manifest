---
// ADR 0009: Public social-signal card. Only approved signals appear.
export interface SocialCardProps {
  platform: string;
  traceSummary: string;
  authorDisplayName?: string | null;
  authorHandle?: string | null;
  canonicalUrl: string;
  corroborationStatus: string;
  evidenceStatus: string;
  linkedSourceCount: number;
}

const { platform, traceSummary, authorDisplayName, authorHandle, canonicalUrl, corroborationStatus, evidenceStatus, linkedSourceCount } = Astro.props;

const platformLabel: Record<string, string> = {
  reddit: "Reddit", x: "X", bluesky: "Bluesky", mastodon: "Mastodon",
  linkedin: "LinkedIn", youtube: "YouTube", "github-discussion": "GitHub Discussion",
  forum: "Forum", "other-approved": "Community",
};

const corrLabel: Record<string, string> = {
  "not-checked": "Not checked",
  "none-found": "Uncorroborated",
  "partially-corroborated": "Partially corroborated",
  "corroborated": "Corroborated",
  "contradicted": "Contradicted",
};
---

<div class="card" style="border-left:3px solid var(--accent);padding:0.75rem 1rem;margin-bottom:1rem;">
  <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;margin-bottom:0.5rem;">
    <span class="badge badge-sm" style="font-size:0.65rem;background:var(--accent);color:white;">{platformLabel[platform] ?? platform}</span>
    <span class="badge badge-sm" style="font-size:0.65rem;">COMMUNITY SIGNAL</span>
    <span class="meta" style="font-size:0.7rem;">{corrLabel[corroborationStatus] ?? corroborationStatus}</span>
    {linkedSourceCount > 0 ? <span class="meta" style="font-size:0.7rem;">{linkedSourceCount} linked source{linkedSourceCount !== 1 ? "s" : ""}</span> : null}
  </div>
  <p style="font-size:0.9rem;margin-bottom:0.5rem;line-height:1.5;">{traceSummary}</p>
  <div style="display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap;">
    {authorDisplayName ? <span class="meta" style="font-size:0.75rem;">{authorDisplayName}{authorHandle ? ` (${authorHandle})` : ""}</span> : null}
    <a href={canonicalUrl} target="_blank" rel="noopener" class="meta" style="font-size:0.75rem;font-weight:550;">Open original &rarr;</a>
  </div>
</div>
